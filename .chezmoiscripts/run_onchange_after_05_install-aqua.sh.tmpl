#!/bin/bash

set -euo pipefail

echo ":: [05] Installing aqua"

# --- Version (pinned in .chezmoidata/versions.yaml, auto-updated by GitHub Actions) ---
AQUA_INSTALLER_VERSION="${AQUA_INSTALLER_VERSION:-{{ .versions.aquaInstaller }}}"
AQUA_INSTALLER_SHA256="{{ .versions.aquaInstallerSha256 }}"
AQUA_PINNED_VERSION="{{ .versions.aquaVersion }}"
AQUA_TARGET_VERSION="${AQUA_VERSION:-$AQUA_PINNED_VERSION}"

AQUA_BIN_DIR="${AQUA_ROOT_DIR:-${XDG_DATA_HOME:-$HOME/.local/share}/aquaproj-aqua}/bin"
AQUA_BIN="${AQUA_BIN_DIR}/aqua"

case "$(uname -s)" in
Darwin | Linux) ;;
*)
    echo "    Skipped (unsupported OS: $(uname -s))"
    exit 0
    ;;
esac

AQUA_INSTALLER_URL="https://raw.githubusercontent.com/aquaproj/aqua-installer/${AQUA_INSTALLER_VERSION}/aqua-installer"

normalize_version() {
    # Strip optional leading "v" for comparison (v2.56.6 vs 2.56.6)
    local version="${1:-}"
    echo "${version#v}"
}

calc_sha256() {
    local file="$1"
    if command -v sha256sum &>/dev/null; then
        sha256sum "$file" | awk '{print $1}'
        return 0
    fi
    if command -v shasum &>/dev/null; then
        shasum -a 256 "$file" | awk '{print $1}'
        return 0
    fi
    if command -v openssl &>/dev/null; then
        openssl dgst -sha256 "$file" | awk '{print $2}'
        return 0
    fi
    return 1
}

detect_aqua_cmd() {
    if command -v aqua &>/dev/null; then
        command -v aqua
        return 0
    fi
    if [[ -x "$AQUA_BIN" ]]; then
        echo "$AQUA_BIN"
        return 0
    fi
    return 1
}

current_aqua_version() {
    local cmd="$1"
    # "aqua -v" output: aqua version 2.56.6 (...)
    "$cmd" -v 2>/dev/null | awk '{print $3}'
}

aqua_cmd=""
if aqua_cmd="$(detect_aqua_cmd)"; then
    current_version="$(current_aqua_version "$aqua_cmd")"
    current_normalized="$(normalize_version "$current_version")"
    target_normalized="$(normalize_version "$AQUA_TARGET_VERSION")"
    echo "    current: ${current_version:-unknown}, pinned: ${AQUA_TARGET_VERSION}"

    if [[ -n "$AQUA_TARGET_VERSION" ]] && [[ "$current_normalized" == "$target_normalized" ]]; then
        echo "    Skipped (already on pinned version)"
        exit 0
    fi

    # Aqua exists but at a different version — upgrade directly.
    # This avoids the aqua-installer bootstrap dance entirely and also sidesteps
    # an upstream bug where `rm -R` (without -f) prompts on macOS for each
    # read-only file in the temp dir (the tarball ships third_party_licenses/*
    # as r--r--r--, and BSD rm prompts "override?" when stdin is a tty).
    if [[ -n "$AQUA_TARGET_VERSION" ]]; then
        echo "    Updating via 'aqua update-aqua ${AQUA_TARGET_VERSION}'..."
        if "$aqua_cmd" update-aqua "$AQUA_TARGET_VERSION"; then
            installed_version="$(current_aqua_version "$aqua_cmd")"
            echo "    Installed: ${installed_version:-unknown}"
            exit 0
        fi
        echo "    update-aqua failed, falling back to full installer"
    fi
fi

if [[ -z "${AQUA_INSTALLER_SHA256:-}" ]]; then
    echo "    Error: AQUA_INSTALLER_SHA256 is empty"
    exit 1
fi

installer_file="$(mktemp "${TMPDIR:-/tmp}/aqua-installer.XXXXXX")"
cleanup() {
    rm -f "$installer_file" "${installer_file}.bak"
}
trap cleanup EXIT

if command -v curl &>/dev/null; then
    curl -fsSL "$AQUA_INSTALLER_URL" -o "$installer_file"
elif command -v wget &>/dev/null; then
    wget -qO "$installer_file" "$AQUA_INSTALLER_URL"
else
    echo "    Error: curl or wget is required to install aqua"
    exit 1
fi

if ! installer_sha256="$(calc_sha256 "$installer_file")"; then
    echo "    Error: no SHA-256 tool is available (need sha256sum/shasum/openssl)"
    exit 1
fi

expected_sha256="$(echo "$AQUA_INSTALLER_SHA256" | tr '[:upper:]' '[:lower:]')"
actual_sha256="$(echo "$installer_sha256" | tr '[:upper:]' '[:lower:]')"
if [[ "$actual_sha256" != "$expected_sha256" ]]; then
    echo "    Error: aqua-installer checksum mismatch"
    echo "    expected: $expected_sha256"
    echo "    actual:   $actual_sha256"
    exit 1
fi

# Workaround: upstream aqua-installer uses `rm -R "$tempdir"` at the end, which
# on macOS prompts "override r--r--r--?" for each read-only file when stdin is a
# tty.  The tarball ships third_party_licenses/* as read-only, so the cleanup
# stalls indefinitely in interactive terminals.  Patch to `rm -rf`.
# Ref: https://github.com/aquaproj/aqua-installer (as of v4.0.4)
sed -i.bak 's/rm -R "\$tempdir"/rm -rf "\$tempdir"/' "$installer_file"

chmod +x "$installer_file"
if [[ -n "$AQUA_TARGET_VERSION" ]]; then
    "$installer_file" -v "$AQUA_TARGET_VERSION"
else
    "$installer_file"
fi

if aqua_cmd="$(detect_aqua_cmd)"; then
    installed_version="$(current_aqua_version "$aqua_cmd")"
    echo "    Installed: ${installed_version:-unknown}"
else
    echo "    Error: aqua installation failed (command not found after install)"
    exit 1
fi

if [[ ! -x "$AQUA_BIN" ]]; then
    echo "    Error: aqua installation failed (binary not found at ${AQUA_BIN})"
    exit 1
fi
