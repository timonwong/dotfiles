# chezmoi external dependencies
# Run `chezmoi apply` to install/update
# Run `chezmoi -R apply` to force refresh

# ==============================================================================
# TPM (Tmux Plugin Manager)
# After chezmoi apply, run `prefix + I` in tmux to install plugins
# ==============================================================================
[".config/tmux/plugins/tpm"]
    type = "git-repo"
    url = "https://github.com/tmux-plugins/tpm.git"
    refreshPeriod = "168h"

# ==============================================================================
# Shared AI Tools Plugins
# Skills are shared between Claude Code and Codex CLI via ~/.agents/skills/
# Agents and commands remain in ~/.claude/ (Claude Code specific)
# Hardcoded plugin/skill lists in this template are the single source of truth
# ==============================================================================

# ------------------------------------------------------------------------------
# Shared AI Skills (hardcoded baseline for Claude + Codex)
# ------------------------------------------------------------------------------

# ------------------------------------------------------------------------------
# NowledgeMem community skills pack
# - Namespace: .agents/skills/nowledge-mem/
# - Keep this focused on curated third-party packs that don't fit ecosystem/*
# ------------------------------------------------------------------------------
{{- $nowledgeCommunitySkills := list
  "distill-memory"
  "read-working-memory"
  "save-thread"
  "search-memory"
}}
{{- range $skill := $nowledgeCommunitySkills }}
[".agents/skills/nowledge-mem/{{ $skill }}"]
    type = "archive"
    url = "https://github.com/nowledge-co/community/archive/{{ $.versions.nowledgeCommunityRev }}.tar.gz"
    checksum.sha256 = "{{ $.versions.nowledgeCommunitySha256 }}"
    exact = true
    stripComponents = 3
    include = [
      "community-*/nowledge-mem-npx-skills/skills/{{ $skill }}/**"
    ]
    refreshPeriod = "168h"

{{- end }}

# ------------------------------------------------------------------------------
# obra/superpowers (skills only)
# - Keep only OpenSpec-complementary skills
# - Hardcoded skill list
# ------------------------------------------------------------------------------
[".agents/skills/superpowers"]
    type = "archive"
    url = "https://github.com/obra/superpowers/archive/{{ $.versions.claudeSuperpowersRev }}.tar.gz"
    checksum.sha256 = "{{ $.versions.claudeSuperpowersSha256 }}"
    exact = true
    stripComponents = 2
    include = [
      "superpowers-*/skills/brainstorming/**",
      "superpowers-*/skills/writing-plans/**",
      "superpowers-*/skills/executing-plans/**",
      "superpowers-*/skills/test-driven-development/**",
      "superpowers-*/skills/using-git-worktrees/**",
      "superpowers-*/skills/finishing-a-development-branch/**",
      "superpowers-*/skills/systematic-debugging/**",
      "superpowers-*/skills/verification-before-completion/**",
      "superpowers-*/skills/requesting-code-review/**",
      "superpowers-*/skills/receiving-code-review/**"
    ]
    refreshPeriod = "168h"

# ------------------------------------------------------------------------------
# anthropics/skills (source-available, NOT open source)
# License: https://github.com/anthropics/skills - see LICENSE.txt in each skill
# Skills go to .agents/skills/anthropics/{skill}/ (Shared)
# - Hardcoded skill list
# ------------------------------------------------------------------------------
{{- $anthropicsSkills := list
  "pdf"
  "docx"
  "pptx"
  "xlsx"
  "skill-creator"
  "mcp-builder"
  "canvas-design"
  "webapp-testing"
  "doc-coauthoring"
  "internal-comms"
  "brand-guidelines"
  "theme-factory"
  "web-artifacts-builder"
  "algorithmic-art"
  "slack-gif-creator"
}}

{{- range $skill := $anthropicsSkills }}
[".agents/skills/anthropics/{{ $skill }}"]
    type = "archive"
    url = "https://github.com/anthropics/skills/archive/{{ $.versions.claudeAnthropicsSkillsRev }}.tar.gz"
    checksum.sha256 = "{{ $.versions.claudeAnthropicsSkillsSha256 }}"
    exact = true
    stripComponents = 3
    include = ["skills-*/skills/{{ $skill }}/**"]
    refreshPeriod = "168h"

{{ end }}

# ------------------------------------------------------------------------------
# Ecosystem skills pack (official upstream, cross-domain)
# - Namespace: .agents/skills/ecosystem/
# - Keep this focused on high-signal, actively maintained skills
# ------------------------------------------------------------------------------

# ------------------------------------------------------------------------------
# openai/skills curated set
# ------------------------------------------------------------------------------
{{- $openaiCuratedSkills := list
  "gh-fix-ci"
  "gh-address-comments"
  "sentry"
  "playwright"
  "vercel-deploy"
  "render-deploy"
  "cloudflare-deploy"
  "security-best-practices"
  "security-threat-model"
  "security-ownership-map"
  "jupyter-notebook"
  "screenshot"
  "speech"
  "transcribe"
  "netlify-deploy"
}}
{{- range $skill := $openaiCuratedSkills }}
[".agents/skills/ecosystem/openai/{{ $skill }}"]
    type = "archive"
    url = "https://github.com/openai/skills/archive/{{ $.versions.openaiSkillsRev }}.tar.gz"
    exact = true
    stripComponents = 4
    include = ["skills-*/skills/.curated/{{ $skill }}/**"]
    refreshPeriod = "168h"

{{- end }}

