{{- $resolvedProvider := "harui@private" -}}
{{- $model := "gpt-5.3-codex" -}}
{{- $modelRef := printf "%s/%s" $resolvedProvider $model -}}
{{- $providerKeys := list "openai@private" "deepseek@private" "doubao@private" "glm@private" "harui@private" "kimi@private" "minimax@private" "naapi@private" "qwen@private" -}}
{{- $providerApiKeys := dict -}}
{{- range $providerKey := $providerKeys -}}
{{-   $providerApiPath := printf "opencode/%s/api_key" (replace "@" "/" $providerKey) -}}
{{-   $providerApiKeyCmd := printf "command -v gopass >/dev/null 2>&1 || exit 0; p='%s'; if gopass list -f \"$p\" >/dev/null 2>&1; then gopass show --password \"$p\" | head -n 1; fi" $providerApiPath -}}
{{-   $_ := set $providerApiKeys $providerKey ((output "sh" "-c" $providerApiKeyCmd) | trim) -}}
{{- end -}}
{
  "$schema": "https://opencode.ai/config.json",
  "theme": "dracula",
  "model": {{ $modelRef | quote }},
  "small_model": {{ $modelRef | quote }},
  "instructions": [
    "AGENTS.md",
    ".opencode/AGENTS.md"
  ],
  "command": {
    "doctor-all": {
      "description": "Run all AI workflow diagnostics and summarize findings.",
      "agent": "build",
      "template": "Run `claude-manage doctor`, `codex-manage doctor`, and `opencode mcp list`. Report failures first, then warnings, then concrete remediation steps. If Tavily / Context7 / Serena MCP is missing from OpenCode output, include remediation to restore `mcp.tavily`, `mcp.context7`, and `mcp.serena` in opencode config and re-run `chezmoi apply`."
    },
    "spec-verify": {
      "description": "Validate current OpenSpec change and repository tests.",
      "agent": "build",
      "template": "Run `openspec validate <change-name>` and `bash tests/run.sh`. Report failing commands with likely root causes."
    }
  },
  "default_agent": "build",
  "agent": {
    "build": {
      "model": {{ $modelRef | quote }},
      "variant": "xhigh",
      "options": {
        "store": false
      },
      "description": "Default implementation agent for daily coding work."
    },
    "plan": {
      "model": {{ $modelRef | quote }},
      "variant": "xhigh",
      "options": {
        "store": false
      },
      "description": "Planning agent for multi-step and spec-first tasks."
    }
  },
  "watcher": {
    "ignore": [
      "**/.git/**",
      "**/node_modules/**",
      "**/.direnv/**",
      "**/.cache/**",
      "**/.sisyphus/**"
    ]
  },
  "lsp": {
    "rust-analyzer": {
      "command": ["rust-analyzer"],
      "extensions": [".rs"]
    },
    "lua-language-server": {
      "command": ["lua-language-server"],
      "extensions": [".lua"]
    },
    "typescript-language-server": {
      "command": ["typescript-language-server", "--stdio"],
      "extensions": [".ts", ".tsx", ".js", ".jsx"],
      "disabled": true
    },
    "basedpyright": {
      "command": ["basedpyright-langserver", "--stdio"],
      "extensions": [".py"],
      "disabled": true
    }
  },
  "formatter": {
    "rustfmt": {
      "command": ["rustfmt"],
      "extensions": [".rs"]
    },
    "ruff-format": {
      "command": ["ruff", "format"],
      "extensions": [".py"]
    },
    "prettier": {
      "command": ["prettier", "--write"],
      "extensions": [".js", ".jsx", ".ts", ".tsx", ".json", ".md", ".yaml", ".yml"],
      "disabled": true
    },
    "stylua": {
      "command": ["stylua"],
      "extensions": [".lua"],
      "disabled": true
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 16384
  },
  "share": "manual",
  "autoupdate": "notify",
  "tui": {
    "diff_style": "auto",
    "scroll_speed": 2.5,
    "scroll_acceleration": {
      "enabled": true
    }
  },
  "provider": {
    "openai@private": {
      "npm": "@ai-sdk/openai",
      "name": "openai@private",
      "env": ["OPENAI_API_KEY"],
      "options": { {{- if ne (get $providerApiKeys "openai@private") "" }}
        "apiKey": {{ get $providerApiKeys "openai@private" | quote }} {{- end }}
      }
    },
    "deepseek@private": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "deepseek@private",
      "env": ["DEEPSEEK_API_KEY"],
      "options": {
        "baseURL": "https://api.deepseek.com/v1"{{- if ne (get $providerApiKeys "deepseek@private") "" }},
        "apiKey": {{ get $providerApiKeys "deepseek@private" | quote }}{{- end }}
      },
      "models": {
        "deepseek-chat": {
          "name": "DeepSeek Chat",
          "options": {
            "store": false
          },
          "variants": {
            "low": {},
            "medium": {},
            "high": {},
            "xhigh": {}
          }
        },
        "deepseek-reasoner": {
          "name": "DeepSeek Reasoner",
          "options": {
            "store": false
          },
          "variants": {
            "low": {},
            "medium": {},
            "high": {},
            "xhigh": {}
          }
        }
      }
    },
    "doubao@private": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "doubao@private",
      "env": ["ARK_API_KEY"],
      "options": {
        "baseURL": "https://ark.cn-beijing.volces.com/api/v3"{{- if ne (get $providerApiKeys "doubao@private") "" }},
        "apiKey": {{ get $providerApiKeys "doubao@private" | quote }}{{- end }}
      },
      "models": {
        "ark-code-latest": {
          "name": "Doubao Ark Code Latest",
          "options": {
            "store": false
          },
          "variants": {
            "low": {},
            "medium": {},
            "high": {},
            "xhigh": {}
          }
        }
      }
    },
    "glm@private": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "glm@private",
      "env": ["ZHIPU_API_KEY"],
      "options": {
        "baseURL": "https://open.bigmodel.cn/api/paas/v4"{{- if ne (get $providerApiKeys "glm@private") "" }},
        "apiKey": {{ get $providerApiKeys "glm@private" | quote }}{{- end }}
      },
      "models": {
        "glm-4.7": {
          "name": "GLM 4.7",
          "options": {
            "store": false
          },
          "variants": {
            "low": {},
            "medium": {},
            "high": {},
            "xhigh": {}
          }
        },
        "glm-4.5-air": {
          "name": "GLM 4.5 Air",
          "options": {
            "store": false
          },
          "variants": {
            "low": {},
            "medium": {},
            "high": {},
            "xhigh": {}
