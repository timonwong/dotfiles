# ------------------------------------------------------------------------------
# Multilingual Humanizer pack (multilingual namespace layout)
# - Shared for Claude + Codex under ~/.agents/skills/multilingual/
# - Keep stable language-suffixed names:
#   - multilingual/humanizer-en
#   - multilingual/stop-slop-en
#   - multilingual/humanizer-zh
# - Commit-pinned via revisions in .chezmoidata/versions.yaml
# ------------------------------------------------------------------------------

[".agents/skills/multilingual/humanizer-en"]
    type = "archive"
    url = "https://github.com/blader/humanizer/archive/{{ $.versions.humanizerEnRev }}.tar.gz"
    exact = true
    stripComponents = 1
    include = [
      "humanizer-*/SKILL.md",
      "humanizer-*/README.md"
    ]
    refreshPeriod = "168h"

[".agents/skills/multilingual/stop-slop-en"]
    type = "archive"
    url = "https://github.com/hardikpandya/stop-slop/archive/{{ $.versions.stopSlopEnRev }}.tar.gz"
    exact = true
    stripComponents = 1
    include = [
      "stop-slop-*/SKILL.md",
      "stop-slop-*/README.md",
      "stop-slop-*/references/**",
      "stop-slop-*/LICENSE"
    ]
    refreshPeriod = "168h"

[".agents/skills/multilingual/humanizer-zh"]
    type = "archive"
    url = "https://github.com/op7418/Humanizer-zh/archive/{{ $.versions.humanizerZhRev }}.tar.gz"
    exact = true
    stripComponents = 1
    include = [
      "Humanizer-zh-*/SKILL.md",
