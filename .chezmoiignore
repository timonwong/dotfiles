init.sh
docs/
node_modules/
selene.toml
stylua.toml
treefmt.toml

# ─────────────────────────────────────────────────────────────────────────────
# macOS-only exclusions (skip on Linux)
# ─────────────────────────────────────────────────────────────────────────────
{{- if ne .chezmoi.os "darwin" }}
# macOS-specific nix modules (these are source paths, OK for non-script files)
nix-config/modules/system.nix
nix-config/modules/apps.nix
nix-config/modules/host-users.nix

# macOS-specific scripts (target paths)
.chezmoiscripts/02_init.sh
.chezmoiscripts/10_update_homebrew_packages.sh

# macOS-only GUI apps (target paths)
.config/karabiner/
.config/ghostty/
Library/Rime/
{{- end }}

# ─────────────────────────────────────────────────────────────────────────────
# Linux-only exclusions (skip on macOS)
# ─────────────────────────────────────────────────────────────────────────────
{{- if eq .chezmoi.os "darwin" }}
.config/ibus/rime/
{{- end }}

# ─────────────────────────────────────────────────────────────────────────────
# Headless/server exclusions (no GUI, reserved for future use)
# ─────────────────────────────────────────────────────────────────────────────
{{- if .headless }}
# GUI apps (not needed on headless servers)
.config/karabiner/
.config/ghostty/
{{- end }}

# ─────────────────────────────────────────────────────────────────────────────
# Rime runtime artifacts (never sync generated state back into chezmoi)
# ─────────────────────────────────────────────────────────────────────────────
Library/Rime/build/
Library/Rime/installation.yaml
Library/Rime/user.yaml
Library/Rime/*.userdb*
Library/Rime/*.log
.config/ibus/rime/build/
.config/ibus/rime/installation.yaml
.config/ibus/rime/user.yaml
.config/ibus/rime/*.userdb*
.config/ibus/rime/*.log

# ─────────────────────────────────────────────────────────────────────────────
# skimi skills are synced by .chezmoiscripts/run_onchange_after_10_sync-skimi
# ─────────────────────────────────────────────────────────────────────────────
.config/skimi/skills/

# ─────────────────────────────────────────────────────────────────────────────
# Encryption-related exclusions (skip when useEncryption is false)
# ─────────────────────────────────────────────────────────────────────────────
{{- if not .useEncryption }}
.chezmoiscripts/01_setup-encryption-key.sh
.chezmoiscripts/04_setup-gopass.sh
{{- end }}

