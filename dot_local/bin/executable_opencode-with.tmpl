#!/usr/bin/env bash
# OpenCode Launcher
# Launch opencode with any account via environment variable injection
#
# Usage:
#   opencode-with                      # fzf interactive picker
#   opencode-with <account> [args]     # Launch with account + opencode args
#   opencode-with -h                   # Show help

set -euo pipefail

# shellcheck source=lib/ai/opencode.tmpl
# shellcheck disable=SC1091
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
source "$SCRIPT_DIR/lib/ai/opencode"

get_compatibility_mode() {
    local mode="strict"
    mode=$(chezmoi data --format json 2>/dev/null | jq -r '.opencodeCompatibilityMode // "strict"' 2>/dev/null || echo "strict")
    case "$mode" in
        compat) echo "compat" ;;
        *) echo "strict" ;;
    esac
}

merge_config_content() {
    local override="$1"
    if [[ -z "${OPENCODE_CONFIG_CONTENT:-}" ]]; then
        printf '%s' "$override"
        return 0
    fi

    if ! echo "$OPENCODE_CONFIG_CONTENT" | jq -e . >/dev/null 2>&1; then
        printf '%s' "$override"
        return 0
    fi

    jq -cn \
        --argjson base "$OPENCODE_CONFIG_CONTENT" \
        --argjson override "$override" \
        '$base * $override' 2>/dev/null || printf '%s' "$override"
}

# FZF picker with shortcuts
fzf_select() {
    local selected
    selected=$(build_account_list_with_token | fzf --ansi \
        --height=50% \
        --border=rounded \
        --header="Launch OpenCode" \
        --preview="$ACCOUNT_PREVIEW"'
            echo ""
            echo -e "\033[1;34m━━━ Shortcuts ━━━\033[0m"
            echo ""
            echo "  Enter     Launch"
        ' \
        --preview-window='right:50%:wrap' \
        --preview-label="[ Select and press Enter ]" \
        --bind='enter:accept' \
        --print-query) || true

    [[ -z "$selected" ]] && return 1

    # Parse output: first line is query (args), second is selection
    local query selection
    query=$(echo "$selected" | head -1)
    selection=$(echo "$selected" | tail -1)

    [[ -z "$selection" ]] && return 1

    # Extract account name
    local account
    account="${selection#* }"

    if [[ -n "$query" ]]; then
        echo "$account|$query"
    else
        echo "$account|"
    fi
}

# Launch opencode with account
launch_opencode() {
    local account="$1"
    shift

    if ! is_runtime_account "$account"; then
        log_error "Unknown account '$account'"
        echo "Available accounts:" >&2
        list_runtime_accounts | sed 's/^/  /' >&2 || true
        return 1
    fi

    local config provider model_ref base_url env_var
    config=$(opencode-token --config "$account")
    provider=$(echo "$config" | jq -r '.provider // empty')
    model_ref=$(echo "$config" | jq -r '.model_ref // empty')
    base_url=$(echo "$config" | jq -r '.base_url // empty')
    env_var=$(echo "$config" | jq -r '.env_var // empty')

    [[ -z "$provider" ]] && provider=$(get_provider "$account")
    [[ -z "$model_ref" ]] && model_ref="${provider}/$(get_provider_default_model "$provider")"

    local api_key=""
    if is_third_party "$provider"; then
        if command -v gopass >/dev/null 2>&1; then
            if opencode-token --check "$account" 2>/dev/null; then
                local parsed acct_name
                parsed=$(parse_provider_account "$account")
                acct_name="${parsed#*|}"
                api_key=$(get_api_key "$provider" "$acct_name") || {
                    log_warn "Failed to retrieve API key (launching without env)"
                    api_key=""
                }
            else
                log_warn "No API token for $account (launching without env)"
            fi
        else
            log_warn "gopass not found (launching without env)"
        fi
    fi

    local override merged
    override=$(jq -cn --arg model "$model_ref" '{model: $model, small_model: $model}')
    merged=$(merge_config_content "$override")
    local compat_mode
    compat_mode=$(get_compatibility_mode)

    echo -e "${GREEN}Launching opencode with ${CYAN}$account${NC}"
    echo -e "  Model: ${model_ref}"
    if [[ -n "$base_url" ]]; then
        echo -e "  URL:   ${base_url}"
    fi
    echo -e "  Mode:  ${compat_mode}"
    echo ""

    # strict mode keeps no-Claude isolation; compat mode allows Claude compatibility ingress.
    if [[ -n "$api_key" && -n "$env_var" ]]; then
        if [[ "$compat_mode" == "compat" ]]; then
            exec env \
                OPENCODE_CONFIG_CONTENT="$merged" \
                "$env_var=$api_key" \
                opencode "$@"
        fi

        exec env \
            OPENCODE_DISABLE_CLAUDE_CODE_PROMPT="1" \
            OPENCODE_DISABLE_EXTERNAL_SKILLS="1" \
            OPENCODE_CONFIG_CONTENT="$merged" \
            "$env_var=$api_key" \
            opencode "$@"
    fi

    if [[ "$compat_mode" == "compat" ]]; then
        exec env \
            OPENCODE_CONFIG_CONTENT="$merged" \
            opencode "$@"
    fi

    exec env \
        OPENCODE_DISABLE_CLAUDE_CODE_PROMPT="1" \
        OPENCODE_DISABLE_EXTERNAL_SKILLS="1" \
        OPENCODE_CONFIG_CONTENT="$merged" \
        opencode "$@"
}

# Show help
show_help() {
    cat << 'EOF'
OpenCode Launcher

Usage:
  opencode-with                      Interactive fzf picker
  opencode-with <account> [args]     Launch with account + pass args to opencode
  opencode-with -h, --help           Show this help

Examples:
  opencode-with
  opencode-with openai
  opencode-with deepseek@private -- run "fix tests"
EOF
}

# Main
main() {
    if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
        show_help
        exit 0
    fi

    require_cmd chezmoi jq opencode opencode-token || exit 1

    if [[ $# -eq 0 ]]; then
        require_cmd fzf || exit 1
        local result
        result=$(fzf_select) || exit 0
        local account="${result%%|*}"
        local args_str="${result#*|}"
        local -a args=()
        if [[ -n "$args_str" ]]; then
            while IFS= read -r line; do
                [[ -n "$line" ]] && args+=("$line")
            done < <(split_cli_args "$args_str")
        fi
        launch_opencode "$account" "${args[@]}"
        exit 0
    fi

    local account="$1"
    shift
    launch_opencode "$account" "$@"
}

main "$@"
