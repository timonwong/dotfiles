#!/usr/bin/env bash
# Codex CLI Shared Library
# Common functions for codex-manage
#
# Usage: source lib/ai/codex

# Source shared AI tools library
CODEX_LIB_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
AI_TOOL_CONTEXT="codex"
source "$CODEX_LIB_DIR/core"

# Codex-specific paths
CODEX_CONFIG="${HOME}/.codex/config.toml"
CODEX_AUTH_OPENAI="${HOME}/.codex/auth.openai.json"
CODEX_AUTH="${HOME}/.codex/auth.json"

# Get current Codex account from chezmoi data
get_current() {
    chezmoi data --format json 2>/dev/null | jq -r '.codexProviderAccount // "openai"'
}

# Get current Codex provider from selected account
get_current_provider() {
    local current_account
    current_account=$(get_current)
    get_provider "$current_account"
}

# Check if provider requires OpenAI auth (uses auth.json instead of env_key).
provider_requires_openai_auth() {
    local provider="$1"
    case "$provider" in
{{- range $name, $config := .codex.providers }}
{{- if and (hasKey $config "requires_openai_auth") $config.requires_openai_auth }}
        {{ $name }}) return 0 ;;
{{- end }}
{{- end }}
        *) return 1 ;;
    esac
}

# Validate a TOML key segment (used for dasel selectors).
validate_toml_segment() {
    local segment="$1"
    [[ -n "$segment" && "$segment" =~ ^[A-Za-z0-9_-]+$ ]]
}

validate_toml_path() {
    local path="$1"
    local segment
    IFS='.' read -r -a segments <<< "$path"
    for segment in "${segments[@]}"; do
        validate_toml_segment "$segment" || return 1
    done
}

# Build account list with status indicators
build_account_list_with_status() {
    local current
    current=$(get_current)
    for account in "${ACCOUNTS[@]}"; do
        if [[ "$account" == "$current" ]]; then
            echo -e "${GREEN}$account ✓${NC}"
        else
            echo "$account"
        fi
    done
}

# Build account list with token status
build_account_list_with_token() {
    for account in "${ACCOUNTS[@]}"; do
        local provider
        provider=$(get_provider "$account")
        if is_third_party "$provider"; then
            local parsed acct_name
            parsed=$(parse_provider_account "$account")
            acct_name="${parsed#*|}"
            if key_exists "$provider" "$acct_name"; then
                echo -e "${GREEN}✓${NC} $account"
            else
                echo -e "${RED}✗${NC} $account"
            fi
        else
            echo -e "${CYAN}○${NC} $account"
        fi
    done
}

# Common preview script for account selection
ACCOUNT_PREVIEW='
    line=$(echo {} | sed "s/^[[:space:]]*//")
    if [[ "$line" == "Back" ]]; then
        echo "Return to main menu"
        exit 0
    fi
    account=$(echo "$line" | sed "s/ ✓$//" | sed "s/^[✓✗○] //")
    echo -e "\033[1;34m━━━ $account ━━━\033[0m"
    echo ""
    config=$(codex-token --config "$account" 2>/dev/null)
    if [[ -n "$config" ]]; then
        echo "$config" | jq -r "
            \"Model:     \(.model // \"default\")\",
            \"Provider:  \(.provider // \"auto\")\",
            (if .base_url then \"Base URL:  \(.base_url)\" else empty end)
        " 2>/dev/null || echo "Config not available"
    else
        echo "Config not available"
    fi
    echo ""
    if echo "$config" | jq -e ".base_url // empty" >/dev/null 2>&1; then
        if codex-token --check "$account" 2>/dev/null; then
            echo -e "\033[0;32m✓ Token ready\033[0m"
        else
            echo -e "\033[0;31m✗ No token (run: codex-manage add-key)\033[0m"
        fi
    else
        echo -e "\033[0;36m○ Native OAuth\033[0m"
    fi
'

# Generic account picker with Back option
fzf_pick_account() {
    local header="$1"
    local list_type="${2:-status}"
    local current
    current=$(get_current)

    local result
    if ! result=$({
        case "$list_type" in
            token) build_account_list_with_token ;;
            plain) printf '%s\n' "${ACCOUNTS[@]}" ;;
            *)     build_account_list_with_status ;;
        esac
        echo -e "${YELLOW}Back${NC}"
    } | fzf --ansi \
        --height=50% \
        --border=rounded \
        --header="$header" \
        --preview="$ACCOUNT_PREVIEW" \
        --preview-window='right:50%:wrap' \
        --preview-label="[ Current: $current ]"); then
        return "$RC_EXIT"
    fi

    [[ -z "$result" ]] && return "$RC_EXIT"
    [[ "$result" == "Back" ]] && return "$RC_BACK"

    result=$(echo "$result" | sed 's/ ✓$//' | sed 's/^[[:space:]]*//')
    result=$(echo "$result" | sed 's/^[✓✗○] //')
    echo "$result"
}

# Update Codex config.toml
update_codex_config() {
    local key="$1"
    local value="$2"
    local table="${3:-}"

    if [[ ! -f "$CODEX_CONFIG" ]]; then
        log_error "Codex config not found: $CODEX_CONFIG"
        return 1
    fi

    require_cmd dasel || return 1

    if ! validate_toml_segment "$key"; then
        log_error "Invalid TOML key '$key'"
        return 1
    fi
    if [[ -n "$table" ]] && ! validate_toml_path "$table"; then
        log_error "Invalid TOML table '$table'"
        return 1
    fi

    local selector=".$key"
    if [[ -n "$table" ]]; then
        selector=".$table.$key"
    fi

    if ! dasel put string -p toml -f "$CODEX_CONFIG" "$selector" "$value" >/dev/null; then
        if [[ -n "$table" ]]; then
            log_error "Failed to update codex config key '$key' in table '$table'"
        else
            log_error "Failed to update codex config key '$key'"
        fi
        return 1
    fi
}

# Backup OpenAI auth.json (contains tokens) before overwriting for third-party.
backup_codex_auth_openai() {
    if [[ ! -f "$CODEX_AUTH" ]]; then
        return 0
    fi

    require_cmd jq || return 1

    if jq -e 'has("tokens") or has("refresh_token") or has("access_token") or has("id_token")' "$CODEX_AUTH" >/dev/null 2>&1; then
        cp "$CODEX_AUTH" "$CODEX_AUTH_OPENAI"
    fi
}

# Restore OpenAI auth.json from backup; if missing, delete auth.json.
restore_codex_auth_openai() {
    if [[ -f "$CODEX_AUTH_OPENAI" ]]; then
        cp "$CODEX_AUTH_OPENAI" "$CODEX_AUTH"
    else
        rm -f "$CODEX_AUTH"
    fi
}

# Write minimal auth.json with OPENAI_API_KEY only (no merge).
write_codex_auth_key() {
    local key_value="${1:-}"
    [[ -n "$key_value" ]] || { log_error "Missing API key for Codex auth.json"; return 1; }

    require_cmd jq || return 1

    local auth_dir
    auth_dir="$(dirname -- "$CODEX_AUTH")"
    mkdir -p "$auth_dir" || { log_error "Failed to create $auth_dir"; return 1; }

    local tmp_file
    tmp_file="$(mktemp)" || { log_error "Failed to create temp file"; return 1; }

    if ! jq -n --arg key "$key_value" '{OPENAI_API_KEY: $key}' > "$tmp_file"; then
        rm -f "$tmp_file"
        log_error "Failed to write $CODEX_AUTH"
        return 1
    fi

    mv "$tmp_file" "$CODEX_AUTH"
}
