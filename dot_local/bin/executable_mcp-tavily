#!/usr/bin/env bash
# Tavily MCP wrapper
# Resolve Tavily API key from gopass at runtime, then launch tavily-mcp.

set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
source "$SCRIPT_DIR/lib/common"

require_cmd npx

# Keep path simple as requested.
TAVILY_GOPASS_PATH="tavily/api_key"

# Allow explicit env override for CI/non-interactive runners.
if [[ -z "${TAVILY_API_KEY:-}" ]]; then
    if ! TAVILY_API_KEY="$(gopass_show_secret "$TAVILY_GOPASS_PATH" 3 2>/dev/null)"; then
        log_error "Failed to read Tavily API key from gopass: $TAVILY_GOPASS_PATH"
        exit 1
    fi
fi

if [[ -z "$TAVILY_API_KEY" ]]; then
    log_error "Tavily API key is empty: $TAVILY_GOPASS_PATH"
    exit 1
fi

export TAVILY_API_KEY

# Pin package version for reproducibility.
exec npx -y tavily-mcp@0.2.16 "$@"
