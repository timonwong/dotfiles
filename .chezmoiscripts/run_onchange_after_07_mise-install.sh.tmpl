#!/bin/bash

set -euo pipefail

{{ $miseConfig := joinPath .chezmoi.homeDir ".config/mise/config.toml" -}}
# mise config: {{ if stat $miseConfig }}{{ output "sha256sum" $miseConfig | trim }}{{ else }}n/a{{ end }}

# chezmoi may be updating dot-directories (e.g. ~/.claude). If the current working
# directory disappears mid-apply, mise will warn. Run mise from a stable dir.
cd "$HOME"

# Ensure nix profile tools are discoverable for this non-interactive shell.
{{ include ".chezmoitemplates/shell/source_nix_env.sh" }}
if [[ -d "$HOME/.nix-profile/bin" ]]; then
    export PATH="$HOME/.nix-profile/bin:$PATH"
fi

echo ":: [07] Installing mise tools"

mise_cmd="$HOME/.nix-profile/bin/mise"
mise_runner=()
if [[ -x "$mise_cmd" ]]; then
    mise_runner=("$mise_cmd")
elif command -v mise &>/dev/null; then
    found_mise="$(command -v mise)"
    if [[ "$found_mise" != *"/aquaproj-aqua/bin/mise" ]]; then
        mise_runner=("$found_mise")
    fi
fi

if [[ ${#mise_runner[@]} -eq 0 ]]; then
    if command -v nix &>/dev/null; then
        mise_runner=(nix run nixpkgs#mise --)
    else
        echo "    Skipped (mise and nix not found)"
        exit 0
    fi
fi

if ! "${mise_runner[@]}" --version &>/dev/null; then
    echo "    Skipped (mise command unavailable)"
    exit 0
fi

# Ensure mise shims are available in this non-interactive shell.
eval "$("${mise_runner[@]}" activate bash)"

# npm-backed tools need npm available during version resolution.
# Install node first if npm is still unavailable in this shell.
if ! command -v npm &>/dev/null; then
    "${mise_runner[@]}" install --yes node
    eval "$("${mise_runner[@]}" activate bash)"
fi

"${mise_runner[@]}" install --yes
"${mise_runner[@]}" reshim --yes
