            "high": {},
            "xhigh": {}
          }
        },
        "qwen-flash": {
          "name": "Qwen Flash",
          "options": {
            "store": false
          },
          "variants": {
            "low": {},
            "medium": {},
            "high": {},
            "xhigh": {}
          }
        }
      }
    }
  },
  "skills": {
    "paths": [
      ".agents/skills"
    ]
  },
  "plugin": [
    "oh-my-opencode",
    "opencode-plugin-openspec"
  ],
  "permission": {
    "edit": "ask",
    "bash": "ask",
    "external_directory": "ask",
    "webfetch": "ask",
    "websearch": "ask",
    "codesearch": "ask",
    "lsp": "ask",
    "task": "ask",
    "skill": "ask",
    "doom_loop": "ask"
  }
}
