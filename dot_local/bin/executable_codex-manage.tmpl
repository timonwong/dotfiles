#!/usr/bin/env bash
# Codex CLI Account Manager
# Manage accounts and API keys with fzf interface
#
# Usage:
#   codex-manage                   # Interactive menu
#   codex-manage switch [account]  # Switch default account
#   codex-manage add-account       # Add new account
#   codex-manage edit-account      # Edit account config
#   codex-manage remove-account    # Remove account
#   codex-manage add-key [account] # Add new API key
#   codex-manage update-key [acct] # Update existing API key
#   codex-manage delete-key [acct] # Delete API key
#   codex-manage test [account]    # Test connectivity
#   codex-manage list [provider]   # List accounts

set -euo pipefail

# shellcheck source=lib/ai/codex.tmpl
# shellcheck disable=SC1091
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
source "$SCRIPT_DIR/lib/ai/codex"

# Return codes
: "${RC_BACK:=10}"
: "${RC_EXIT:=130}"

# Set Codex account in chezmoi.toml
set_chezmoi_account() {
    local account="$1"
    local escaped_account
    escaped_account=$(escape_toml_string "$account")
    local tmp_file
    tmp_file=$(mktemp) || { log_error "Failed to create temp file"; return 1; }

    if grep -q "^codexProviderAccount = " "$CHEZMOI_CONFIG"; then
        sed "s/^codexProviderAccount = .*/codexProviderAccount = \"$escaped_account\"/" "$CHEZMOI_CONFIG" > "$tmp_file"
    elif grep -q "^claudeProviderAccount = " "$CHEZMOI_CONFIG"; then
        awk -v line="codexProviderAccount = \"$escaped_account\"" '
            BEGIN { inserted = 0 }
            { print }
            /^claudeProviderAccount = / && inserted == 0 { print line; inserted = 1 }
            END { if (inserted == 0) print line }
        ' "$CHEZMOI_CONFIG" > "$tmp_file"
    elif grep -q "^\[data\]" "$CHEZMOI_CONFIG"; then
        awk -v line="codexProviderAccount = \"$escaped_account\"" '
            BEGIN { inserted = 0; in_data = 0 }
            /^\[data\]$/ { in_data = 1; print; next }
            /^\[/ {
                if (in_data == 1 && inserted == 0) {
                    print line
                    inserted = 1
                }
                in_data = 0
                print
                next
            }
            { print }
            END {
                if (in_data == 1 && inserted == 0) {
                    print line
                }
            }
        ' "$CHEZMOI_CONFIG" > "$tmp_file"
    else
        cp "$CHEZMOI_CONFIG" "$tmp_file"
        {
            echo ""
            echo "[data]"
            echo "codexProviderAccount = \"$escaped_account\""
        } >> "$tmp_file"
    fi
    mv "$tmp_file" "$CHEZMOI_CONFIG"
}
# FZF interactive menu
fzf_menu() {
    while true; do
        local current
        current=$(get_current)

        local selected
        # shellcheck disable=SC2016
        if ! selected=$({
            cat <<'MENU'
switch         Change default account
add-account    Add new account
edit-account   Edit account config
remove-account Remove account
add-key        Add API key
update-key     Update API key
delete-key     Delete API key
test           Test connectivity
list           Show all accounts
MENU
            echo -e "${YELLOW}quit${NC}           Exit to shell"
        } | fzf --ansi \
            --height=50% \
            --border=rounded \
            --header="Codex Account Manager" \
            --preview='
                cmd=$(echo {} | awk "{print \$1}")
                echo -e "\033[1;34m━━━ $cmd ━━━\033[0m"
                echo ""
                case "$cmd" in
                    switch)         echo "Switch the default account." ;;
                    add-account)    echo "Add a new account to codex.yaml." ;;
                    edit-account)   echo "Edit account model settings." ;;
                    remove-account) echo "Remove account from codex.yaml." ;;
                    add-key)        echo "Add API key (must not exist)." ;;
                    update-key)     echo "Update existing API key." ;;
                    delete-key)     echo "Remove API key from gopass." ;;
                    test)           echo "Test API connectivity." ;;
                    list)           echo "Show all accounts." ;;
                    quit)           echo "Exit to shell." ;;
                esac
                echo ""
                echo -e "\033[1;34m━━━ Accounts ━━━\033[0m"
                echo ""
                codex-manage list 2>/dev/null | tail -n +3
            ' \
            --preview-window='right:50%:wrap' \
            --preview-label="[ Current: $current ]"
        ); then
            return "$RC_EXIT"
        fi

        local cmd
        cmd=$(echo "$selected" | awk '{print $1}')

        local rc=0
        case "$cmd" in
            switch)         cmd_switch || rc=$? ;;
            add-account)    cmd_add_account || rc=$? ;;
            edit-account)   cmd_edit_account || rc=$? ;;
            remove-account) cmd_remove_account || rc=$? ;;
            add-key)        cmd_add_key || rc=$? ;;
            update-key)     cmd_update_key || rc=$? ;;
            delete-key)     cmd_delete_key || rc=$? ;;
            test)           cmd_test || rc=$? ;;
            list)           cmd_list || rc=$? ;;
            quit)           return 0 ;;
            *)              log_error "Unknown command: $cmd"; return 1 ;;
        esac

        case "$rc" in
            0) return 0 ;;
            "$RC_BACK") continue ;;
            "$RC_EXIT") return "$RC_EXIT" ;;
            *) return "$rc" ;;
        esac
    done
}

# Switch account
cmd_switch() {
    local input="${1:-}"
    if [[ -z "$input" ]]; then
        if ! input=$(fzf_pick_account "Switch Account"); then
            local rc=$?
            if [[ $rc -eq $RC_BACK || $rc -eq $RC_EXIT ]]; then
                return "$rc"
            fi
            return 1
        fi
    fi

    if ! is_configured_account "$input"; then
        log_error "Unknown account '$input'"
        return 1
    fi

    local provider
    provider=$(get_provider "$input")

    if is_third_party "$provider"; then
        if command -v gopass >/dev/null 2>&1; then
            if ! codex-token --check "$input" 2>/dev/null; then
                log_warn "No API token for $input (continuing without auth update)"
            fi
        else
            log_warn "gopass not found (continuing without auth update)"
        fi
    fi

    [[ "$(get_current)" == "$input" ]] && { log_warn "Already using '$input'"; return 0; }
    set_chezmoi_account "$input"
    echo "  ✓ Updated chezmoi.toml"
    log_info "Applying chezmoi templates..."
    chezmoi apply >/dev/null
    echo "  ✓ Updated ~/.codex/config.toml"
    if is_third_party "$provider"; then
        if command -v gopass >/dev/null 2>&1 && codex-token --check "$input" 2>/dev/null; then
            backup_codex_auth_openai || return 1
            local parsed acct_name
            parsed=$(parse_provider_account "$input")
            acct_name="${parsed#*|}"
            local api_key
            api_key=$(get_api_key "$provider" "$acct_name") || {
                log_warn "Failed to retrieve API key (skipping auth.json update)"
                api_key=""
            }
            if [[ -n "$api_key" ]]; then
                write_codex_auth_key "$api_key" || return 1
                echo "  ✓ Updated ~/.codex/auth.json (OPENAI_API_KEY)"
            fi
        else
            log_warn "Skipping auth.json update for $input"
        fi
    else
        restore_codex_auth_openai || return 1
        if [[ -f "$CODEX_AUTH" ]]; then
            echo "  ✓ Restored ~/.codex/auth.json"
        else
            echo "  ✓ Removed ~/.codex/auth.json (re-login required)"
        fi
    fi
    echo ""
    log_success "Account set to $input"
    log_warn "Restart Codex to apply changes"
}

# Add account
cmd_add_account() {
    require_cmd fzf yq || return 1

    log_info "Add New Account"
    echo ""

    # Select provider
    local provider
    if ! provider=$({
        printf '%s\n' "${PROVIDERS[@]}"
        echo -e "${YELLOW}Back${NC}"
    } | fzf --ansi --height=40% --border=rounded --header="Select Provider"); then
        return "$RC_EXIT"
    fi
    [[ -z "$provider" ]] && return "$RC_EXIT"
    [[ "$provider" == "Back" ]] && return "$RC_BACK"

    # Get account name
    local account_name full_name
    echo ""
    if [[ "$provider" == "openai" ]]; then
        printf "Account name (e.g., openai, work): "
        read -r account_name
        [[ -z "$account_name" ]] && return 1
        full_name="$account_name"
    else
        printf 'Account name (will become %s@<name>): ' "$provider"
        read -r account_name
        [[ -z "$account_name" ]] && return 1
        full_name="${provider}@${account_name}"
    fi

    if ! validate_account_name "$account_name"; then
        log_error "Invalid account name (allowed: letters, numbers, dot, underscore, hyphen)"
        return 1
    fi

    ACCOUNT_NAME="$full_name" yq -e '.codex.accounts[strenv(ACCOUNT_NAME)]' "$CHEZMOI_DATA" &>/dev/null && {
        log_error "Account '$full_name' already exists"
        return 1
    }

    # Get model
    echo ""
    local default_model model
    default_model=$(get_provider_default_model "$provider")
    [[ -n "$default_model" ]] && echo "Default model: $default_model"
    printf "Model name (Enter to use default): "
    read -r model
    [[ -z "$model" ]] && model="$default_model"
    [[ -z "$model" ]] && { log_error "Model is required"; return 1; }

    # Add to YAML
    echo ""
    log_info "Adding account..."
    ACCOUNT_NAME="$full_name" \
    PROVIDER_NAME="$provider" \
    MODEL_NAME="$model" \
    yq -i '
        .codex.accounts[strenv(ACCOUNT_NAME)] = {
            "provider": strenv(PROVIDER_NAME),
            "model": strenv(MODEL_NAME)
        }
    ' "$CHEZMOI_DATA"

    log_success "Account '$full_name' added"

    # Add API key for third-party
    if is_third_party "$provider"; then
        echo ""
        printf "API Key (leave empty to skip): "
        read -rs api_key
        echo ""
        if [[ -n "$api_key" ]]; then
            store_api_key "$provider" "$account_name" "$api_key"
            log_success "API key saved"
        else
            log_info "Skipped API key (run: codex-manage add-key $full_name)"
        fi
    fi

    echo ""
    log_info "Applying chezmoi..."
    chezmoi apply
    log_success "Done"
}

# Edit account
cmd_edit_account() {
    require_cmd yq || return 1

    local input="${1:-}"
    if [[ -z "$input" ]]; then
        require_cmd fzf || return 1
    fi
    if [[ -z "$input" ]]; then
        if ! input=$(fzf_pick_account "Edit Account" "plain"); then
            local rc=$?
            if [[ $rc -eq $RC_BACK || $rc -eq $RC_EXIT ]]; then
                return "$rc"
            fi
            return 1
        fi
    fi

    is_configured_account "$input" || { log_error "Unknown account '$input'"; return 1; }

    log_info "Edit Account: $input"
    echo ""

    local current_model
    current_model=$(ACCOUNT_NAME="$input" yq -r '.codex.accounts[strenv(ACCOUNT_NAME)].model // ""' "$CHEZMOI_DATA")

    echo "Current model: $current_model"
    printf "New model (Enter to keep): "
    read -r new_model
    [[ -z "$new_model" ]] && new_model="$current_model"
    [[ -z "$new_model" ]] && { log_error "Model is required"; return 1; }

    ACCOUNT_NAME="$input" \
    NEW_MODEL="$new_model" \
    yq -i '
        .codex.accounts[strenv(ACCOUNT_NAME)].model = strenv(NEW_MODEL)
    ' "$CHEZMOI_DATA"

    echo ""
    log_success "Account '$input' updated"
    log_info "Applying chezmoi..."
    chezmoi apply
    log_success "Done"
}

# Remove account
cmd_remove_account() {
    require_cmd yq || return 1

    local input="${1:-}"
    if [[ -z "$input" ]]; then
        require_cmd fzf || return 1
    fi
    if [[ -z "$input" ]]; then
        if ! input=$(fzf_pick_account "Remove Account" "plain"); then
            local rc=$?
            if [[ $rc -eq $RC_BACK || $rc -eq $RC_EXIT ]]; then
                return "$rc"
            fi
            return 1
        fi
    fi

    is_configured_account "$input" || { log_error "Unknown account '$input'"; return 1; }

    log_warn "Remove account '$input'?"
    printf "This will delete it from codex.yaml. Continue? [y/N]: "
    read -r confirm
    [[ "$confirm" != "y" && "$confirm" != "Y" ]] && { echo "Cancelled"; return 0; }

    local provider
    provider=$(get_provider "$input")

    ACCOUNT_NAME="$input" yq -i 'del(.codex.accounts[strenv(ACCOUNT_NAME)])' "$CHEZMOI_DATA"
    log_success "Account removed"

    if is_third_party "$provider"; then
        local parsed acct_name
        parsed=$(parse_provider_account "$input")
        acct_name="${parsed#*|}"
        if key_exists "$provider" "$acct_name"; then
            printf "Also delete API key? [y/N]: "
            read -r del_key
            [[ "$del_key" == "y" || "$del_key" == "Y" ]] && {
                delete_api_key "$provider" "$acct_name"
                log_success "API key deleted"
            }
        fi
    fi

    echo ""
    log_info "Applying chezmoi..."
    chezmoi apply
    log_success "Done"
}

# Add API key
cmd_add_key() {
    require_cmd gopass || return 1
    local input="${1:-}"

    if [[ -z "$input" ]]; then
        require_cmd fzf || return 1
        local needs_key=()
        for acct in "${ACCOUNTS[@]}"; do
            local prov
            prov=$(get_provider "$acct")
            if is_third_party "$prov"; then
                local parsed acct_name
                parsed=$(parse_provider_account "$acct")
                acct_name="${parsed#*|}"
                key_exists "$prov" "$acct_name" || needs_key+=("$acct")
            fi
        done

        [[ ${#needs_key[@]} -eq 0 ]] && {
            log_warn "All accounts already have API keys"
            return 0
        }

        if ! input=$({
            printf '%s\n' "${needs_key[@]}"
            echo -e "${YELLOW}Back${NC}"
        } | fzf --ansi --height=40% --border=rounded --header='Add API Key'); then
            return "$RC_EXIT"
        fi
        [[ -z "$input" ]] && return "$RC_EXIT"
        [[ "$input" == "Back" ]] && return "$RC_BACK"
    fi

    local provider
    provider=$(get_provider "$input")
    local parsed acct_name
    parsed=$(parse_provider_account "$input")
    acct_name="${parsed#*|}"

    is_third_party "$provider" || { log_warn "Native provider, no key needed"; return 0; }
    key_exists "$provider" "$acct_name" && { log_error "Key already exists. Use update-key."; return 1; }

    log_info "Adding API key for $input"
    printf "API Key: "
    read -rs api_key
    echo ""
    [[ -z "$api_key" ]] && { log_error "API key required"; return 1; }

    store_api_key "$provider" "$acct_name" "$api_key"
    log_success "API key saved"
    log_info "Tip: run 'codex-manage test $input' to verify"
}

# Update API key
cmd_update_key() {
    require_cmd gopass || return 1
    local input="${1:-}"

    if [[ -z "$input" ]]; then
        require_cmd fzf || return 1
        local existing
        existing=$(build_accounts_with_keys)
        [[ -z "$existing" ]] && { log_warn "No API keys to update"; return 0; }

        if ! input=$({
            echo "$existing"
            echo -e "${YELLOW}Back${NC}"
        } | fzf --ansi --height=40% --border=rounded --header='Update API Key'); then
            return "$RC_EXIT"
        fi
        [[ -z "$input" ]] && return "$RC_EXIT"
        [[ "$input" == "Back" ]] && return "$RC_BACK"
    fi

    local provider
    provider=$(get_provider "$input")
    local parsed acct_name
    parsed=$(parse_provider_account "$input")
    acct_name="${parsed#*|}"

    is_third_party "$provider" || { log_warn "Native provider, no key needed"; return 0; }
    key_exists "$provider" "$acct_name" || { log_error "No key exists. Use add-key."; return 1; }

    log_info "Updating API key for $input"
    printf "New API Key: "
    read -rs api_key
    echo ""
    [[ -z "$api_key" ]] && { log_error "API key required"; return 1; }

    store_api_key "$provider" "$acct_name" "$api_key"
    log_success "API key updated"
}

# Delete API key
cmd_delete_key() {
    require_cmd gopass || return 1
    local input="${1:-}"

    if [[ -z "$input" ]]; then
        require_cmd fzf || return 1
        local existing
        existing=$(build_accounts_with_keys)
        [[ -z "$existing" ]] && { log_warn "No API keys to delete"; return 0; }

        if ! input=$({
            echo "$existing"
            echo -e "${YELLOW}Back${NC}"
        } | fzf --ansi --height=40% --border=rounded --header='Delete API Key'); then
            return "$RC_EXIT"
        fi
        [[ -z "$input" ]] && return "$RC_EXIT"
        [[ "$input" == "Back" ]] && return "$RC_BACK"
    fi

    local provider
    provider=$(get_provider "$input")
    local parsed acct_name
    parsed=$(parse_provider_account "$input")
    acct_name="${parsed#*|}"

    key_exists "$provider" "$acct_name" || { log_error "No key exists"; return 1; }

    log_warn "Delete API key for $input?"
    printf "Continue? [y/N]: "
    read -r confirm
    [[ "$confirm" == "y" || "$confirm" == "Y" ]] && {
        delete_api_key "$provider" "$acct_name"
        log_success "API key deleted"
    } || echo "Cancelled"
}

# Test connectivity
cmd_test() {
    local input="${1:-}"
    if [[ -z "$input" ]]; then
        if ! input=$(fzf_pick_account "Test Connectivity"); then
            local rc=$?
            if [[ $rc -eq $RC_BACK || $rc -eq $RC_EXIT ]]; then
                return "$rc"
            fi
            return 1
        fi
    fi

    is_configured_account "$input" || { log_error "Unknown account '$input'"; return 1; }

    local provider config base_url
    provider=$(get_provider "$input")
    config=$(codex-token --config "$input")
    base_url=$(echo "$config" | jq -r '.base_url // empty')
    base_url=${base_url%/v1}
    base_url=${base_url%/v1/}
    base_url=${base_url%/}

    if [[ -z "$base_url" ]]; then
        log_warn "Native OpenAI provider"
        log_success "Use 'codex' to authenticate via OAuth"
        return 0
    fi

    require_cmd curl || return 1

    log_info "Testing $input..."
    echo "  Base URL: $base_url"

    local parsed acct_name
    parsed=$(parse_provider_account "$input")
    acct_name="${parsed#*|}"

    key_exists "$provider" "$acct_name" || {
        log_fail "No API key"
        return 1
    }
    log_success "Key found"

    local token
    token=$(get_api_key "$provider" "$acct_name") || { log_fail "Failed to decrypt"; return 1; }

    echo "  Testing API..."

    local model response http_code
    model=$(echo "$config" | jq -r '.model // "unknown"')

    # Codex schema indicates the Responses API at /v1/responses.
    local header_file
    header_file=$(mktemp) || { log_fail "Failed to create header temp file"; return 1; }
    if ! chmod 600 "$header_file"; then
        log_fail "Failed to secure header temp file"
        rm -f "$header_file"
        return 1
    fi
    if ! cat > "$header_file" <<EOF
Authorization: Bearer $token
Content-Type: application/json
EOF
    then
        log_fail "Failed to write header file"
        rm -f "$header_file"
        return 1
    fi

    response=$(curl -sS -w "\n%{http_code}" --max-time 30 \
        -X POST "$base_url/v1/responses" \
        -H @"$header_file" \
        -d "{\"model\":\"$model\",\"input\":\"ping\"}" 2>&1 || true)

    rm -f "$header_file"

    http_code=$(echo "$response" | tail -n1)

    case "$http_code" in
        200) log_success "API OK" ;;
        401|403) log_fail "Invalid API key"; return 1 ;;
        429) log_warn "Rate limited"; http_code=200 ;;
        *)
            if [[ -z "$http_code" || "$http_code" == "000" ]]; then
                log_fail "Network error"
                return 1
            fi
            log_warn "HTTP $http_code" ;;
    esac

    if [[ "$http_code" != "200" ]]; then
        return 1
    fi

    echo ""
    log_success "Account $input is configured"
}

# List accounts
cmd_list() {
    local filter="${1:-}"
    log_info "Configured accounts:"
    echo ""

    for account in "${ACCOUNTS[@]}"; do
        local provider
        provider=$(get_provider "$account")

        [[ -n "$filter" && "$provider" != "$filter" ]] && continue

        if is_third_party "$provider"; then
            local parsed acct_name
            parsed=$(parse_provider_account "$account")
            acct_name="${parsed#*|}"
            if key_exists "$provider" "$acct_name"; then
                echo -e "  ${GREEN}${STATUS_OK}${NC} $account"
            else
                echo -e "  ${RED}${STATUS_ERROR}${NC} $account (no key)"
            fi
        else
            echo -e "  ${GREEN}${STATUS_NATIVE}${NC} $account (native)"
        fi
    done
}

# Show current
cmd_current() {
    local account provider
    account=$(get_current)
    provider=$(get_provider "$account")
    echo -e "Current: ${GREEN}${account}${NC} (${provider})"
}

# Show help
show_help() {
    cat << 'EOF'
Codex CLI Account Manager

Usage:
  codex-manage                        Interactive menu
  codex-manage switch [account]       Switch default account
  codex-manage add-account            Add new account
  codex-manage edit-account [account] Edit account config
  codex-manage remove-account [acct]  Remove account
  codex-manage add-key [account]      Add API key
  codex-manage update-key [account]   Update API key
  codex-manage delete-key [account]   Delete API key
  codex-manage test [account]         Test connectivity
  codex-manage list [provider]        List accounts
  codex-manage current                Show current account
EOF
}

# Main
main() {
    local cmd="${1:-}"
    shift || true

    case "$cmd" in
        help|--help|-h)
            show_help
            ;;
        "")
            require_cmd chezmoi jq fzf gopass || return 1
            run_cmd fzf_menu
            ;;
        switch|sw)
            require_cmd chezmoi jq || return 1
            run_cmd cmd_switch "$@"
            ;;
        add-account)
            require_cmd chezmoi jq yq fzf || return 1
            run_cmd cmd_add_account "$@"
            ;;
        edit-account)
            require_cmd chezmoi jq yq || return 1
            run_cmd cmd_edit_account "$@"
            ;;
        remove-account)
            require_cmd chezmoi jq yq || return 1
            run_cmd cmd_remove_account "$@"
            ;;
        add-key|update-key|delete-key)
            require_cmd chezmoi jq gopass || return 1
            case "$cmd" in
                add-key) run_cmd cmd_add_key "$@" ;;
                update-key) run_cmd cmd_update_key "$@" ;;
                delete-key) run_cmd cmd_delete_key "$@" ;;
            esac
            ;;
        test)
            require_cmd chezmoi jq gopass curl || return 1
            run_cmd cmd_test "$@"
            ;;
        list|ls)
            require_cmd chezmoi jq gopass || return 1
            run_cmd cmd_list "$@"
            ;;
        current)
            require_cmd chezmoi jq || return 1
            cmd_current
            ;;
        *)
            log_error "Unknown: $cmd"
            show_help
            return 1
            ;;
    esac
}

main "$@"
