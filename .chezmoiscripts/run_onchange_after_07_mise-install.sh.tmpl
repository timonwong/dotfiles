#!/bin/bash

set -euo pipefail

{{ $miseConfig := joinPath .chezmoi.homeDir ".config/mise/config.toml" -}}
# mise config: {{ if stat $miseConfig }}{{ output "sha256sum" $miseConfig | trim }}{{ else }}n/a{{ end }}

# chezmoi may be updating dot-directories (e.g. ~/.claude). If the current working
# directory disappears mid-apply, mise will warn. Run mise from a stable dir.
cd "$HOME"

# Ensure aqua-managed binaries are discoverable for this non-interactive shell.
aqua_bin_dir="${AQUA_ROOT_DIR:-${XDG_DATA_HOME:-$HOME/.local/share}/aquaproj-aqua}/bin"
if [[ -d "$aqua_bin_dir" ]]; then
    export PATH="$aqua_bin_dir:$PATH"
fi

source_aqua_config="{{ joinPath .chezmoi.sourceDir "private_dot_config/aquaproj-aqua/aqua.yaml" }}"
AQUA_CONFIG_PATH="$HOME/.config/aquaproj-aqua/aqua.yaml"
if [[ -f "$AQUA_CONFIG_PATH" ]]; then
    :
elif [[ -f "$source_aqua_config" ]]; then
    AQUA_CONFIG_PATH="$source_aqua_config"
fi
if [[ -f "$AQUA_CONFIG_PATH" ]]; then
    # aqua-proxy resolves commands from this config in non-interactive shells.
    export AQUA_GLOBAL_CONFIG="$AQUA_CONFIG_PATH"
    export AQUA_CONFIG="$AQUA_CONFIG_PATH"
fi

echo ":: [07] Installing mise tools"

if command -v mise &>/dev/null; then
    if ! mise --version &>/dev/null; then
        echo "    Skipped (mise proxy unavailable)"
        exit 0
    fi

    # Ensure mise shims are available in this non-interactive shell.
    eval "$(mise activate bash)"

    # npm-backed tools need npm available during version resolution.
    # Install node first if npm is still unavailable in this shell.
    if ! command -v npm &>/dev/null; then
        mise install --yes node
        eval "$(mise activate bash)"
    fi

    mise install --yes
else
    echo "    Skipped (mise not found)"
    exit 0
fi
