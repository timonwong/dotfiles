#!/usr/bin/env bash
# Claude Code Launcher
# Launch claude with any account via environment variable injection
#
# Session Isolation:
#   This script ensures complete isolation from shell environment:
#   - Unsets ANTHROPIC_API_KEY and ANTHROPIC_AUTH_TOKEN to prevent key leakage
#   - Unsets ANTHROPIC_BASE_URL for native Anthropic accounts
#   - Always sets _CLAUDE_OVERRIDE_ACCOUNT to ensure correct token selection
#
# Usage:
#   claude-with                    # fzf interactive picker
#   claude-with <account> [args]   # Launch with account + claude args
#   claude-with -h                 # Show help (includes claude --help)

set -euo pipefail

# shellcheck source=lib/ai/claude.tmpl
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
source "$SCRIPT_DIR/lib/ai/claude"

# FZF picker with shortcuts
fzf_select() {
    local selected
    selected=$(build_account_list_with_token | fzf --ansi \
        --height=50% \
        --border=rounded \
        --header="Launch Claude" \
        --preview="$ACCOUNT_PREVIEW"'
            echo ""
            echo -e "\033[1;34m━━━ Shortcuts ━━━\033[0m"
            echo ""
            echo "  Enter     Launch"
            echo "  ctrl-r    --resume"
            echo "  ctrl-p    --dangerously-skip-permissions"
        ' \
        --preview-window='right:50%:wrap' \
        --preview-label="[ Select and press Enter ]" \
        --bind='enter:accept' \
        --bind='ctrl-r:transform-query(echo --resume)+accept' \
        --bind='ctrl-p:transform-query(echo --dangerously-skip-permissions)+accept' \
        --print-query) || true

    [[ -z "$selected" ]] && return 1

    # Parse output: first line is query (args), second is selection
    local query selection
    query=$(echo "$selected" | head -1)
    selection=$(echo "$selected" | tail -1)

    [[ -z "$selection" ]] && return 1

    # Extract account name
    local account
    account="${selection#* }"

    if [[ -n "$query" ]]; then
        echo "$account|$query"
    else
        echo "$account|"
    fi
}

# Inject environment variables and launch
launch_claude() {
    local account="$1"
    shift

    if ! is_runtime_account "$account"; then
        log_error "Unknown account '$account'"
        echo "Available accounts:" >&2
        list_runtime_accounts | sed 's/^/  /' >&2 || true
        return 1
    fi

    # Get config via claude-token
    local config base_url model small_model
    config=$(claude-token --config "$account")
    base_url=$(echo "$config" | jq -r '.base_url // empty')
    model=$(echo "$config" | jq -r '.model // empty')
    small_model=$(echo "$config" | jq -r '.small_model // empty')

    # Session isolation: clean up environment to prevent shell pollution
    # Unset any existing ANTHROPIC_* variables that could interfere
    unset ANTHROPIC_API_KEY
    unset ANTHROPIC_AUTH_TOKEN

    # Always set override account to ensure claude-token uses the correct provider
    # This works for both native Anthropic (OAuth) and third-party (API key)
    export _CLAUDE_OVERRIDE_ACCOUNT="$account"

    # Configure base_url for third-party providers
    # Native Anthropic accounts have no base_url and use OAuth
    if [[ -n "$base_url" ]]; then
        # Verify token exists before launching
        if ! claude-token --check "$account" 2>/dev/null; then
            log_error "No API token for $account"
            echo -e "Run: ${YELLOW}claude-manage update-account $account${NC}" >&2
            return 1
        fi
        export ANTHROPIC_BASE_URL="$base_url"
    else
        # Native Anthropic: ensure no base_url is set (prevents shell env leakage)
        unset ANTHROPIC_BASE_URL
    fi

    # Common settings
    [[ -n "$model" ]] && export ANTHROPIC_MODEL="$model"
    [[ -n "$small_model" ]] && export ANTHROPIC_SMALL_FAST_MODEL="$small_model"

    # Optional settings
    local timeout haiku sonnet opus disable_traffic
    timeout=$(echo "$config" | jq -r '.timeout_ms // empty')
    haiku=$(echo "$config" | jq -r '.haiku_model // empty')
    sonnet=$(echo "$config" | jq -r '.sonnet_model // empty')
    opus=$(echo "$config" | jq -r '.opus_model // empty')
    disable_traffic=$(echo "$config" | jq -r '.disable_nonessential_traffic // empty')

    [[ -n "$timeout" ]] && export API_TIMEOUT_MS="$timeout"
    [[ "$disable_traffic" == "true" ]] && export CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC="1"
    [[ -n "$haiku" ]] && export ANTHROPIC_DEFAULT_HAIKU_MODEL="$haiku"
    [[ -n "$sonnet" ]] && export ANTHROPIC_DEFAULT_SONNET_MODEL="$sonnet"
    [[ -n "$opus" ]] && export ANTHROPIC_DEFAULT_OPUS_MODEL="$opus"

    # Status
    echo -e "${GREEN}Launching claude with ${CYAN}$account${NC}"
    echo -e "  Model: ${model:-default}"
    [[ -n "$base_url" ]] && echo -e "  URL:   $base_url"
    echo ""

    # Important: ~/.claude/settings.json may include a default provider's env (e.g. ANTHROPIC_BASE_URL).
    # When default is a third-party provider, that global env will break `ccw anthropic` unless we override it.
    # Strategy:
    #   - Load the user's global settings JSON
    #   - Strip provider-specific keys (apiKeyHelper + ANTHROPIC_* routing/model)
    #   - Inject per-session overrides for the selected account
    #   - Start Claude Code with `--setting-sources project,local` to avoid re-loading the unmodified user settings
    local settings_override api_key_helper_override base_url_override

    if [[ -n "$base_url" ]]; then
        api_key_helper_override="$HOME/.local/bin/claude-token"
        base_url_override="$base_url"
    else
        # Native Anthropic (OAuth). Ensure we do not inherit a third-party base URL.
        api_key_helper_override=""
        base_url_override="https://api.anthropic.com"
    fi

    local user_settings
    user_settings=$(jq -c '
        del(.apiKeyHelper)
        | .env = (.env // {} | del(
            .ANTHROPIC_BASE_URL,
            .ANTHROPIC_MODEL,
            .ANTHROPIC_SMALL_FAST_MODEL,
            .ANTHROPIC_DEFAULT_HAIKU_MODEL,
            .ANTHROPIC_DEFAULT_SONNET_MODEL,
            .ANTHROPIC_DEFAULT_OPUS_MODEL
        ))
    ' "$HOME/.claude/settings.json" 2>/dev/null || echo '{}')

    settings_override=$(jq -nc \
        --argjson base "$user_settings" \
        --arg apiKeyHelper "$api_key_helper_override" \
        --arg base_url "$base_url_override" \
        --arg model "${model:-}" \
        --arg small_model "${small_model:-}" \
        --arg haiku "${haiku:-}" \
        --arg sonnet "${sonnet:-}" \
        --arg opus "${opus:-}" \
        --arg disable_traffic "${disable_traffic:-}" \
        '(
            $base
            * {
                apiKeyHelper: $apiKeyHelper,
                env: (
                    ($base.env // {})
                    + {
                        ANTHROPIC_BASE_URL: $base_url,
                        ANTHROPIC_MODEL: $model,
                        ANTHROPIC_SMALL_FAST_MODEL: $small_model,
                        ANTHROPIC_DEFAULT_HAIKU_MODEL: $haiku,
                        ANTHROPIC_DEFAULT_SONNET_MODEL: $sonnet,
                        ANTHROPIC_DEFAULT_OPUS_MODEL: $opus,
                        CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC: (if $disable_traffic == "true" then "1" else "" end)
                    }
                )
            }
            | .env |= with_entries(select(.value | length > 0))
        )')

    exec claude --setting-sources project,local --settings "$settings_override" "$@"
}

# Show help
show_help() {
    cat << 'EOF'
Claude Code Launcher

Usage:
  claude-with                    Interactive fzf picker
  claude-with <account> [args]   Launch with account + pass args to claude
  claude-with -h, --help         Show this help

Examples:
  claude-with                    # fzf picker with shortcuts
  claude-with kimi               # Launch with kimi account
  claude-with kimi --resume      # Launch and resume last session
  claude-with deepseek -p .      # Launch in current directory

FZF Shortcuts:
  Enter     Launch claude
  ctrl-r    Launch with --resume
  ctrl-p    Launch with --dangerously-skip-permissions

EOF
    echo -e "${BLUE}━━━ Claude Code Help ━━━${NC}"
    echo ""
    claude --help 2>/dev/null || echo "(claude --help not available)"
}

# Main
main() {
    if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
        require_cmd claude || exit 1
        show_help
        exit 0
    fi

    require_cmd chezmoi jq claude claude-token || exit 1

    if [[ $# -eq 0 ]]; then
        require_cmd fzf || exit 1
        local result
        result=$(fzf_select) || exit 0
        local account="${result%%|*}"
        local args_str="${result#*|}"
        local -a args=()
        if [[ -n "$args_str" ]]; then
            while IFS= read -r line; do
                [[ -n "$line" ]] && args+=("$line")
            done < <(split_cli_args "$args_str")
        fi
        launch_claude "$account" "${args[@]}"
        exit 0
    fi

    local account="$1"
    shift
    launch_claude "$account" "$@"
}

main "$@"
