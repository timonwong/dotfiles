            "high": {},
            "xhigh": {}
          }
        }
      }
    },
    "naapi": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "NAAPI",
      "env": ["NAAPI_API_KEY"],
      "options": {
        "baseURL": "https://na.wanxiaot.com/v1"{{- if ne $naapiApiKey "" }},
        "apiKey": {{ $naapiApiKey | quote }}{{- end }}
      },
      "models": {
        "gpt-5.3-codex": {
          "name": "GPT-5.3 Codex",
          "options": {
            "store": false
          },
          "variants": {
            "low": {},
            "medium": {},
            "high": {},
            "xhigh": {}
          }
        },
        "gpt-5.2-codex": {
          "name": "GPT-5.2 Codex",
          "options": {
            "store": false
          },
          "variants": {
            "low": {},
            "medium": {},
            "high": {},
            "xhigh": {}
          }
        }
      }
    },
    "qwen": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Qwen",
      "env": ["DASHSCOPE_API_KEY"],
      "options": {
        "baseURL": "https://dashscope.aliyuncs.com/compatible-mode/v1"{{- if ne $qwenApiKey "" }},
        "apiKey": {{ $qwenApiKey | quote }}{{- end }}
      },
      "models": {
        "qwen3-coder-plus": {
          "name": "Qwen3 Coder Plus",
          "options": {
            "store": false
          },
          "variants": {
            "low": {},
            "medium": {},
            "high": {},
            "xhigh": {}
          }
        },
        "qwen3-max": {
          "name": "Qwen3 Max",
          "options": {
            "store": false
          },
          "variants": {
            "low": {},
