      "options": {
        "baseURL": "https://api.moonshot.ai/v1"{{- if ne (get $providerApiKeys "kimi@private") "" }},
        "apiKey": {{ get $providerApiKeys "kimi@private" | quote }}{{- end }}
      },
      "models": {
        "kimi-k2.5": {
          "name": "Kimi K2.5",
          "options": {
