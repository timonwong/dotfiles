#!/usr/bin/env bash
set -euo pipefail

skill_file="${HOME}/.agents/skills/ui-ux-pro-max/SKILL.md"

if [[ ! -f "$skill_file" ]]; then
    exit 0
fi

tmp_file="$(mktemp "${TMPDIR:-/tmp}/ui-ux-pro-max-skill.XXXXXX")"
trap 'rm -f "$tmp_file"' EXIT

# Upstream SKILL.md is generated for .claude/.codex/.opencode roots.
# Normalize script invocations for shared ~/.agents/skills projection.
sed 's|python3 skills/ui-ux-pro-max/scripts/search.py|python3 scripts/search.py|g' "$skill_file" >"$tmp_file"

if ! cmp -s "$tmp_file" "$skill_file"; then
    mv "$tmp_file" "$skill_file"
fi
