{{- $accountKey := "openai" -}}
{{- if hasKey . "opencodeProviderAccount" -}}
{{-   $accountKey = .opencodeProviderAccount -}}
{{- else if hasKey . "codexProviderAccount" -}}
{{-   $accountKey = .codexProviderAccount -}}
{{- end -}}
{{- $providerName := (split "@" $accountKey)._0 -}}
{{- $accountLabel := "default" -}}
{{- if contains "@" $accountKey -}}
{{-   $accountLabel = (split "@" $accountKey)._1 -}}
{{- end -}}
{{- $resolvedProvider := "openai" -}}
{{- $model := "gpt-5.3-codex" -}}
{{- if eq $providerName "anthropic" -}}
{{-   $resolvedProvider = "anthropic" -}}
{{-   $model = "claude-sonnet-4-5" -}}
{{- else if eq $providerName "google" -}}
{{-   $resolvedProvider = "google" -}}
{{-   $model = "gemini-3-pro" -}}
{{- else if eq $providerName "deepseek" -}}
{{-   $resolvedProvider = "deepseek" -}}
{{-   $model = "deepseek-chat" -}}
{{- else if eq $providerName "doubao" -}}
{{-   $resolvedProvider = "doubao" -}}
{{-   $model = "ark-code-latest" -}}
{{- else if eq $providerName "glm" -}}
{{-   $resolvedProvider = "glm" -}}
{{-   $model = "glm-4.7" -}}
{{- else if eq $providerName "harui" -}}
{{-   $resolvedProvider = "harui" -}}
{{-   $model = "gpt-5.3-codex" -}}
{{- else if eq $providerName "kimi" -}}
{{-   $resolvedProvider = "kimi" -}}
{{-   $model = "kimi-k2.5" -}}
{{- else if eq $providerName "minimax" -}}
{{-   $resolvedProvider = "minimax" -}}
{{-   $model = "MiniMax-M2.1" -}}
{{- else if eq $providerName "naapi" -}}
{{-   $resolvedProvider = "naapi" -}}
{{-   $model = "gpt-5.3-codex" -}}
{{- else if eq $providerName "qwen" -}}
{{-   $resolvedProvider = "qwen" -}}
{{-   $model = "qwen3-coder-plus" -}}
{{- else if eq $providerName "opencode" -}}
{{-   $resolvedProvider = "opencode" -}}
{{-   $model = "gpt-5.3-codex" -}}
{{- end -}}
{{- $modelRef := printf "%s/%s" $resolvedProvider $model -}}
{{- $selectedApiPath := "" -}}
{{- if and (regexMatch "^[A-Za-z0-9._-]+$" $providerName) (regexMatch "^[A-Za-z0-9._-]+$" $accountLabel) -}}
{{-   $selectedApiPathCmd := printf "command -v gopass >/dev/null 2>&1 || exit 0; p='opencode/%s/%s/api_key'; if gopass list -f \"$p\" >/dev/null 2>&1; then printf '%%s' \"$p\"; fi" $providerName $accountLabel -}}
{{-   $selectedApiPath = (output "sh" "-c" $selectedApiPathCmd) | trim -}}
{{- end -}}
{{- $selectedApiKey := "" -}}
{{- if ne $selectedApiPath "" -}}{{- $selectedApiKey = gopass $selectedApiPath -}}{{- end -}}
{{- $deepseekApiKey := "" -}}
{{- if and (eq $providerName "deepseek") (ne $selectedApiKey "") -}}{{- $deepseekApiKey = $selectedApiKey -}}{{- end -}}
{{- $doubaoApiKey := "" -}}
{{- if and (eq $providerName "doubao") (ne $selectedApiKey "") -}}{{- $doubaoApiKey = $selectedApiKey -}}{{- end -}}
{{- $glmApiKey := "" -}}
{{- if and (eq $providerName "glm") (ne $selectedApiKey "") -}}{{- $glmApiKey = $selectedApiKey -}}{{- end -}}
{{- $haruiApiKey := "" -}}
{{- if and (eq $providerName "harui") (ne $selectedApiKey "") -}}{{- $haruiApiKey = $selectedApiKey -}}{{- end -}}
{{- $kimiApiKey := "" -}}
{{- if and (eq $providerName "kimi") (ne $selectedApiKey "") -}}{{- $kimiApiKey = $selectedApiKey -}}{{- end -}}
{{- $minimaxApiKey := "" -}}
{{- if and (eq $providerName "minimax") (ne $selectedApiKey "") -}}{{- $minimaxApiKey = $selectedApiKey -}}{{- end -}}
{{- $naapiApiKey := "" -}}
{{- if and (eq $providerName "naapi") (ne $selectedApiKey "") -}}{{- $naapiApiKey = $selectedApiKey -}}{{- end -}}
{{- $qwenApiKey := "" -}}
{{- if and (eq $providerName "qwen") (ne $selectedApiKey "") -}}{{- $qwenApiKey = $selectedApiKey -}}{{- end -}}
{
  "$schema": "https://opencode.ai/config.json",
  "theme": "dracula",
  "model": {{ $modelRef | quote }},
  "small_model": {{ $modelRef | quote }},
  "instructions": [
    "AGENTS.md",
    ".opencode/AGENTS.md"
  ],
  "command": {
    "doctor-all": {
      "description": "Run all AI workflow diagnostics and summarize findings.",
      "agent": "build",
      "template": "Run `claude-manage doctor` and `codex-manage doctor`. Report failures first, then warnings, then concrete remediation steps."
    },
    "spec-verify": {
      "description": "Validate current OpenSpec change and repository tests.",
      "agent": "build",
      "template": "Run `openspec validate --changes <change-name>` and `bash tests/run.sh`. Report failing commands with likely root causes."
    }
  },
  "default_agent": "build",
  "agent": {
    "build": {
      "model": {{ $modelRef | quote }},
      "variant": "medium",
      "options": {
        "store": false
      },
      "description": "Default implementation agent for daily coding work."
    },
    "plan": {
      "model": {{ $modelRef | quote }},
      "variant": "high",
      "options": {
        "store": false
      },
      "description": "Planning agent for multi-step and spec-first tasks."
    }
  },
  "watcher": {
    "ignore": [
      "**/.git/**",
      "**/node_modules/**",
      "**/.direnv/**",
      "**/.cache/**",
      "**/.sisyphus/**"
    ]
  },
  "lsp": {
    "rust-analyzer": {
      "command": ["rust-analyzer"],
      "extensions": [".rs"]
    },
    "lua-language-server": {
      "command": ["lua-language-server"],
      "extensions": [".lua"]
    },
    "typescript-language-server": {
      "command": ["typescript-language-server", "--stdio"],
      "extensions": [".ts", ".tsx", ".js", ".jsx"],
      "disabled": true
    },
    "basedpyright": {
      "command": ["basedpyright-langserver", "--stdio"],
      "extensions": [".py"],
      "disabled": true
    }
  },
  "formatter": {
    "rustfmt": {
      "command": ["rustfmt"],
      "extensions": [".rs"]
    },
    "ruff-format": {
      "command": ["ruff", "format"],
      "extensions": [".py"]
    },
    "prettier": {
      "command": ["prettier", "--write"],
      "extensions": [".js", ".jsx", ".ts", ".tsx", ".json", ".md", ".yaml", ".yml"],
      "disabled": true
    },
    "stylua": {
      "command": ["stylua"],
      "extensions": [".lua"],
      "disabled": true
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 16384
  },
  "share": "manual",
  "autoupdate": "notify",
  "tui": {
    "diff_style": "auto",
    "scroll_speed": 2.5,
    "scroll_acceleration": {
      "enabled": true
    }
  },
  "provider": {
    "deepseek": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DeepSeek",
      "env": ["DEEPSEEK_API_KEY"],
      "options": {
        "baseURL": "https://api.deepseek.com/v1"{{- if ne $deepseekApiKey "" }},
        "apiKey": {{ $deepseekApiKey | quote }}{{- end }}
      },
      "models": {
        "deepseek-chat": {
          "name": "DeepSeek Chat",
          "options": {
            "store": false
          },
          "variants": {
            "low": {},
            "medium": {},
            "high": {},
            "xhigh": {}
          }
        },
        "deepseek-reasoner": {
          "name": "DeepSeek Reasoner",
          "options": {
            "store": false
          },
          "variants": {
            "low": {},
            "medium": {},
            "high": {},
            "xhigh": {}
          }
        }
      }
    },
    "doubao": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Doubao",
      "env": ["ARK_API_KEY"],
      "options": {
        "baseURL": "https://ark.cn-beijing.volces.com/api/v3"{{- if ne $doubaoApiKey "" }},
        "apiKey": {{ $doubaoApiKey | quote }}{{- end }}
      },
      "models": {
        "ark-code-latest": {
          "name": "Doubao Ark Code Latest",
          "options": {
            "store": false
          },
          "variants": {
            "low": {},
            "medium": {},
            "high": {},
            "xhigh": {}
          }
        }
      }
    },
    "glm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "GLM",
      "env": ["ZHIPU_API_KEY"],
      "options": {
        "baseURL": "https://open.bigmodel.cn/api/paas/v4"{{- if ne $glmApiKey "" }},
        "apiKey": {{ $glmApiKey | quote }}{{- end }}
      },
      "models": {
        "glm-4.7": {
          "name": "GLM 4.7",
          "options": {
            "store": false
          },
          "variants": {
            "low": {},
            "medium": {},
            "high": {},
            "xhigh": {}
          }
        },
        "glm-4.5-air": {
          "name": "GLM 4.5 Air",
          "options": {
            "store": false
          },
          "variants": {
            "low": {},
            "medium": {},
            "high": {},
            "xhigh": {}
          }
        }
      }
    },
    "harui": {
      "npm": "@ai-sdk/openai",
      "name": "Harui",
      "env": ["HARUI_API_KEY"],
      "options": {
        "baseURL": "https://codex.harui.edu.kg/v1"{{- if ne $haruiApiKey "" }},
        "apiKey": {{ $haruiApiKey | quote }}{{- end }}
      },
      "models": {
        "gpt-5.3-codex": {
          "name": "GPT-5.3 Codex",
          "options": {
            "store": false
          },
          "variants": {
            "low": {},
            "medium": {},
            "high": {},
            "xhigh": {}
          }
        },
        "gpt-5.2-codex": {
          "name": "GPT-5.2 Codex",
          "options": {
            "store": false
          },
          "variants": {
            "low": {},
            "medium": {},
            "high": {},
            "xhigh": {}
          }
        }
      }
    },
    "kimi": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Kimi",
      "env": ["MOONSHOT_API_KEY"],
      "options": {
        "baseURL": "https://api.moonshot.ai/v1"{{- if ne $kimiApiKey "" }},
        "apiKey": {{ $kimiApiKey | quote }}{{- end }}
      },
      "models": {
        "kimi-k2.5": {
          "name": "Kimi K2.5",
          "options": {
            "store": false
          },
          "variants": {
            "low": {},
            "medium": {},
            "high": {},
            "xhigh": {}
          }
        },
        "kimi-k2": {
          "name": "Kimi K2",
          "options": {
            "store": false
          },
          "variants": {
            "low": {},
            "medium": {},
            "high": {},
            "xhigh": {}
          }
        }
      }
    },
    "minimax": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "MiniMax",
      "env": ["MINIMAX_API_KEY"],
      "options": {
        "baseURL": "https://api.minimax.io/v1"{{- if ne $minimaxApiKey "" }},
        "apiKey": {{ $minimaxApiKey | quote }}{{- end }}
      },
      "models": {
        "MiniMax-M2.1": {
          "name": "MiniMax M2.1",
          "options": {
            "store": false
          },
          "variants": {
            "low": {},
