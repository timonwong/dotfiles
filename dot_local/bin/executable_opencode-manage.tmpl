#!/usr/bin/env bash
# OpenCode Account Manager
# Manage accounts and API keys with fzf interface
#
# Usage:
#   opencode-manage                          # Interactive menu
#   opencode-manage switch [account]         Switch default account
#   opencode-manage create-account [account] Create account (optionally with API key)
#   opencode-manage update-account [account] Update account (optionally rotate API key)
#   opencode-manage remove-account [account] Remove account (optionally delete API key)
#   opencode-manage test [account]           Test connectivity
#   opencode-manage list [provider]          List accounts
#   opencode-manage doctor                   Run workflow diagnostics

set -euo pipefail

# shellcheck source=lib/ai/opencode.tmpl
# shellcheck disable=SC1091
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
source "$SCRIPT_DIR/lib/ai/opencode"

# Return codes
: "${RC_BACK:=10}"
: "${RC_EXIT:=130}"

# Set OpenCode account in chezmoi.toml
set_chezmoi_account() {
    local account="$1"
    local escaped_account
    escaped_account=$(escape_toml_string "$account")
    local tmp_file
    tmp_file=$(mktemp) || { log_error "Failed to create temp file"; return 1; }

    if grep -q "^opencodeProviderAccount = " "$CHEZMOI_CONFIG"; then
        sed "s/^opencodeProviderAccount = .*/opencodeProviderAccount = \"$escaped_account\"/" "$CHEZMOI_CONFIG" > "$tmp_file"
    elif grep -q "^codexProviderAccount = " "$CHEZMOI_CONFIG"; then
        awk -v line="opencodeProviderAccount = \"$escaped_account\"" '
            BEGIN { inserted = 0 }
            { print }
            /^codexProviderAccount = / && inserted == 0 { print line; inserted = 1 }
            END { if (inserted == 0) print line }
        ' "$CHEZMOI_CONFIG" > "$tmp_file"
    elif grep -q "^claudeProviderAccount = " "$CHEZMOI_CONFIG"; then
        awk -v line="opencodeProviderAccount = \"$escaped_account\"" '
            BEGIN { inserted = 0 }
            { print }
            /^claudeProviderAccount = / && inserted == 0 { print line; inserted = 1 }
            END { if (inserted == 0) print line }
        ' "$CHEZMOI_CONFIG" > "$tmp_file"
    elif grep -q "^\[data\]" "$CHEZMOI_CONFIG"; then
        awk -v line="opencodeProviderAccount = \"$escaped_account\"" '
            BEGIN { inserted = 0; in_data = 0 }
            /^\[data\]$/ { in_data = 1; print; next }
            /^\[/ {
                if (in_data == 1 && inserted == 0) {
                    print line
                    inserted = 1
                }
                in_data = 0
                print
                next
            }
            { print }
            END {
                if (in_data == 1 && inserted == 0) {
                    print line
                }
            }
        ' "$CHEZMOI_CONFIG" > "$tmp_file"
    else
        cp "$CHEZMOI_CONFIG" "$tmp_file"
        {
            echo ""
            echo "[data]"
            echo "opencodeProviderAccount = \"$escaped_account\""
        } >> "$tmp_file"
    fi
    mv "$tmp_file" "$CHEZMOI_CONFIG"
}

# FZF interactive menu
fzf_menu() {
    while true; do
        local current
        current=$(get_current)

        local selected
        # shellcheck disable=SC2016
        if ! selected=$({
            cat <<'MENU'
switch         Change default account
create-account Create account (and optional API key)
update-account Update account (and optional API key)
remove-account Remove account (and optional API key)
test           Test connectivity
list           Show all accounts
doctor         Run workflow diagnostics
MENU
            echo -e "${YELLOW}quit${NC}           Exit to shell"
        } | fzf --ansi \
            --height=50% \
            --border=rounded \
            --header="OpenCode Account Manager" \
            --preview='
                cmd=$(echo {} | awk "{print \$1}")
                echo -e "\033[1;34m━━━ $cmd ━━━\033[0m"
                echo ""
                case "$cmd" in
                    switch)         echo "Switch the default account." ;;
                    create-account) echo "Create account (and optional API key)." ;;
                    update-account) echo "Update account (and optional API key)." ;;
                    remove-account) echo "Remove account (and optional API key)." ;;
                    test)           echo "Test API connectivity." ;;
                    list)           echo "Show all accounts." ;;
                    doctor)         echo "Run workflow diagnostics." ;;
                    quit)           echo "Exit to shell." ;;
                esac
                echo ""
                echo -e "\033[1;34m━━━ Accounts ━━━\033[0m"
                echo ""
                opencode-manage list 2>/dev/null | tail -n +3
            ' \
            --preview-window='right:50%:wrap' \
            --preview-label="[ Current: $current ]"
        ); then
            return "$RC_EXIT"
        fi

        local cmd
        selected=$(normalize_menu_selection "$selected")
        cmd=$(echo "$selected" | awk '{print $1}')

        local rc=0
        case "$cmd" in
            switch)         cmd_switch || rc=$? ;;
            create-account) cmd_create_account || rc=$? ;;
            update-account) cmd_update_account || rc=$? ;;
            remove-account) cmd_remove_account || rc=$? ;;
            test)           cmd_test || rc=$? ;;
            list)           cmd_list || rc=$? ;;
            doctor)         cmd_doctor || rc=$? ;;
            quit)           return 0 ;;
            *)              log_error "Unknown command: $cmd"; return 1 ;;
        esac

        case "$rc" in
            0) return 0 ;;
            "$RC_BACK") continue ;;
            "$RC_EXIT") return "$RC_EXIT" ;;
            *)
                log_error "Command '$cmd' failed (exit $rc)"
                return "$rc"
                ;;
        esac
    done
}

# Switch account
cmd_switch() {
    local input="${1:-}"
    if [[ -z "$input" ]]; then
        if input=$(fzf_pick_account "Switch Account"); then
            :
        else
            local rc=$?
            if [[ $rc -eq $RC_BACK || $rc -eq $RC_EXIT ]]; then
                return "$rc"
            fi
            return 1
        fi
    fi

    if ! is_runtime_account "$input"; then
        log_error "Unknown account '$input'"
        return 1
    fi

    local provider
    provider=$(get_provider "$input")

    if is_third_party "$provider"; then
        if command -v gopass >/dev/null 2>&1; then
            if ! opencode-token --check "$input" 2>/dev/null; then
                log_warn "No API token for $input (continuing without token)"
            fi
        else
            log_warn "gopass not found (continuing without token)"
        fi
    fi

    [[ "$(get_current)" == "$input" ]] && { log_warn "Already using '$input'"; return 0; }
    set_chezmoi_account "$input"
    echo "  ✓ Updated chezmoi.toml"
    log_info "Applying chezmoi templates..."
    chezmoi apply --verbose --exclude scripts "$OPENCODE_CONFIG" "$SCRIPT_DIR/lib/ai/core"
    echo "  ✓ Updated ~/.config/opencode/opencode.jsonc"
    echo ""
    log_success "Account set to $input"
    log_warn "Restart OpenCode to apply changes"
}

# Create account
cmd_create_account() {
    require_cmd gopass || return 1

    local provider
    if ! provider=$({
        printf '%s\n' "${PROVIDERS[@]}"
        echo -e "${YELLOW}Back${NC}"
    } | fzf --ansi --height=40% --border=rounded --header="Select Provider"); then
        return "$RC_EXIT"
    fi
    provider=$(normalize_menu_selection "$provider")
    [[ -z "$provider" ]] && return "$RC_EXIT"
    is_back_selection "$provider" && return "$RC_BACK"

    local account_label full_name
    if is_opencode_native_provider "$provider"; then
        account_label="$provider"
        full_name="$provider"
    else
        printf 'Account label (default: private): '
        read -r account_label
        [[ -z "$account_label" ]] && account_label="private"
        validate_account_name "$account_label" || { log_error "Invalid label"; return 1; }
        full_name="${provider}@${account_label}"
    fi

    if is_opencode_native_provider "$provider"; then
        set_chezmoi_account "$full_name"
        chezmoi apply --verbose --exclude scripts "$OPENCODE_CONFIG" "$SCRIPT_DIR/lib/ai/core"
        log_success "Account created and switched: $full_name (native auth)"
        log_info "Use: opencode auth login $provider"
        return 0
    fi

    local parsed acct_name
    parsed=$(parse_provider_account "$full_name")
    acct_name="${parsed#*|}"

    printf "API Key (optional): "
    read -rs api_key
    echo ""
    if [[ -n "$api_key" ]]; then
        store_api_key "$provider" "$acct_name" "$api_key"
        log_success "API key saved"
    else
        log_info "Skipped API key"
    fi

    set_chezmoi_account "$full_name"
    chezmoi apply --verbose --exclude scripts "$OPENCODE_CONFIG" "$SCRIPT_DIR/lib/ai/core"
    log_success "Account created and switched: $full_name"
}

# Update account
cmd_update_account() {
    local input="${1:-}"
    if [[ -z "$input" ]]; then
        if input=$(fzf_pick_account "Update Account"); then
            :
        else
            local rc=$?
            if [[ $rc -eq $RC_BACK || $rc -eq $RC_EXIT ]]; then
                return "$rc"
            fi
            return 1
        fi
    fi

    is_runtime_account "$input" || { log_error "Unknown account '$input'"; return 1; }

    local provider parsed acct_name
    provider=$(get_provider "$input")

    set_chezmoi_account "$input"
    chezmoi apply --verbose --exclude scripts "$OPENCODE_CONFIG" "$SCRIPT_DIR/lib/ai/core"
    log_success "Switched to $input"

    if is_opencode_native_provider "$provider"; then
        log_info "$provider uses native auth"
        log_info "Run: opencode auth login $provider"
        return 0
    fi

    parsed=$(parse_provider_account "$input")
    acct_name="${parsed#*|}"

    printf "Update API key now? [y/N]: "
    read -r yes
    if [[ "$yes" == "y" || "$yes" == "Y" ]]; then
        printf "New API Key: "
        read -rs api_key
        echo ""
        [[ -z "$api_key" ]] && { log_error "API key required"; return 1; }
        store_api_key "$provider" "$acct_name" "$api_key"
        log_success "API key updated"
    fi
}

# Remove account
cmd_remove_account() {
    local input="${1:-}"
    if [[ -z "$input" ]]; then
        if input=$(fzf_pick_account "Remove Account"); then
            :
        else
            local rc=$?
            if [[ $rc -eq $RC_BACK || $rc -eq $RC_EXIT ]]; then
                return "$rc"
            fi
            return 1
        fi
    fi

    is_runtime_account "$input" || { log_error "Unknown account '$input'"; return 1; }

    local current
    current=$(get_current)
    if [[ "$input" == "$current" ]]; then
        log_error "Cannot remove current account. Switch first."
        return 1
    fi

    local provider parsed acct_name
    provider=$(get_provider "$input")
    parsed=$(parse_provider_account "$input")
    acct_name="${parsed#*|}"

    if is_third_party "$provider"; then
        printf 'Also delete API key for %s? [y/N]: ' "$input"
        read -r del_key
        if [[ "$del_key" == "y" || "$del_key" == "Y" ]]; then
            if key_exists "$provider" "$acct_name"; then
                delete_api_key "$provider" "$acct_name"
                log_success "API key deleted"
            else
                log_info "No API key found"
            fi
        fi
    fi

    log_warn "Account profile is template-managed; to fully remove, update private_dot_config/opencode/opencode.jsonc.tmpl"
}

# Add API key
cmd_add_key() {
    require_cmd gopass || return 1
    local input="${1:-}"

    if [[ -z "$input" ]]; then
        require_cmd fzf || return 1
        local needs_key=()
        local acct
        while IFS= read -r acct; do
            [[ -z "$acct" ]] && continue
            local prov
            prov=$(get_provider "$acct")
            if is_third_party "$prov"; then
                local parsed acct_name
                parsed=$(parse_provider_account "$acct")
                acct_name="${parsed#*|}"
                key_exists "$prov" "$acct_name" || needs_key+=("$acct")
            fi
        done < <(list_runtime_accounts)

        [[ ${#needs_key[@]} -eq 0 ]] && {
            log_warn "All accounts already have API keys"
            return 0
        }

        if ! input=$({
            printf '%s\n' "${needs_key[@]}"
            echo -e "${YELLOW}Back${NC}"
        } | fzf --ansi --height=40% --border=rounded --header='Add API Key'); then
            return "$RC_EXIT"
        fi
        input=$(normalize_menu_selection "$input")
        [[ -z "$input" ]] && return "$RC_EXIT"
        is_back_selection "$input" && return "$RC_BACK"
    fi

    local provider
    provider=$(get_provider "$input")
    local parsed acct_name
    parsed=$(parse_provider_account "$input")
    acct_name="${parsed#*|}"

    is_third_party "$provider" || { log_warn "Native provider, no key needed"; return 0; }
    key_exists "$provider" "$acct_name" && { log_error "Key already exists. Use update-key."; return 1; }

    log_info "Adding API key for $input"
    printf "API Key: "
    read -rs api_key
    echo ""
    [[ -z "$api_key" ]] && { log_error "API key required"; return 1; }

    store_api_key "$provider" "$acct_name" "$api_key"
    log_success "API key saved"
    log_info "Tip: run 'opencode-manage test $input' to verify"
}

# Update API key
cmd_update_key() {
    require_cmd gopass || return 1
    local input="${1:-}"

    if [[ -z "$input" ]]; then
        require_cmd fzf || return 1
        local existing
        existing=$(build_accounts_with_keys)
        [[ -z "$existing" ]] && { log_warn "No API keys to update"; return 0; }

        if ! input=$({
            echo "$existing"
            echo -e "${YELLOW}Back${NC}"
        } | fzf --ansi --height=40% --border=rounded --header='Update API Key'); then
            return "$RC_EXIT"
        fi
        input=$(normalize_menu_selection "$input")
        [[ -z "$input" ]] && return "$RC_EXIT"
        is_back_selection "$input" && return "$RC_BACK"
    fi

    local provider
    provider=$(get_provider "$input")
    local parsed acct_name
    parsed=$(parse_provider_account "$input")
    acct_name="${parsed#*|}"

    is_third_party "$provider" || { log_warn "Native provider, no key needed"; return 0; }
    key_exists "$provider" "$acct_name" || { log_error "No key exists. Use update-account."; return 1; }

    log_info "Updating API key for $input"
    printf "New API Key: "
    read -rs api_key
    echo ""
    [[ -z "$api_key" ]] && { log_error "API key required"; return 1; }

    store_api_key "$provider" "$acct_name" "$api_key"
    log_success "API key updated"
}

# Delete API key
cmd_delete_key() {
    require_cmd gopass || return 1
    local input="${1:-}"

    if [[ -z "$input" ]]; then
        require_cmd fzf || return 1
        local existing
        existing=$(build_accounts_with_keys)
        [[ -z "$existing" ]] && { log_warn "No API keys to delete"; return 0; }

        if ! input=$({
            echo "$existing"
            echo -e "${YELLOW}Back${NC}"
        } | fzf --ansi --height=40% --border=rounded --header='Delete API Key'); then
            return "$RC_EXIT"
        fi
        input=$(normalize_menu_selection "$input")
        [[ -z "$input" ]] && return "$RC_EXIT"
        is_back_selection "$input" && return "$RC_BACK"
    fi

    local provider
    provider=$(get_provider "$input")
    local parsed acct_name
    parsed=$(parse_provider_account "$input")
    acct_name="${parsed#*|}"

    key_exists "$provider" "$acct_name" || { log_error "No key exists"; return 1; }

    log_warn "Delete API key for $input?"
    printf "Continue? [y/N]: "
    read -r confirm
    [[ "$confirm" == "y" || "$confirm" == "Y" ]] && {
        delete_api_key "$provider" "$acct_name"
        log_success "API key deleted"
    } || echo "Cancelled"
}

# Test connectivity
cmd_test() {
    local input="${1:-}"
    if [[ -z "$input" ]]; then
        if input=$(fzf_pick_account "Test Connectivity"); then
            :
        else
            local rc=$?
            if [[ $rc -eq $RC_BACK || $rc -eq $RC_EXIT ]]; then
                return "$rc"
            fi
            return 1
        fi
    fi

    is_runtime_account "$input" || { log_error "Unknown account '$input'"; return 1; }

    local provider config base_url
    provider=$(get_provider "$input")
    config=$(opencode-token --config "$input")
    base_url=$(echo "$config" | jq -r '.base_url // empty')
    base_url=${base_url%/v1}
    base_url=${base_url%/v1/}
    base_url=${base_url%/}

    if [[ -z "$base_url" ]]; then
        log_warn "Native provider: $provider"
        log_success "Use 'opencode auth login $provider' to verify credentials"
        return 0
    fi

    require_cmd curl || return 1

    log_info "Testing $input..."
    echo "  Base URL: $base_url"

    local parsed acct_name
    parsed=$(parse_provider_account "$input")
    acct_name="${parsed#*|}"

    key_exists "$provider" "$acct_name" || {
        log_fail "No API key"
        return 1
    }
    log_success "Key found"

    local token
    token=$(get_api_key "$provider" "$acct_name") || { log_fail "Failed to decrypt"; return 1; }

    echo "  Testing API..."

    local header_file models_response models_code
    header_file=$(mktemp) || { log_fail "Failed to create header temp file"; return 1; }
    if ! chmod 600 "$header_file"; then
        log_fail "Failed to secure header temp file"
        rm -f "$header_file"
        return 1
    fi
    if ! cat > "$header_file" <<EOF
Authorization: Bearer $token
Content-Type: application/json
EOF
    then
        log_fail "Failed to write header file"
        rm -f "$header_file"
        return 1
    fi

    models_response=$(curl -sS -w "\n%{http_code}" --max-time 30 \
        -X GET "$base_url/v1/models" \
        -H @"$header_file" 2>&1 || true)
    models_code=$(echo "$models_response" | tail -n1)

    rm -f "$header_file"

    case "$models_code" in
        200)
            log_success "API OK (/v1/models)"
            ;;
        401|403)
            log_fail "Invalid API key"
            return 1
            ;;
        429)
            log_warn "Rate limited"
            ;;
        *)
            if [[ -z "$models_code" || "$models_code" == "000" ]]; then
                log_fail "Network error"
            else
                log_fail "HTTP $models_code"
            fi
            return 1
            ;;
    esac

    echo ""
    log_success "Account $input is configured"
}

# List accounts
cmd_list() {
    local filter="${1:-}"
    log_info "Configured accounts:"
    echo ""

    local account
    while IFS= read -r account; do
        [[ -z "$account" ]] && continue
        local provider
        provider=$(get_provider "$account")

        [[ -n "$filter" && "$provider" != "$filter" ]] && continue

        if is_third_party "$provider"; then
            local parsed acct_name
            parsed=$(parse_provider_account "$account")
            acct_name="${parsed#*|}"
            if key_exists "$provider" "$acct_name"; then
                echo -e "  ${GREEN}${STATUS_OK}${NC} $account"
            fi
        else
            echo -e "  ${GREEN}${STATUS_NATIVE}${NC} $account (native)"
        fi
    done < <(list_runtime_accounts)
}

# Show current
cmd_current() {
    local account provider
    account=$(get_current)
    provider=$(get_provider "$account")
    echo -e "Current: ${GREEN}${account}${NC} (${provider})"
}

# Run workflow diagnostics
cmd_doctor() {
    local ok=0
    local warn=0
    local fail=0

    pass() {
        echo -e "  ${GREEN}${STATUS_OK}${NC} $1"
        ok=$((ok + 1))
    }

    note_warn() {
        echo -e "  ${YELLOW}${STATUS_WARN}${NC} $1"
        warn=$((warn + 1))
    }

    note_fail() {
        echo -e "  ${RED}${STATUS_ERROR}${NC} $1"
        fail=$((fail + 1))
    }

    log_header "OpenCode Workflow Doctor"

    echo "Runtime commands:"
    if command -v opencode >/dev/null 2>&1; then pass "opencode found"; else note_fail "opencode not found"; fi
    if command -v jq >/dev/null 2>&1; then pass "jq found"; else note_fail "jq not found"; fi
    if command -v chezmoi >/dev/null 2>&1; then pass "chezmoi found"; else note_fail "chezmoi not found"; fi
    if command -v gopass >/dev/null 2>&1; then pass "gopass found"; else note_warn "gopass missing (third-party keys unavailable)"; fi
    echo ""

    echo "Rendered configs:"
    if [[ -f "$OPENCODE_CONFIG" ]]; then
        if jq -e . "$OPENCODE_CONFIG" >/dev/null 2>&1; then
            pass "~/.config/opencode/opencode.jsonc is valid JSON"
        else
            note_fail "~/.config/opencode/opencode.jsonc is not valid JSON"
        fi
    else
        note_fail "~/.config/opencode/opencode.jsonc missing"
    fi

    if [[ -f "$OPENCODE_OHMY_CONFIG" ]]; then
        if jq -e . "$OPENCODE_OHMY_CONFIG" >/dev/null 2>&1; then
            pass "~/.config/opencode/oh-my-opencode.jsonc is valid JSON"
        else
            note_fail "~/.config/opencode/oh-my-opencode.jsonc is not valid JSON"
        fi
    else
        note_warn "~/.config/opencode/oh-my-opencode.jsonc missing"
    fi

    local user_agents
    user_agents="${HOME}/.config/opencode/AGENTS.md"
    if [[ -f "$user_agents" ]]; then
        pass "~/.config/opencode/AGENTS.md present"
    else
        note_warn "~/.config/opencode/AGENTS.md missing"
    fi
    echo ""

    echo "Feature profile checks:"
    if [[ -f "$OPENCODE_CONFIG" ]]; then
        if jq -e '.agent | type == "object" and (keys | length) >= 1' "$OPENCODE_CONFIG" >/dev/null 2>&1; then
            pass "agent profile configured"
        else
            note_warn "agent profile missing"
        fi

        if jq -e '.command | type == "object" and (keys | length) >= 1' "$OPENCODE_CONFIG" >/dev/null 2>&1; then
            pass "command templates configured"
        else
            note_warn "command templates missing"
        fi

        if jq -e '.lsp | type == "object"' "$OPENCODE_CONFIG" >/dev/null 2>&1; then
            pass "lsp section configured"
        else
            note_warn "lsp section missing"
        fi

        if jq -e '.formatter | type == "object"' "$OPENCODE_CONFIG" >/dev/null 2>&1; then
            pass "formatter section configured"
        else
            note_warn "formatter section missing"
        fi

        local lsp_total=0
        local lsp_missing=0
        local lsp_name lsp_cmd
        while IFS=$'\t' read -r lsp_name lsp_cmd; do
            [[ -z "${lsp_name:-}" || -z "${lsp_cmd:-}" ]] && continue
            lsp_total=$((lsp_total + 1))
            if command -v "$lsp_cmd" >/dev/null 2>&1; then
                pass "lsp binary ready: ${lsp_name} (${lsp_cmd})"
            else
                note_warn "lsp binary missing: ${lsp_name} (${lsp_cmd})"
                lsp_missing=$((lsp_missing + 1))
            fi
        done < <(jq -r '
            (.lsp // {}) | to_entries[]
            | select(.value | type == "object")
            | select((.value.disabled // false) != true)
            | select((.value.command // []) | length > 0)
            | [.key, .value.command[0]]
            | @tsv
        ' "$OPENCODE_CONFIG" 2>/dev/null)

        if [[ $lsp_total -eq 0 ]]; then
            note_warn "no enabled lsp entries configured"
        elif [[ $lsp_missing -eq 0 ]]; then
            pass "enabled lsp binaries all present (${lsp_total})"
        else
            note_warn "enabled lsp binaries missing: ${lsp_missing}/${lsp_total}"
        fi

        local fmt_total=0
        local fmt_missing=0
        local fmt_name fmt_cmd
        while IFS=$'\t' read -r fmt_name fmt_cmd; do
            [[ -z "${fmt_name:-}" || -z "${fmt_cmd:-}" ]] && continue
            fmt_total=$((fmt_total + 1))
            if command -v "$fmt_cmd" >/dev/null 2>&1; then
                pass "formatter binary ready: ${fmt_name} (${fmt_cmd})"
            else
                note_warn "formatter binary missing: ${fmt_name} (${fmt_cmd})"
                fmt_missing=$((fmt_missing + 1))
            fi
        done < <(jq -r '
            (.formatter // {}) | to_entries[]
            | select(.value | type == "object")
            | select((.value.disabled // false) != true)
            | select((.value.command // []) | length > 0)
            | [.key, .value.command[0]]
            | @tsv
        ' "$OPENCODE_CONFIG" 2>/dev/null)

        if [[ $fmt_total -eq 0 ]]; then
            note_warn "no enabled formatter entries configured"
        elif [[ $fmt_missing -eq 0 ]]; then
            pass "enabled formatter binaries all present (${fmt_total})"
        else
            note_warn "enabled formatter binaries missing: ${fmt_missing}/${fmt_total}"
        fi
    fi
    echo ""

    echo "Plugin and policy checks:"
    if [[ -f "$OPENCODE_CONFIG" ]] && jq -e '.plugin | index("oh-my-opencode") != null' "$OPENCODE_CONFIG" >/dev/null 2>&1; then
        pass "oh-my-opencode plugin configured"
    else
        note_warn "oh-my-opencode plugin not configured"
    fi

    if [[ -f "$OPENCODE_CONFIG" ]] && jq -e '.plugin | index("opencode-plugin-openspec") != null' "$OPENCODE_CONFIG" >/dev/null 2>&1; then
        pass "opencode-plugin-openspec configured"
    else
        note_warn "opencode-plugin-openspec not configured"
    fi

    if [[ -f "$OPENCODE_OHMY_CONFIG" ]]; then
        local websearch_provider
        websearch_provider=$(jq -r '.websearch.provider // "exa"' "$OPENCODE_OHMY_CONFIG" 2>/dev/null)
        if [[ "$websearch_provider" == "tavily" ]]; then
            if [[ -n "${TAVILY_API_KEY:-}" ]]; then
                pass "websearch provider: tavily (TAVILY_API_KEY set)"
            else
                note_warn "websearch provider is tavily but TAVILY_API_KEY is not set"
            fi
        elif [[ -n "$websearch_provider" ]]; then
            pass "websearch provider: ${websearch_provider}"
        else
            note_warn "websearch provider not configured"
        fi
    fi

    local expected_mode="strict"
    expected_mode=$(chezmoi data --format json 2>/dev/null | jq -r '.opencodeCompatibilityMode // "strict"' 2>/dev/null || echo "strict")
    [[ "$expected_mode" == "compat" ]] || expected_mode="strict"

    local -a claude_bridge_toggles=(commands skills agents hooks plugins)
    local compat_policy_ok=true
    if [[ -f "$OPENCODE_OHMY_CONFIG" ]]; then
        local toggle expected_bool actual_bool
        for toggle in "${claude_bridge_toggles[@]}"; do
            expected_bool="false"
            [[ "$expected_mode" == "compat" ]] && expected_bool="true"
            actual_bool=$(jq -r --arg key "$toggle" '.claude_code[$key] // false' "$OPENCODE_OHMY_CONFIG" 2>/dev/null || echo "false")
            if [[ "$actual_bool" == "$expected_bool" ]]; then
                pass "claude_code.${toggle} matches ${expected_mode} mode (${actual_bool})"
            else
                note_warn "claude_code.${toggle} is ${actual_bool}, expected ${expected_bool} (${expected_mode} mode)"
                compat_policy_ok=false
            fi
        done

        if jq -e --argjson expected "$( [[ "$expected_mode" == "compat" ]] && echo true || echo false )" \
            '.sisyphus.tasks.claude_code_compat == $expected' "$OPENCODE_OHMY_CONFIG" >/dev/null 2>&1; then
            pass "sisyphus.tasks.claude_code_compat matches ${expected_mode} mode"
        else
            note_warn "sisyphus.tasks.claude_code_compat does not match ${expected_mode} mode"
            compat_policy_ok=false
        fi

        if [[ "$expected_mode" == "strict" ]]; then
            if jq -e '.disabled_hooks | index("claude-code-hooks") != null' "$OPENCODE_OHMY_CONFIG" >/dev/null 2>&1; then
                pass "claude-code-hooks disabled (strict mode)"
            else
                note_warn "claude-code-hooks should be disabled in strict mode"
                compat_policy_ok=false
            fi
        else
            if jq -e '.disabled_hooks | index("claude-code-hooks") == null' "$OPENCODE_OHMY_CONFIG" >/dev/null 2>&1; then
                pass "claude-code-hooks enabled (compat mode)"
            else
                note_warn "claude-code-hooks is disabled but compat mode expects it enabled"
                compat_policy_ok=false
            fi
        fi
    else
        compat_policy_ok=false
    fi

    if [[ "$compat_policy_ok" == true ]]; then
        pass "compatibility profile validated (${expected_mode})"
    else
        note_warn "compatibility profile drift detected (${expected_mode})"
    fi
    echo ""

    echo "Commands and skills projection:"
    if [[ -L "${HOME}/.config/opencode/commands/core" ]]; then
        pass "~/.config/opencode/commands/core symlink exists"
    else
        note_warn "~/.config/opencode/commands/core symlink missing"
    fi

    if [[ -L "${HOME}/.config/opencode/skills" ]]; then
        pass "~/.config/opencode/skills symlink exists"
    else
        note_warn "~/.config/opencode/skills symlink missing"
    fi

    if [[ -f "$OPENCODE_OHMY_CONFIG" ]] && jq -e '.skills.sources | type == "array" and length >= 1' "$OPENCODE_OHMY_CONFIG" >/dev/null 2>&1; then
        if jq -e '.skills.sources[]? | select(type=="object" and .path==".agents/skills" and .recursive==true)' "$OPENCODE_OHMY_CONFIG" >/dev/null 2>&1; then
            pass "oh-my recursive .agents/skills source configured"
        else
            note_warn "oh-my recursive .agents/skills source not configured"
        fi
    else
        note_warn "oh-my skills.sources missing"
    fi
    echo ""

    echo "MCP and model routing checks:"
    if [[ -f "$OPENCODE_OHMY_CONFIG" ]]; then
        local mcp
        for mcp in websearch context7 grep_app; do
            if jq -e --arg m "$mcp" '.disabled_mcps | index($m) != null' "$OPENCODE_OHMY_CONFIG" >/dev/null 2>&1; then
                note_warn "built-in MCP disabled: ${mcp}"
            else
                pass "built-in MCP enabled: ${mcp}"
            fi
        done
    else
        note_warn "unable to inspect built-in MCP state (oh-my config missing)"
    fi

    if [[ -f "$OPENCODE_CONFIG" && -f "$OPENCODE_OHMY_CONFIG" ]]; then
        local -a supported_providers=(openai anthropic google opencode github-copilot)
        local p
        while IFS= read -r p; do
            [[ -z "$p" ]] && continue
            if [[ " ${supported_providers[*]-} " != *" $p "* ]]; then
                supported_providers+=("$p")
            fi
        done < <(jq -r '.provider // {} | keys[]' "$OPENCODE_CONFIG" 2>/dev/null || true)

        local provider_missing=0
        while IFS= read -r p; do
            [[ -z "$p" ]] && continue
            if [[ " ${supported_providers[*]-} " == *" $p "* ]]; then
                pass "model provider available: ${p}"
            else
                note_warn "model provider missing from OpenCode config: ${p}"
                provider_missing=$((provider_missing + 1))
            fi
        done < <(jq -r '
            [
              ((.categories // {}) | to_entries[]?.value.model // empty),
              ((.agents // {}) | to_entries[]?.value.model // empty)
            ]
            | map(select(type=="string" and length > 0))
            | map(split("/")[0])
            | unique[]
        ' "$OPENCODE_OHMY_CONFIG" 2>/dev/null)

        if [[ $provider_missing -eq 0 ]]; then
            pass "all category/agent model providers are routable"
        else
            note_warn "some category/agent model providers are not routable (${provider_missing})"
        fi
    fi
    echo ""

    echo "Account and auth state:"
    local account provider
    account=$(get_current)
    provider=$(get_provider "$account")
    pass "current selector: ${account} (${provider})"

    if is_third_party "$provider"; then
        if opencode-token --check "$account" >/dev/null 2>&1; then
            pass "API key available for ${account}"
        else
            note_warn "API key missing for ${account}"
        fi
    else
        note_warn "${provider} uses native auth; run: opencode auth login ${provider}"
    fi

    echo ""
    echo -e "Summary: ${GREEN}${ok} ok${NC}, ${YELLOW}${warn} warning${NC}, ${RED}${fail} failed${NC}"
    [[ $fail -eq 0 ]]
}

# Show help
show_help() {
    cat << 'EOF'
OpenCode Account Manager

Usage:
  opencode-manage                               Interactive menu
  opencode-manage switch [account]              Switch default account
  opencode-manage create-account [account]      Create account (optionally with API key)
  opencode-manage update-account [account]      Update account (optionally rotate API key)
  opencode-manage remove-account [account]      Remove account (optionally delete API key)
  opencode-manage test [account]                Test connectivity
  opencode-manage list [provider]               List accounts
  opencode-manage current                       Show current account
  opencode-manage doctor                        Run workflow diagnostics

Compatibility aliases:
  add-account -> create-account
  edit-account -> update-account

Legacy key-only commands (still supported):
  add-key | update-key | delete-key
EOF
}

# Main
main() {
    local cmd="${1:-}"
    shift || true

    case "$cmd" in
        help|--help|-h)
            show_help
            ;;
        "")
            require_cmd chezmoi jq fzf gopass || return 1
            run_cmd fzf_menu
            ;;
        switch|sw)
            require_cmd chezmoi jq || return 1
            run_cmd cmd_switch "$@"
            ;;
        create-account|add-account)
            require_cmd chezmoi jq gopass fzf || return 1
            run_cmd cmd_create_account "$@"
            ;;
        update-account|edit-account)
            if [[ $# -eq 0 ]]; then
                require_cmd chezmoi jq gopass fzf || return 1
            else
                require_cmd chezmoi jq gopass || return 1
            fi
            run_cmd cmd_update_account "$@"
            ;;
        remove-account)
            if [[ $# -eq 0 ]]; then
                require_cmd chezmoi jq gopass fzf || return 1
            else
                require_cmd chezmoi jq gopass || return 1
            fi
            run_cmd cmd_remove_account "$@"
            ;;
        add-key|update-key|delete-key)
            if [[ $# -eq 0 ]]; then
                require_cmd chezmoi jq gopass fzf || return 1
            else
                require_cmd chezmoi jq gopass || return 1
            fi
            case "$cmd" in
                add-key) run_cmd cmd_add_key "$@" ;;
                update-key) run_cmd cmd_update_key "$@" ;;
                delete-key) run_cmd cmd_delete_key "$@" ;;
            esac
            ;;
        test)
            require_cmd chezmoi jq gopass curl || return 1
            run_cmd cmd_test "$@"
            ;;
        list|ls)
            require_cmd chezmoi jq gopass || return 1
            run_cmd cmd_list "$@"
            ;;
        doctor)
            require_cmd chezmoi jq || return 1
            run_cmd cmd_doctor "$@"
            ;;
        current)
            require_cmd chezmoi jq || return 1
            cmd_current
            ;;
        *)
            log_error "Unknown: $cmd"
            show_help
            return 1
            ;;
    esac
}

main "$@"
