  "skills": {
    "paths": [
      ".agents/skills"
    ]
  },
  "plugin": [
    "oh-my-opencode",
    "opencode-plugin-openspec"
  ],
  "mcp": {
    "tavily": {
      "type": "local",
      "command": ["{{ .chezmoi.homeDir }}/.local/bin/mcp-tavily"],
      "enabled": true
    },
    "context7": {
      "type": "local",
      "command": ["{{ .chezmoi.homeDir }}/.local/bin/mcp-context7"],
      "enabled": true
    },
    "serena": {
      "type": "local",
      "command": ["uvx", "--from", "git+https://github.com/oraios/serena", "serena", "start-mcp-server", "--context", "ide", "--project", ".", "--enable-web-dashboard", "false"],
      "enabled": true
    },
    "gitmcp": {
      "type": "remote",
      "url": "https://gitmcp.io/docs",
      "oauth": false,
      "enabled": true
    }
  },
  "permission": {
    "edit": "ask",
    "bash": "ask",
    "external_directory": "ask",
    "webfetch": "ask",
    "websearch": "ask",
    "codesearch": "ask",
    "lsp": "ask",
    "task": "ask",
    "skill": "ask",
    "doom_loop": "ask"
  }
}
