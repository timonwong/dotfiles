        "apiKey": {{ get $providerApiKeys "naapi@private" | quote }}{{- end }}
      },
      "models": {
        "gpt-5.3-codex": {
          "name": "GPT-5.3 Codex",
          "options": {
            "store": false
          },
          "variants": {
