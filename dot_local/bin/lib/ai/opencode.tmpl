#!/usr/bin/env bash
# OpenCode Shared Library
# Common functions for opencode-manage and opencode-with
#
# Usage: source lib/ai/opencode

# Source shared AI tools library
OPENCODE_LIB_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
AI_TOOL_CONTEXT="opencode"
source "$OPENCODE_LIB_DIR/core"

# OpenCode-specific paths
OPENCODE_CONFIG="${HOME}/.config/opencode/opencode.jsonc"
OPENCODE_OHMY_CONFIG="${HOME}/.config/opencode/oh-my-opencode.jsonc"

# Get current OpenCode account from chezmoi data
get_current() {
    chezmoi data --format json 2>/dev/null | jq -r '.opencodeProviderAccount // .opencodeProvider // "openai"'
}

# Build account list with status indicators
build_account_list_with_status() {
    local current
    current=$(get_current)
    local account
    while IFS= read -r account; do
        [[ -z "$account" ]] && continue
        if [[ "$account" == "$current" ]]; then
            echo -e "${GREEN}$account ✓${NC}"
        else
            echo "$account"
        fi
    done < <(list_runtime_accounts)
}

# Build account list with token status
build_account_list_with_token() {
    local account
    while IFS= read -r account; do
        [[ -z "$account" ]] && continue
        local provider
        provider=$(get_provider "$account")
        if is_third_party "$provider"; then
            local parsed acct_name
            parsed=$(parse_provider_account "$account")
            acct_name="${parsed#*|}"
            if key_exists "$provider" "$acct_name"; then
                echo -e "${GREEN}✓${NC} $account"
            else
                echo -e "${RED}✗${NC} $account"
            fi
        else
            echo -e "${CYAN}○${NC} $account"
        fi
    done < <(list_runtime_accounts)
}

# Common preview script for account selection
ACCOUNT_PREVIEW='
    line=$(echo {} | sed "s/^[[:space:]]*//" | tr -d "\033" | sed -E "s/\[[0-9;]*[mK]//g")
    if [[ "$line" == "Back" ]]; then
        echo "Return to main menu"
        exit 0
    fi
    account=$(echo "$line" | sed "s/ ✓$//" | sed "s/^[✓✗○] //")
    echo -e "\033[1;34m━━━ $account ━━━\033[0m"
    echo ""
    config=$(opencode-token --config "$account" 2>/dev/null)
    if [[ -n "$config" ]]; then
        echo "$config" | jq -r "
            \"Model:     \(.model_ref // .model // \"default\")\",
            \"Provider:  \(.provider // \"auto\")\",
            (if .base_url then \"Base URL:  \(.base_url)\" else empty end),
            (if .env_var then \"Env Key:   \(.env_var)\" else empty end)
        " 2>/dev/null || echo "Config not available"
    else
        echo "Config not available"
    fi
    echo ""
    if echo "$config" | jq -e ".base_url // empty" >/dev/null 2>&1; then
        if opencode-token --check "$account" 2>/dev/null; then
            echo -e "\033[0;32m✓ Token ready\033[0m"
        else
            echo -e "\033[0;31m✗ No token (run: opencode-manage update-account $account)\033[0m"
        fi
    else
        echo -e "\033[0;36m○ Native auth\033[0m"
    fi
'

# Generic account picker with Back option
fzf_pick_account() {
    local header="$1"
    local list_type="${2:-status}"
    local current
    current=$(get_current)

    local result raw
    if ! raw=$({
        case "$list_type" in
            token) build_account_list_with_token ;;
            plain) printf '%s\n' "${ACCOUNTS[@]}" ;;
            *)     build_account_list_with_status ;;
        esac
        echo -e "${YELLOW}Back${NC}"
    } | fzf --ansi \
        --height=50% \
        --border=rounded \
        --header="$header" \
        --preview="$ACCOUNT_PREVIEW" \
        --preview-window='right:50%:wrap' \
        --preview-label="[ Current: $current ]"); then
        return "$RC_EXIT"
    fi

    result=$(normalize_menu_selection "$raw")

    [[ -z "$result" ]] && return "$RC_EXIT"
    is_back_selection "$result" && return "$RC_BACK"

    result=$(echo "$result" | sed 's/ ✓$//' | sed 's/^[[:space:]]*//')
    result=$(echo "$result" | sed 's/^[✓✗○] //')
    echo "$result"
}
