#!/usr/bin/env bash
# Claude Code Account Manager
# Manage accounts and API keys with fzf interface
#
# Usage:
#   claude-manage                   # Interactive menu
#   claude-manage switch [account]         # Switch default account
#   claude-manage create-account [account] # Create account (optionally with API key)
#   claude-manage update-account [account] # Update account (optionally rotate API key)
#   claude-manage remove-account [account] # Remove account (optionally delete API key)
#   claude-manage test [account]           # Test connectivity
#   claude-manage list [provider]          # List accounts
#   claude-manage doctor                   # Run workflow diagnostics

set -euo pipefail

# shellcheck source=lib/ai/claude.tmpl
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
source "$SCRIPT_DIR/lib/ai/claude"

# Return codes used for interactive navigation.
# (Also defined in lib/ai/claude, but keep here so this script is self-contained.)
: "${RC_BACK:=10}"
: "${RC_EXIT:=130}"

# Set account in chezmoi.toml
set_chezmoi_account() {
    local account="$1"
    local escaped_account
    escaped_account=$(escape_toml_string "$account")
    local tmp_file
    tmp_file=$(mktemp) || { log_error "Failed to create temp file"; return 1; }

    if grep -q "^claudeProviderAccount = " "$CHEZMOI_CONFIG"; then
        sed "s/^claudeProviderAccount = .*/claudeProviderAccount = \"$escaped_account\"/" "$CHEZMOI_CONFIG" > "$tmp_file"
    elif grep -q "^claudeProvider = " "$CHEZMOI_CONFIG"; then
        # Keep claudeProvider intact; insert claudeProviderAccount after it.
        awk -v line="claudeProviderAccount = \"$escaped_account\"" '
            BEGIN { inserted = 0 }
            { print }
            /^claudeProvider = / && inserted == 0 { print line; inserted = 1 }
            END { if (inserted == 0) print line }
        ' "$CHEZMOI_CONFIG" > "$tmp_file"
    else
        cp "$CHEZMOI_CONFIG" "$tmp_file"
        echo "claudeProviderAccount = \"$escaped_account\"" >> "$tmp_file"
    fi
    mv "$tmp_file" "$CHEZMOI_CONFIG"
}

# FZF interactive menu
fzf_menu() {
    while true; do
        local current
        current=$(get_current)

        local selected
        if ! selected=$({
            cat <<'MENU'
switch         Change default account
create-account Create account (and optional API key)
update-account Update account (and optional API key)
remove-account Remove account (and optional API key)
test           Test connectivity
list           Show all accounts
doctor         Run workflow diagnostics
MENU
            echo -e "${YELLOW}quit${NC}           Exit to shell"
        } | fzf --ansi \
            --height=50% \
            --border=rounded \
            --header="Account Manager" \
            --preview='
                cmd=$(echo {} | awk "{print \$1}")
                echo -e "\033[1;34m━━━ $cmd ━━━\033[0m"
                echo ""
                case "$cmd" in
                    switch)         echo "Switch the default account." ;;
                    create-account) echo "Create account (and optional API key)." ;;
                    update-account) echo "Update account (and optional API key)." ;;
                    remove-account) echo "Remove account (and optional API key)." ;;
                    test)           echo "Test API connectivity." ;;
                    list)           echo "Show all accounts." ;;
                    doctor)         echo "Run workflow diagnostics." ;;
                    quit)           echo "Exit to shell." ;;
                esac
                echo ""
                echo -e "\033[1;34m━━━ Accounts ━━━\033[0m"
                echo ""
                claude-manage list 2>/dev/null | tail -n +3
            ' \
            --preview-window='right:50%:wrap' \
            --preview-label="[ Current: $current ]"
        ); then
            return "$RC_EXIT"
        fi

        local cmd
        selected=$(normalize_menu_selection "$selected")
        cmd=$(echo "$selected" | awk '{print $1}')

        local rc=0
        case "$cmd" in
            switch)         cmd_switch || rc=$? ;;
            create-account) cmd_create_account || rc=$? ;;
            update-account) cmd_update_account || rc=$? ;;
            remove-account) cmd_remove_account || rc=$? ;;
            test)           cmd_test || rc=$? ;;
            list)           cmd_list || rc=$? ;;
            doctor)         cmd_doctor || rc=$? ;;
            quit)           return 0 ;;
            *)              log_error "Unknown command: $cmd"; return 1 ;;
        esac

        case "$rc" in
            0) return 0 ;;
            "$RC_BACK") continue ;;
            "$RC_EXIT") return "$RC_EXIT" ;;
            *)
                log_error "Command '$cmd' failed (exit $rc)"
                return "$rc"
                ;;
        esac
    done
}

# Switch account
cmd_switch() {
    local input="${1:-}"
    if [[ -z "$input" ]]; then
        if input=$(fzf_pick_account "Switch Account"); then
            :
        else
            local rc=$?
            if [[ $rc -eq $RC_BACK || $rc -eq $RC_EXIT ]]; then
                return "$rc"
            fi
            return 1
        fi
    fi

    if ! is_runtime_account "$input"; then
        log_error "Unknown account '$input'"
        return 1
    fi

    local provider
    provider=$(get_provider "$input")

    if is_third_party "$provider" && ! claude-token --check "$input" 2>/dev/null; then
        log_error "No API token for $input"
        echo "Run: claude-manage update-account $input" >&2
        return 1
    fi

    [[ "$(get_current)" == "$input" ]] && { log_warn "Already using '$input'"; return 0; }

    log_info "Setting default to $input..."
    set_chezmoi_account "$input"
    echo "  ✓ Updated chezmoi.toml"
    chezmoi apply --verbose --exclude scripts "$SETTINGS_FILE" "$SCRIPT_DIR/lib/ai/core"
    echo "  ✓ Applied chezmoi"
    echo ""
    log_success "Default set to $input"
    log_warn "Restart Claude Code to apply changes"
}

# Ensure third-party account model fields exist (fill missing only; never overwrite)
ensure_third_party_account_models() {
    local account="$1"
    local provider
    provider=$(get_provider "$account")

    if ! is_third_party "$provider"; then
        return 0
    fi

    local default_model
    default_model=$(get_provider_default_model "$provider")

    ACCOUNT_NAME="$account" DEFAULT_MODEL="$default_model" yq -i '
      .claude.accounts[strenv(ACCOUNT_NAME)] as $acct |
      .claude.accounts[strenv(ACCOUNT_NAME)].model = (
        ($acct.model // "") as $m |
        if $m == "" then (($acct.small_model // strenv(DEFAULT_MODEL) // "") as $s | if $s == "" then null else $s end) else $m end
      ) |
      .claude.accounts[strenv(ACCOUNT_NAME)].small_model = (
        ($acct.small_model // "") as $s |
        if $s == "" then (($acct.model // strenv(DEFAULT_MODEL) // "") as $m | if $m == "" then null else $m end) else $s end
      ) |
      .claude.accounts[strenv(ACCOUNT_NAME)].sonnet_model = (
        ($acct.sonnet_model // "") as $v |
        if $v == "" then (($acct.small_model // $acct.model // strenv(DEFAULT_MODEL) // "") as $d | if $d == "" then null else $d end) else $v end
      ) |
      .claude.accounts[strenv(ACCOUNT_NAME)].opus_model = (
        ($acct.opus_model // "") as $v |
        if $v == "" then (($acct.model // $acct.small_model // strenv(DEFAULT_MODEL) // "") as $d | if $d == "" then null else $d end) else $v end
      ) |
      .claude.accounts[strenv(ACCOUNT_NAME)].haiku_model = (
        ($acct.haiku_model // "") as $v |
        if $v == "" then (($acct.small_model // $acct.model // strenv(DEFAULT_MODEL) // "") as $d | if $d == "" then null else $d end) else $v end
      )
    ' "$CLAUDE_YAML"

    if ! ACCOUNT_NAME="$account" yq -e '
      .claude.accounts[strenv(ACCOUNT_NAME)] as $acct |
      ($acct.model // "") != "" and
      ($acct.small_model // "") != "" and
      ($acct.sonnet_model // "") != "" and
      ($acct.opus_model // "") != "" and
      ($acct.haiku_model // "") != ""
    ' "$CLAUDE_YAML" >/dev/null; then
        log_error "Failed to ensure required third-party model fields for '$account'"
        return 1
    fi
}

# Create account
cmd_create_account() {
    require_cmd fzf yq || return 1

    log_info "Add New Account"
    echo ""

    # Select provider
    local provider
    if ! provider=$({
        printf '%s\n' "${PROVIDERS[@]}"
        echo -e "${YELLOW}Back${NC}"
    } | fzf --ansi --height=40% --border=rounded --header="Select Provider"); then
        return "$RC_EXIT"
    fi
    provider=$(normalize_menu_selection "$provider")
    [[ -z "$provider" ]] && return "$RC_EXIT"
    is_back_selection "$provider" && return "$RC_BACK"

    # Get account name
    local account_name full_name
    echo ""
    if [[ "$provider" == "anthropic" ]]; then
        printf "Account name (e.g., sonnet, opus): "
        read -r account_name
        [[ -z "$account_name" ]] && return 1
        full_name="$account_name"
    else
        printf 'Account name (will become %s@<name>): ' "$provider"
        read -r account_name
        [[ -z "$account_name" ]] && return 1
        full_name="${provider}@${account_name}"
    fi

    if ! validate_account_name "$account_name"; then
        log_error "Invalid account name (allowed: letters, numbers, dot, underscore, hyphen)"
        return 1
    fi

    ACCOUNT_NAME="$full_name" yq -e '.claude.accounts[strenv(ACCOUNT_NAME)]' "$CLAUDE_YAML" &>/dev/null && {
        log_error "Account '$full_name' already exists"
        return 1
    }

    # Get model
    echo ""
    local model small_model
    if is_third_party "$provider"; then
        model=$(get_provider_default_model "$provider")
        [[ -z "$model" ]] && model="$provider"
        small_model="$model"
        log_info "Using provider default model: $model"
    else
        printf "Model name: "
        read -r model
        [[ -z "$model" ]] && { log_error "Model is required"; return 1; }

        printf "Small model (Enter to use same): "
        read -r small_model
        [[ -z "$small_model" ]] && small_model="$model"
    fi

    # Add to YAML
    echo ""
    log_info "Adding account..."
    ACCOUNT_NAME="$full_name" \
    PROVIDER_NAME="$provider" \
    MODEL_NAME="$model" \
    SMALL_MODEL_NAME="$small_model" \
    yq -i '
        .claude.accounts[strenv(ACCOUNT_NAME)] = {
            "provider": strenv(PROVIDER_NAME),
            "model": strenv(MODEL_NAME),
            "small_model": strenv(SMALL_MODEL_NAME)
        }
    ' "$CLAUDE_YAML"

    if is_third_party "$provider"; then
        ensure_third_party_account_models "$full_name"
    fi
    log_success "Account '$full_name' added"

    # Add API key for third-party
    if is_third_party "$provider"; then
        echo ""
        printf "API Key (leave empty to skip): "
        read -rs api_key
        echo ""
        if [[ -n "$api_key" ]]; then
            store_api_key "$provider" "$account_name" "$api_key"
            log_success "API key saved"
        else
            log_info "Skipped API key (run: claude-manage update-account $full_name)"
        fi
    fi

    echo ""
    log_info "Applying chezmoi..."
    chezmoi apply --verbose --exclude scripts "$SETTINGS_FILE" "$SCRIPT_DIR/lib/ai/core"
    log_success "Done"
}

# Update account
cmd_update_account() {
    require_cmd yq || return 1

    local input="${1:-}"
    if [[ -z "$input" ]]; then
        require_cmd fzf || return 1
    fi
    if [[ -z "$input" ]]; then
        if input=$(fzf_pick_account "Edit Account" "plain"); then
            :
        else
            local rc=$?
            if [[ $rc -eq $RC_BACK || $rc -eq $RC_EXIT ]]; then
                return "$rc"
            fi
            return 1
        fi
    fi

    is_runtime_account "$input" || { log_error "Unknown account '$input'"; return 1; }

    log_info "Edit Account: $input"
    echo ""

    local current_model current_small
    current_model=$(ACCOUNT_NAME="$input" yq -r '.claude.accounts[strenv(ACCOUNT_NAME)].model // ""' "$CLAUDE_YAML")
    current_small=$(ACCOUNT_NAME="$input" yq -r '.claude.accounts[strenv(ACCOUNT_NAME)].small_model // ""' "$CLAUDE_YAML")

    echo "Current model: $current_model"
    printf "New model (Enter to keep): "
    read -r new_model
    [[ -z "$new_model" ]] && new_model="$current_model"

    echo "Current small_model: $current_small"
    printf "New small_model (Enter to keep): "
    read -r new_small
    [[ -z "$new_small" ]] && new_small="$current_small"

    ACCOUNT_NAME="$input" \
    NEW_MODEL="$new_model" \
    NEW_SMALL="$new_small" \
    yq -i '
        .claude.accounts[strenv(ACCOUNT_NAME)].model = strenv(NEW_MODEL) |
        .claude.accounts[strenv(ACCOUNT_NAME)].small_model = strenv(NEW_SMALL)
    ' "$CLAUDE_YAML"

    if is_third_party_account "$input"; then
        ensure_third_party_account_models "$input"
        log_info "Ensured third-party model fields (fill missing only)"
    fi

    echo ""
    log_success "Account '$input' updated"
    log_info "Applying chezmoi..."
    chezmoi apply --verbose --exclude scripts "$SETTINGS_FILE" "$SCRIPT_DIR/lib/ai/core"
    log_success "Done"
}

# Remove account
cmd_remove_account() {
    require_cmd yq || return 1

    local input="${1:-}"
    if [[ -z "$input" ]]; then
        require_cmd fzf || return 1
    fi
    if [[ -z "$input" ]]; then
        if input=$(fzf_pick_account "Remove Account" "plain"); then
            :
        else
            local rc=$?
            if [[ $rc -eq $RC_BACK || $rc -eq $RC_EXIT ]]; then
                return "$rc"
            fi
            return 1
        fi
    fi

    is_runtime_account "$input" || { log_error "Unknown account '$input'"; return 1; }

    local has_profile=0
    if ACCOUNT_NAME="$input" yq -e '.claude.accounts[strenv(ACCOUNT_NAME)] // empty' "$CLAUDE_YAML" >/dev/null 2>&1; then
        has_profile=1
    fi

    log_warn "Remove account '$input'?"
    if [[ "$has_profile" -eq 1 ]]; then
        printf "This will delete it from claude.yaml. Continue? [y/N]: "
    else
        printf "No claude.yaml profile found; continue to manage API key only? [y/N]: "
    fi
    read -r confirm
    [[ "$confirm" != "y" && "$confirm" != "Y" ]] && { echo "Cancelled"; return 0; }

    local provider
    provider=$(get_provider "$input")

    if [[ "$has_profile" -eq 1 ]]; then
        ACCOUNT_NAME="$input" yq -i 'del(.claude.accounts[strenv(ACCOUNT_NAME)])' "$CLAUDE_YAML"
        log_success "Account profile removed"
    else
        log_info "Skipped profile removal (not present in claude.yaml)"
    fi

    if is_third_party "$provider"; then
        local parsed acct_name
        parsed=$(parse_provider_account "$input")
        acct_name="${parsed#*|}"
        if key_exists "$provider" "$acct_name"; then
            printf "Also delete API key? [y/N]: "
            read -r del_key
            [[ "$del_key" == "y" || "$del_key" == "Y" ]] && {
                delete_api_key "$provider" "$acct_name"
                log_success "API key deleted"
            }
        fi
    fi

    if [[ "$has_profile" -eq 1 ]]; then
        echo ""
        log_info "Applying chezmoi..."
        chezmoi apply --verbose --exclude scripts "$SETTINGS_FILE" "$SCRIPT_DIR/lib/ai/core"
        log_success "Done"
    fi
}

# Add API key
cmd_add_key() {
    require_cmd gopass || return 1
    local input="${1:-}"

    if [[ -z "$input" ]]; then
        require_cmd fzf || return 1
        local needs_key=()
        for acct in "${ACCOUNTS[@]}"; do
            local prov
            prov=$(get_provider "$acct")
            if is_third_party "$prov"; then
                local parsed acct_name
                parsed=$(parse_provider_account "$acct")
                acct_name="${parsed#*|}"
                key_exists "$prov" "$acct_name" || needs_key+=("$acct")
            fi
        done

        [[ ${#needs_key[@]} -eq 0 ]] && {
            log_warn "All accounts already have API keys"
            return 0
        }

        if ! input=$({
            printf '%s\n' "${needs_key[@]}"
            echo -e "${YELLOW}Back${NC}"
        } | fzf --ansi --height=40% --border=rounded --header='Add API Key'); then
            return "$RC_EXIT"
        fi
        input=$(normalize_menu_selection "$input")
        [[ -z "$input" ]] && return "$RC_EXIT"
        is_back_selection "$input" && return "$RC_BACK"
    fi

    local provider
    provider=$(get_provider "$input")
    local parsed acct_name
    parsed=$(parse_provider_account "$input")
    acct_name="${parsed#*|}"

    is_third_party "$provider" || { log_warn "Native OAuth, no key needed"; return 0; }
    key_exists "$provider" "$acct_name" && { log_error "Key already exists. Use update-key."; return 1; }

    log_info "Adding API key for $input"
    printf "API Key: "
    read -rs api_key
    echo ""
    [[ -z "$api_key" ]] && { log_error "API key required"; return 1; }

    store_api_key "$provider" "$acct_name" "$api_key"
    log_success "API key saved"
    log_info "Tip: run 'claude-manage test $input' to verify"
}

# Update API key
cmd_update_key() {
    require_cmd gopass || return 1
    local input="${1:-}"

    if [[ -z "$input" ]]; then
        require_cmd fzf || return 1
        local existing
        existing=$(build_accounts_with_keys)
        [[ -z "$existing" ]] && { log_warn "No API keys to update"; return 0; }

        if ! input=$({
            echo "$existing"
            echo -e "${YELLOW}Back${NC}"
        } | fzf --ansi --height=40% --border=rounded --header='Update API Key'); then
            return "$RC_EXIT"
        fi
        input=$(normalize_menu_selection "$input")
        [[ -z "$input" ]] && return "$RC_EXIT"
        is_back_selection "$input" && return "$RC_BACK"
    fi

    local provider
    provider=$(get_provider "$input")
    local parsed acct_name
    parsed=$(parse_provider_account "$input")
    acct_name="${parsed#*|}"

    is_third_party "$provider" || { log_warn "Native OAuth, no key needed"; return 0; }
    key_exists "$provider" "$acct_name" || { log_error "No key exists. Use update-account."; return 1; }

    log_info "Updating API key for $input"
    printf "New API Key: "
    read -rs api_key
    echo ""
    [[ -z "$api_key" ]] && { log_error "API key required"; return 1; }

    store_api_key "$provider" "$acct_name" "$api_key"
    log_success "API key updated"
    log_info "Tip: run 'claude-manage test $input' to verify"
}

# Delete API key
cmd_delete_key() {
    require_cmd gopass || return 1
    local input="${1:-}"

    if [[ -z "$input" ]]; then
        require_cmd fzf || return 1
        local existing
        existing=$(build_accounts_with_keys)
        [[ -z "$existing" ]] && { log_warn "No API keys to delete"; return 0; }

        if ! input=$({
            echo "$existing"
            echo -e "${YELLOW}Back${NC}"
        } | fzf --ansi --height=40% --border=rounded --header='Delete API Key'); then
            return "$RC_EXIT"
        fi
        input=$(normalize_menu_selection "$input")
        [[ -z "$input" ]] && return "$RC_EXIT"
        is_back_selection "$input" && return "$RC_BACK"
    fi

    local provider
    provider=$(get_provider "$input")
    local parsed acct_name
    parsed=$(parse_provider_account "$input")
    acct_name="${parsed#*|}"

    key_exists "$provider" "$acct_name" || { log_error "No key exists"; return 1; }

    log_warn "Delete API key for $input?"
    printf "Continue? [y/N]: "
    read -r confirm
    [[ "$confirm" == "y" || "$confirm" == "Y" ]] && {
        delete_api_key "$provider" "$acct_name"
        log_success "API key deleted"
    } || echo "Cancelled"
}

# Test connectivity
cmd_test() {
    local input="${1:-}"
    if [[ -z "$input" ]]; then
        if input=$(fzf_pick_account "Test Connectivity"); then
            :
        else
            local rc=$?
            if [[ $rc -eq $RC_BACK || $rc -eq $RC_EXIT ]]; then
                return "$rc"
            fi
            return 1
        fi
    fi

    is_runtime_account "$input" || { log_error "Unknown account '$input'"; return 1; }

    local provider config base_url
    provider=$(get_provider "$input")
    config=$(claude-token --config "$input")
    base_url=$(echo "$config" | jq -r '.base_url // empty')

    [[ -z "$base_url" ]] && {
        log_warn "Native Anthropic (OAuth)"
        log_success "No API key needed"
        return 0
    }

    require_cmd curl || return 1

    log_info "Testing $input..."
    echo "  Base URL: $base_url"

    local parsed acct_name
    parsed=$(parse_provider_account "$input")
    acct_name="${parsed#*|}"

    key_exists "$provider" "$acct_name" || {
        log_fail "No API key"
        return 1
    }
    log_success "Key found"

    local token
    token=$(claude-token "$input" 2>/dev/null) || { log_fail "Failed to decrypt"; return 1; }

    echo "  Testing API..."
    local model response http_code
    model=$(echo "$config" | jq -r '.model // "unknown"')
    local header_file
    header_file=$(mktemp) || { log_fail "Failed to create header temp file"; return 1; }
    if ! chmod 600 "$header_file"; then
        log_fail "Failed to secure header temp file"
        rm -f "$header_file"
        return 1
    fi
    if ! cat > "$header_file" <<EOF
x-api-key: $token
anthropic-version: 2023-06-01
Content-Type: application/json
EOF
    then
        log_fail "Failed to write header file"
        rm -f "$header_file"
        return 1
    fi

    response=$(curl -sS -w "\n%{http_code}" --max-time 30 \
        -X POST "$base_url/v1/messages" \
        -H @"$header_file" \
        -d "{\"model\":\"$model\",\"max_tokens\":1,\"messages\":[{\"role\":\"user\",\"content\":\"hi\"}]}" 2>&1 || true)
    rm -f "$header_file"

    http_code=$(echo "$response" | tail -n1)

    case "$http_code" in
        200)
            log_success "API OK"
            ;;
        401)
            log_fail "Invalid API key"
            return 1
            ;;
        403)
            log_fail "Access forbidden"
            return 1
            ;;
        429)
            log_warn "Rate limited"
            http_code=200
            ;;
        *)
            if [[ -z "$http_code" || "$http_code" == "000" || ! "$http_code" =~ ^[0-9]{3}$ ]]; then
                log_fail "Network error"
            else
                log_fail "HTTP $http_code"
            fi
            return 1
            ;;
    esac

    if [[ "$http_code" != "200" ]]; then
        return 1
    fi

    echo ""
    log_success "Account $input is working"
}

# List accounts
list_claude_accounts() {
    list_runtime_accounts
}

cmd_list() {
    local filter="${1:-}"
    log_info "Configured accounts:"
    echo ""

    local account
    while IFS= read -r account; do
        [[ -z "$account" ]] && continue
        local provider
        provider=$(get_provider "$account")

        [[ -n "$filter" && "$provider" != "$filter" ]] && continue

        if is_third_party "$provider"; then
            local parsed acct_name
            parsed=$(parse_provider_account "$account")
            acct_name="${parsed#*|}"
            if key_exists "$provider" "$acct_name"; then
                echo -e "  ${GREEN}${STATUS_OK}${NC} $account"
            fi
        else
            echo -e "  ${GREEN}${STATUS_NATIVE}${NC} $account (native)"
        fi
    done < <(list_claude_accounts)
}

# Show current
cmd_current() {
    echo -e "Current: ${GREEN}$(get_current)${NC}"
}

# Run workflow diagnostics
cmd_doctor() {
    local ok=0
    local warn=0
    local fail=0

    pass() {
        echo -e "  ${GREEN}${STATUS_OK}${NC} $1"
        ok=$((ok + 1))
    }

    note_warn() {
        echo -e "  ${YELLOW}${STATUS_WARN}${NC} $1"
        warn=$((warn + 1))
    }

    note_fail() {
        echo -e "  ${RED}${STATUS_ERROR}${NC} $1"
        fail=$((fail + 1))
    }

    log_header "Claude Workflow Doctor"

    echo "Runtime commands:"
    if command -v claude >/dev/null 2>&1; then pass "claude found"; else note_fail "claude not found"; fi
    if command -v openspec >/dev/null 2>&1; then pass "openspec found"; else note_warn "openspec not found (C3/L3 OpenSpec gate unavailable)"; fi
    if command -v specify >/dev/null 2>&1; then pass "specify found"; else note_warn "specify not found (C4 Spec-Kit bootstrap unavailable)"; fi
    if command -v jq >/dev/null 2>&1; then pass "jq found"; else note_fail "jq not found"; fi
    if command -v chezmoi >/dev/null 2>&1; then pass "chezmoi found"; else note_fail "chezmoi not found"; fi
    if command -v yq >/dev/null 2>&1; then pass "yq found"; else note_warn "yq missing (account metadata checks reduced)"; fi
    if require_cmd gopass >/dev/null 2>&1; then pass "gopass found"; else note_warn "gopass missing (third-party keys unavailable)"; fi
    echo ""

    echo "Rendered configs:"
    if [[ -f "$SETTINGS_FILE" ]]; then
        if jq -e . "$SETTINGS_FILE" >/dev/null 2>&1; then
            pass "~/.claude/settings.json is valid JSON"
        else
            note_fail "~/.claude/settings.json is not valid JSON"
        fi
    else
        note_warn "~/.claude/settings.json missing"
    fi

    if [[ -f "$CLAUDE_YAML" ]]; then
        pass "~/.local/share/chezmoi/.chezmoidata/claude.yaml present"
    else
        note_warn "~/.local/share/chezmoi/.chezmoidata/claude.yaml missing"
    fi

    if [[ -f "${HOME}/.claude/CLAUDE.md" ]]; then
        pass "~/.claude/CLAUDE.md present"
    else
        note_warn "~/.claude/CLAUDE.md missing"
    fi
    echo ""

    echo "Commands and skills projection:"
    local cmd_count
    cmd_count=$(find "${HOME}/.claude/commands/core" -maxdepth 1 -name '*.md' 2>/dev/null | wc -l | tr -d ' ')
    if [[ "${cmd_count:-0}" -ge 7 ]]; then
        pass "core command docs present (${cmd_count})"
    else
        note_warn "core command docs incomplete (${cmd_count:-0})"
    fi

    if [[ -L "${HOME}/.claude/skills" ]]; then
        pass "~/.claude/skills symlink exists"
    else
        note_warn "~/.claude/skills symlink missing"
    fi

    if command -v specify >/dev/null 2>&1; then
        if specify check >/dev/null 2>&1; then
            pass "specify check passed"
        else
            note_warn "specify check reported issues; C4 bootstrap may be degraded"
        fi
    fi
    echo ""

    echo "Account and auth state:"
    local account provider
    account=$(get_current)
    provider=$(get_provider "$account")
    pass "current selector: ${account} (${provider})"

    if is_third_party "$provider"; then
        if claude-token --check "$account" >/dev/null 2>&1; then
            pass "API key available for ${account}"
        else
            note_warn "API key missing for ${account}"
        fi
    else
        note_warn "${provider} uses native OAuth/session auth"
    fi

    echo ""
    echo -e "Summary: ${GREEN}${ok} ok${NC}, ${YELLOW}${warn} warning${NC}, ${RED}${fail} failed${NC}"
    [[ $fail -eq 0 ]]
}

# Show help
show_help() {
    cat << 'EOF'
Claude CLI Account Manager

Usage:
  claude-manage                               Interactive menu
  claude-manage switch [account]              Switch default account
  claude-manage create-account [account]      Create account (optionally with API key)
  claude-manage update-account [account]      Update account (optionally rotate API key)
  claude-manage remove-account [account]      Remove account (optionally delete API key)
  claude-manage test [account]                Test connectivity
  claude-manage list [provider]               List accounts
  claude-manage doctor                        Run workflow diagnostics
  claude-manage current                       Show current account

Compatibility aliases:
  add-account -> create-account
  edit-account -> update-account

Legacy key-only commands (still supported):
  add-key | update-key | delete-key
EOF
}

# Main
main() {
    local cmd="${1:-}"
    shift || true

    case "$cmd" in
        help|--help|-h)
            show_help
            ;;
        "")
            require_cmd chezmoi jq fzf gopass || return 1
            run_cmd fzf_menu
            ;;
        switch|sw)
            require_cmd chezmoi jq || return 1
            run_cmd cmd_switch "$@"
            ;;
        create-account|add-account)
            require_cmd chezmoi jq yq fzf || return 1
            run_cmd cmd_create_account "$@"
            ;;
        update-account|edit-account)
            require_cmd chezmoi jq yq || return 1
            run_cmd cmd_update_account "$@"
            ;;
        remove-account)
            require_cmd chezmoi jq yq || return 1
            run_cmd cmd_remove_account "$@"
            ;;
        add-key|update-key|delete-key)
            require_cmd chezmoi jq gopass || return 1
            case "$cmd" in
                add-key) run_cmd cmd_add_key "$@" ;;
                update-key) run_cmd cmd_update_key "$@" ;;
                delete-key) run_cmd cmd_delete_key "$@" ;;
            esac
            ;;
        test)
            require_cmd chezmoi jq gopass curl || return 1
            run_cmd cmd_test "$@"
            ;;
        list|ls)
            require_cmd chezmoi jq gopass || return 1
            run_cmd cmd_list "$@"
            ;;
        doctor)
            require_cmd chezmoi jq || return 1
            run_cmd cmd_doctor "$@"
            ;;
        current)
            require_cmd chezmoi jq || return 1
            cmd_current
            ;;
        *)
            log_error "Unknown: $cmd"
            show_help
            return 1
            ;;
    esac
}

main "$@"
