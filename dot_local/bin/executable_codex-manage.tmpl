#!/usr/bin/env bash
# Codex CLI Account Manager
# Manage accounts and API keys with fzf interface
#
# Usage:
#   codex-manage                   # Interactive menu
#   codex-manage switch [account]         Switch default account
#   codex-manage create-account [account] Create account (optionally with API key)
#   codex-manage update-account [account] Update account (optionally rotate API key)
#   codex-manage remove-account [account] Remove account (optionally delete API key)
#   codex-manage test [account]           Test connectivity
#   codex-manage list [provider]          List accounts
#   codex-manage doctor                   Run workflow diagnostics

set -euo pipefail

# shellcheck source=lib/ai/codex.tmpl
# shellcheck disable=SC1091
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
source "$SCRIPT_DIR/lib/ai/codex"

# Return codes
: "${RC_BACK:=10}"
: "${RC_EXIT:=130}"

# Set Codex account in chezmoi.toml
set_chezmoi_account() {
    local account="$1"
    local escaped_account
    escaped_account=$(escape_toml_string "$account")
    local tmp_file
    tmp_file=$(mktemp) || { log_error "Failed to create temp file"; return 1; }

    if grep -q "^codexProviderAccount = " "$CHEZMOI_CONFIG"; then
        sed "s/^codexProviderAccount = .*/codexProviderAccount = \"$escaped_account\"/" "$CHEZMOI_CONFIG" > "$tmp_file"
    elif grep -q "^claudeProviderAccount = " "$CHEZMOI_CONFIG"; then
        awk -v line="codexProviderAccount = \"$escaped_account\"" '
            BEGIN { inserted = 0 }
            { print }
            /^claudeProviderAccount = / && inserted == 0 { print line; inserted = 1 }
            END { if (inserted == 0) print line }
        ' "$CHEZMOI_CONFIG" > "$tmp_file"
    elif grep -q "^\[data\]" "$CHEZMOI_CONFIG"; then
        awk -v line="codexProviderAccount = \"$escaped_account\"" '
            BEGIN { inserted = 0; in_data = 0 }
            /^\[data\]$/ { in_data = 1; print; next }
            /^\[/ {
                if (in_data == 1 && inserted == 0) {
                    print line
                    inserted = 1
                }
                in_data = 0
                print
                next
            }
            { print }
            END {
                if (in_data == 1 && inserted == 0) {
                    print line
                }
            }
        ' "$CHEZMOI_CONFIG" > "$tmp_file"
    else
        cp "$CHEZMOI_CONFIG" "$tmp_file"
        {
            echo ""
            echo "[data]"
            echo "codexProviderAccount = \"$escaped_account\""
        } >> "$tmp_file"
    fi
    mv "$tmp_file" "$CHEZMOI_CONFIG"
}
# FZF interactive menu
fzf_menu() {
    while true; do
        local current
        current=$(get_current)

        local selected
        # shellcheck disable=SC2016
        if ! selected=$({
            cat <<'MENU'
switch         Change default account
create-account Create account (and optional API key)
update-account Update account (and optional API key)
remove-account Remove account (and optional API key)
test           Test connectivity
list           Show all accounts
doctor         Run workflow diagnostics
MENU
            echo -e "${YELLOW}quit${NC}           Exit to shell"
        } | fzf --ansi \
            --height=50% \
            --border=rounded \
            --header="Codex Account Manager" \
            --preview='
                cmd=$(echo {} | awk "{print \$1}")
                echo -e "\033[1;34m━━━ $cmd ━━━\033[0m"
                echo ""
                case "$cmd" in
                    switch)         echo "Switch the default account." ;;
                    create-account) echo "Create account (and optional API key)." ;;
                    update-account) echo "Update account (and optional API key)." ;;
                    remove-account) echo "Remove account (and optional API key)." ;;
                    test)           echo "Test API connectivity." ;;
                    list)           echo "Show all accounts." ;;
                    doctor)         echo "Run workflow diagnostics." ;;
                    quit)           echo "Exit to shell." ;;
                esac
                echo ""
                echo -e "\033[1;34m━━━ Accounts ━━━\033[0m"
                echo ""
                codex-manage list 2>/dev/null | tail -n +3
            ' \
            --preview-window='right:50%:wrap' \
            --preview-label="[ Current: $current ]"
        ); then
            return "$RC_EXIT"
        fi

        local cmd
        selected=$(normalize_menu_selection "$selected")
        cmd=$(echo "$selected" | awk '{print $1}')

        local rc=0
        case "$cmd" in
            switch)         cmd_switch || rc=$? ;;
            create-account) cmd_create_account || rc=$? ;;
            update-account) cmd_update_account || rc=$? ;;
            remove-account) cmd_remove_account || rc=$? ;;
            test)           cmd_test || rc=$? ;;
            list)           cmd_list || rc=$? ;;
            doctor)         cmd_doctor || rc=$? ;;
            quit)           return 0 ;;
            *)              log_error "Unknown command: $cmd"; return 1 ;;
        esac

        case "$rc" in
            0) return 0 ;;
            "$RC_BACK") continue ;;
            "$RC_EXIT") return "$RC_EXIT" ;;
            *)
                log_error "Command '$cmd' failed (exit $rc)"
                return "$rc"
                ;;
        esac
    done
}

# Switch account
cmd_switch() {
    local input="${1:-}"
    if [[ -z "$input" ]]; then
        if input=$(fzf_pick_account "Switch Account"); then
            :
        else
            local rc=$?
            if [[ $rc -eq $RC_BACK || $rc -eq $RC_EXIT ]]; then
                return "$rc"
            fi
            return 1
        fi
    fi

    if ! is_runtime_account "$input"; then
        log_error "Unknown account '$input'"
        return 1
    fi

    local provider
    provider=$(get_provider "$input")

    if is_third_party "$provider"; then
        if require_cmd gopass >/dev/null 2>&1; then
            if ! codex-token --check "$input" 2>/dev/null; then
                log_warn "No API token for $input (continuing without auth update)"
            fi
        else
            log_warn "gopass not found (continuing without auth update)"
        fi
    fi

    [[ "$(get_current)" == "$input" ]] && { log_warn "Already using '$input'"; return 0; }
    set_chezmoi_account "$input"
    echo "  ✓ Updated chezmoi.toml"
    log_info "Applying chezmoi templates..."
    chezmoi apply --verbose --exclude scripts "$CODEX_CONFIG" "$SCRIPT_DIR/lib/ai/core"
    echo "  ✓ Updated ~/.codex/config.toml"
    if is_third_party "$provider"; then
        if require_cmd gopass >/dev/null 2>&1 && codex-token --check "$input" 2>/dev/null; then
            backup_codex_auth_openai || return 1
            local parsed acct_name
            parsed=$(parse_provider_account "$input")
            acct_name="${parsed#*|}"
            local api_key
            api_key=$(get_api_key "$provider" "$acct_name") || {
                log_warn "Failed to retrieve API key (skipping auth.json update)"
                api_key=""
            }
            if [[ -n "$api_key" ]]; then
                write_codex_auth_key "$api_key" || return 1
                echo "  ✓ Updated ~/.codex/auth.json (OPENAI_API_KEY)"
            fi
        else
            log_warn "Skipping auth.json update for $input"
        fi
    else
        restore_codex_auth_openai || return 1
        if [[ -f "$CODEX_AUTH" ]]; then
            echo "  ✓ Restored ~/.codex/auth.json"
        else
            echo "  ✓ Removed ~/.codex/auth.json (re-login required)"
        fi
    fi
    echo ""
    log_success "Account set to $input"
    log_warn "Restart Codex to apply changes"
}

# Create account
cmd_create_account() {
    require_cmd gopass || return 1

    local provider
    if ! provider=$({
        printf '%s\n' "${PROVIDERS[@]}"
        echo -e "${YELLOW}Back${NC}"
    } | fzf --ansi --height=40% --border=rounded --header="Select Provider"); then
        return "$RC_EXIT"
    fi
    provider=$(normalize_menu_selection "$provider")
    [[ -z "$provider" ]] && return "$RC_EXIT"
    is_back_selection "$provider" && return "$RC_BACK"

    local account_label full_name
    if [[ "$provider" == "openai" ]]; then
        account_label="openai"
        full_name="openai"
    else
        printf 'Account label (default: private): '
        read -r account_label
        [[ -z "$account_label" ]] && account_label="private"
        validate_account_name "$account_label" || { log_error "Invalid label"; return 1; }
        full_name="${provider}@${account_label}"
    fi

    if [[ "$provider" == "openai" ]]; then
        set_chezmoi_account "$full_name"
        chezmoi apply --verbose --exclude scripts "$CODEX_CONFIG" "$SCRIPT_DIR/lib/ai/core"
        log_success "Account created and switched: $full_name (OAuth)"
        return 0
    fi

    local parsed acct_name
    parsed=$(parse_provider_account "$full_name")
    acct_name="${parsed#*|}"

    printf "API Key (optional): "
    read -rs api_key
    echo ""
    if [[ -n "$api_key" ]]; then
        store_api_key "$provider" "$acct_name" "$api_key"
        log_success "API key saved"
    else
        log_info "Skipped API key"
    fi

    set_chezmoi_account "$full_name"
    chezmoi apply --verbose --exclude scripts "$CODEX_CONFIG" "$SCRIPT_DIR/lib/ai/core"
    log_success "Account created and switched: $full_name"
}

# Update account
cmd_update_account() {
    local input="${1:-}"
    if [[ -z "$input" ]]; then
        if input=$(fzf_pick_account "Update Account"); then
            :
        else
            local rc=$?
            if [[ $rc -eq $RC_BACK || $rc -eq $RC_EXIT ]]; then
                return "$rc"
            fi
            return 1
        fi
    fi

    is_runtime_account "$input" || { log_error "Unknown account '$input'"; return 1; }

    local provider parsed acct_name
    provider=$(get_provider "$input")

    set_chezmoi_account "$input"
    chezmoi apply --verbose --exclude scripts "$CODEX_CONFIG" "$SCRIPT_DIR/lib/ai/core"
    log_success "Switched to $input"

    if [[ "$provider" == "openai" ]]; then
        log_info "openai uses OAuth, no API key update"
        return 0
    fi

    parsed=$(parse_provider_account "$input")
    acct_name="${parsed#*|}"

    printf "Update API key now? [y/N]: "
    read -r yes
    if [[ "$yes" == "y" || "$yes" == "Y" ]]; then
        printf "New API Key: "
        read -rs api_key
        echo ""
        [[ -z "$api_key" ]] && { log_error "API key required"; return 1; }
        store_api_key "$provider" "$acct_name" "$api_key"
        log_success "API key updated"
    fi
}

# Remove account
cmd_remove_account() {
    local input="${1:-}"
    if [[ -z "$input" ]]; then
        if input=$(fzf_pick_account "Remove Account"); then
            :
        else
            local rc=$?
            if [[ $rc -eq $RC_BACK || $rc -eq $RC_EXIT ]]; then
                return "$rc"
            fi
            return 1
        fi
    fi

    is_runtime_account "$input" || { log_error "Unknown account '$input'"; return 1; }

    local current
    current=$(get_current)
    if [[ "$input" == "$current" ]]; then
        log_error "Cannot remove current account. Switch first."
        return 1
    fi

    local provider parsed acct_name
    provider=$(get_provider "$input")
    parsed=$(parse_provider_account "$input")
    acct_name="${parsed#*|}"

    printf 'Also delete API key for %s? [y/N]: ' "$input"
    read -r del_key
    if [[ "$del_key" == "y" || "$del_key" == "Y" ]]; then
        if key_exists "$provider" "$acct_name"; then
            delete_api_key "$provider" "$acct_name"
            log_success "API key deleted"
        else
            log_info "No API key found"
        fi
    fi

    log_warn "Account profile is template-managed; to fully remove, update dot_codex/config.toml.tmpl"
}

# Add API key
cmd_add_key() {
    require_cmd gopass || return 1
    local input="${1:-}"

    if [[ -z "$input" ]]; then
        require_cmd fzf || return 1
        local needs_key=()
        for acct in "${ACCOUNTS[@]}"; do
            local prov
            prov=$(get_provider "$acct")
            if is_third_party "$prov"; then
                local parsed acct_name
                parsed=$(parse_provider_account "$acct")
                acct_name="${parsed#*|}"
                key_exists "$prov" "$acct_name" || needs_key+=("$acct")
            fi
        done

        [[ ${#needs_key[@]} -eq 0 ]] && {
            log_warn "All accounts already have API keys"
            return 0
        }

        if ! input=$({
            printf '%s\n' "${needs_key[@]}"
            echo -e "${YELLOW}Back${NC}"
        } | fzf --ansi --height=40% --border=rounded --header='Add API Key'); then
            return "$RC_EXIT"
        fi
        input=$(normalize_menu_selection "$input")
        [[ -z "$input" ]] && return "$RC_EXIT"
        is_back_selection "$input" && return "$RC_BACK"
    fi

    local provider
    provider=$(get_provider "$input")
    local parsed acct_name
    parsed=$(parse_provider_account "$input")
    acct_name="${parsed#*|}"

    is_third_party "$provider" || { log_warn "Native provider, no key needed"; return 0; }
    key_exists "$provider" "$acct_name" && { log_error "Key already exists. Use update-key."; return 1; }

    log_info "Adding API key for $input"
    printf "API Key: "
    read -rs api_key
    echo ""
    [[ -z "$api_key" ]] && { log_error "API key required"; return 1; }

    store_api_key "$provider" "$acct_name" "$api_key"
    log_success "API key saved"
    log_info "Tip: run 'codex-manage test $input' to verify"
}

# Update API key
cmd_update_key() {
    require_cmd gopass || return 1
    local input="${1:-}"

    if [[ -z "$input" ]]; then
        require_cmd fzf || return 1
        local existing
        existing=$(build_accounts_with_keys)
        [[ -z "$existing" ]] && { log_warn "No API keys to update"; return 0; }

        if ! input=$({
            echo "$existing"
            echo -e "${YELLOW}Back${NC}"
        } | fzf --ansi --height=40% --border=rounded --header='Update API Key'); then
            return "$RC_EXIT"
        fi
        input=$(normalize_menu_selection "$input")
        [[ -z "$input" ]] && return "$RC_EXIT"
        is_back_selection "$input" && return "$RC_BACK"
    fi

    local provider
    provider=$(get_provider "$input")
    local parsed acct_name
    parsed=$(parse_provider_account "$input")
    acct_name="${parsed#*|}"

    is_third_party "$provider" || { log_warn "Native provider, no key needed"; return 0; }
    key_exists "$provider" "$acct_name" || { log_error "No key exists. Use update-account."; return 1; }

    log_info "Updating API key for $input"
    printf "New API Key: "
    read -rs api_key
    echo ""
    [[ -z "$api_key" ]] && { log_error "API key required"; return 1; }

    store_api_key "$provider" "$acct_name" "$api_key"
    log_success "API key updated"
}

# Delete API key
cmd_delete_key() {
    require_cmd gopass || return 1
    local input="${1:-}"

    if [[ -z "$input" ]]; then
        require_cmd fzf || return 1
        local existing
        existing=$(build_accounts_with_keys)
        [[ -z "$existing" ]] && { log_warn "No API keys to delete"; return 0; }

        if ! input=$({
            echo "$existing"
            echo -e "${YELLOW}Back${NC}"
        } | fzf --ansi --height=40% --border=rounded --header='Delete API Key'); then
            return "$RC_EXIT"
        fi
        input=$(normalize_menu_selection "$input")
        [[ -z "$input" ]] && return "$RC_EXIT"
        is_back_selection "$input" && return "$RC_BACK"
    fi

    local provider
    provider=$(get_provider "$input")
    local parsed acct_name
    parsed=$(parse_provider_account "$input")
    acct_name="${parsed#*|}"

    key_exists "$provider" "$acct_name" || { log_error "No key exists"; return 1; }

    log_warn "Delete API key for $input?"
    printf "Continue? [y/N]: "
    read -r confirm
    [[ "$confirm" == "y" || "$confirm" == "Y" ]] && {
        delete_api_key "$provider" "$acct_name"
        log_success "API key deleted"
    } || echo "Cancelled"
}

# Test connectivity
cmd_test() {
    local input="${1:-}"
    if [[ -z "$input" ]]; then
        if input=$(fzf_pick_account "Test Connectivity"); then
            :
        else
            local rc=$?
            if [[ $rc -eq $RC_BACK || $rc -eq $RC_EXIT ]]; then
                return "$rc"
            fi
            return 1
        fi
    fi

    is_runtime_account "$input" || { log_error "Unknown account '$input'"; return 1; }

    local provider config base_url
    provider=$(get_provider "$input")
    config=$(codex-token --config "$input")
    base_url=$(echo "$config" | jq -r '.base_url // empty')
    base_url=${base_url%/v1}
    base_url=${base_url%/v1/}
    base_url=${base_url%/}

    if [[ -z "$base_url" ]]; then
        log_warn "Native OpenAI provider"
        log_success "Use 'codex' to authenticate via OAuth"
        return 0
    fi

    require_cmd curl || return 1

    log_info "Testing $input..."
    echo "  Base URL: $base_url"

    local parsed acct_name
    parsed=$(parse_provider_account "$input")
    acct_name="${parsed#*|}"

    key_exists "$provider" "$acct_name" || {
        log_fail "No API key"
        return 1
    }
    log_success "Key found"

    local token
    token=$(get_api_key "$provider" "$acct_name") || { log_fail "Failed to decrypt"; return 1; }

    echo "  Testing API..."

    local model wire_api response http_code
    model=$(echo "$config" | jq -r '.model // "unknown"')
    wire_api=$(echo "$config" | jq -r '.wire_api // "responses"')

    local header_file
    header_file=$(mktemp) || { log_fail "Failed to create header temp file"; return 1; }
    if ! chmod 600 "$header_file"; then
        log_fail "Failed to secure header temp file"
        rm -f "$header_file"
        return 1
    fi
    if ! cat > "$header_file" <<EOF
Authorization: Bearer $token
Content-Type: application/json
EOF
    then
        log_fail "Failed to write header file"
        rm -f "$header_file"
        return 1
    fi

    # Prefer /v1/models to validate auth/connectivity without model execution.
    local models_response models_code
    models_response=$(curl -sS -w "\n%{http_code}" --max-time 30 \
        -X GET "$base_url/v1/models" \
        -H @"$header_file" 2>&1 || true)
    models_code=$(echo "$models_response" | tail -n1)

    case "$models_code" in
        200)
            rm -f "$header_file"
            log_success "API OK (/v1/models)"
            echo ""
            log_success "Account $input is configured"
            return 0
            ;;
        401|403)
            rm -f "$header_file"
            log_fail "Invalid API key"
            return 1
            ;;
        429)
            rm -f "$header_file"
            log_warn "Rate limited on /v1/models"
            echo ""
            log_success "Account $input is configured"
            return 0
            ;;
        404|405)
            log_warn "/v1/models not supported; probing inference endpoint"
            ;;
        *)
            if [[ -z "$models_code" || "$models_code" == "000" ]]; then
                rm -f "$header_file"
                log_fail "Network error"
                return 1
            fi
            log_warn "/v1/models returned HTTP $models_code; probing inference endpoint"
            ;;
    esac

    local endpoint payload
    case "$wire_api" in
        chat_completions|chat)
            endpoint="/v1/chat/completions"
            payload="{\"model\":\"$model\",\"messages\":[{\"role\":\"user\",\"content\":\"ping\"}],\"max_tokens\":1}"
            ;;
        *)
            endpoint="/v1/responses"
            payload="{\"model\":\"$model\",\"input\":\"ping\"}"
            ;;
    esac

    response=$(curl -sS -w "\n%{http_code}" --max-time 30 \
        -X POST "$base_url$endpoint" \
        -H @"$header_file" \
        -d "$payload" 2>&1 || true)

    rm -f "$header_file"

    http_code=$(echo "$response" | tail -n1)

    case "$http_code" in
        200) log_success "API OK" ;;
        401|403) log_fail "Invalid API key"; return 1 ;;
        429) log_warn "Rate limited"; http_code=200 ;;
        *)
            if [[ -z "$http_code" || "$http_code" == "000" ]]; then
                log_fail "Network error"
                return 1
            fi
            log_warn "HTTP $http_code" ;;
    esac

    if [[ "$http_code" != "200" ]]; then
        return 1
    fi

    echo ""
    log_success "Account $input is configured"
}

# Build Codex list accounts: native + third-party accounts present in gopass.
list_codex_accounts() {
    list_runtime_accounts
}

# List accounts
cmd_list() {
    local filter="${1:-}"
    log_info "Configured accounts:"
    echo ""

    local account
    while IFS= read -r account; do
        [[ -z "$account" ]] && continue
        local provider
        provider=$(get_provider "$account")

        [[ -n "$filter" && "$provider" != "$filter" ]] && continue

        if is_third_party "$provider"; then
            local parsed acct_name
            parsed=$(parse_provider_account "$account")
            acct_name="${parsed#*|}"
            if key_exists "$provider" "$acct_name"; then
                echo -e "  ${GREEN}${STATUS_OK}${NC} $account"
            fi
        else
            echo -e "  ${GREEN}${STATUS_NATIVE}${NC} $account (native)"
        fi
    done < <(list_codex_accounts)
}

# Show current
cmd_current() {
    local account provider
    account=$(get_current)
    provider=$(get_provider "$account")
    echo -e "Current: ${GREEN}${account}${NC} (${provider})"
}

# Run workflow diagnostics
cmd_doctor() {
    local ok=0
    local warn=0
    local fail=0

    pass() {
        echo -e "  ${GREEN}${STATUS_OK}${NC} $1"
        ok=$((ok + 1))
    }

    note_warn() {
        echo -e "  ${YELLOW}${STATUS_WARN}${NC} $1"
        warn=$((warn + 1))
    }

    note_fail() {
        echo -e "  ${RED}${STATUS_ERROR}${NC} $1"
        fail=$((fail + 1))
    }

    log_header "Codex Workflow Doctor"

    echo "Runtime commands:"
    if command -v codex >/dev/null 2>&1; then pass "codex found"; else note_fail "codex not found"; fi
    if command -v openspec >/dev/null 2>&1; then pass "openspec found"; else note_warn "openspec not found (C3/L3 OpenSpec gate unavailable)"; fi
    if command -v specify >/dev/null 2>&1; then pass "specify found"; else note_warn "specify not found (C4 Spec-Kit bootstrap unavailable)"; fi
    if command -v jq >/dev/null 2>&1; then pass "jq found"; else note_fail "jq not found"; fi
    if command -v chezmoi >/dev/null 2>&1; then pass "chezmoi found"; else note_fail "chezmoi not found"; fi
    if require_cmd gopass >/dev/null 2>&1; then pass "gopass found"; else note_warn "gopass missing (third-party keys unavailable)"; fi
    echo ""

    echo "Rendered configs:"
    if [[ -f "$CODEX_CONFIG" ]]; then
        pass "~/.codex/config.toml present"
        local model_provider
        model_provider=$(toml_get_model_provider "$CODEX_CONFIG")
        if [[ -n "$model_provider" ]]; then
            pass "model_provider resolved (${model_provider})"
        else
            note_warn "model_provider missing in ~/.codex/config.toml"
        fi
    else
        note_fail "~/.codex/config.toml missing"
    fi

    local user_agents
    user_agents="${HOME}/.codex/AGENTS.md"
    if [[ -f "$user_agents" ]]; then
        pass "~/.codex/AGENTS.md present"
    else
        note_warn "~/.codex/AGENTS.md missing"
    fi
    echo ""

    echo "Commands and skills projection:"
    local prompt_count
    prompt_count=$(find "${HOME}/.codex/prompts" -maxdepth 1 -name 'core-*.md' 2>/dev/null | wc -l | tr -d ' ')
    if [[ "${prompt_count:-0}" -ge 7 ]]; then
        pass "core prompt links present (${prompt_count})"
    else
        note_warn "core prompt links incomplete (${prompt_count:-0})"
    fi

    local opsx_count
    opsx_count=$(find "${HOME}/.codex/prompts" -maxdepth 1 -name 'opsx-*.md' 2>/dev/null | wc -l | tr -d ' ')
    if [[ "${opsx_count:-0}" -ge 5 ]]; then
        pass "opsx wrapper prompts present (${opsx_count})"
    else
        note_warn "opsx wrapper prompts incomplete (${opsx_count:-0}); native openspec CLI still works. run: openspec update"
    fi

    if [[ -L "${HOME}/.codex/skills" ]]; then
        pass "~/.codex/skills symlink exists"
    else
        note_warn "~/.codex/skills symlink missing"
    fi

    if command -v specify >/dev/null 2>&1; then
        if specify check >/dev/null 2>&1; then
            pass "specify check passed"
        else
            note_warn "specify check reported issues; C4 bootstrap may be degraded"
        fi
    fi

    if [[ -d "$PWD/.codex" ]]; then
        note_warn "if project prompt discovery is missing, set: export CODEX_HOME=\"$PWD/.codex\""
    fi
    echo ""

    echo "Account and auth state:"
    local account provider
    account=$(get_current)
    provider=$(get_provider "$account")
    pass "current selector: ${account} (${provider})"

    if is_third_party "$provider"; then
        if codex-token --check "$account" >/dev/null 2>&1; then
            pass "API key available for ${account}"
        else
            note_warn "API key missing for ${account}"
        fi
    else
        note_warn "${provider} uses native auth; run: codex login"
    fi

    echo ""
    echo -e "Summary: ${GREEN}${ok} ok${NC}, ${YELLOW}${warn} warning${NC}, ${RED}${fail} failed${NC}"
    [[ $fail -eq 0 ]]
}

# Show help
show_help() {
    cat << 'EOF'
Codex CLI Account Manager

Usage:
  codex-manage                               Interactive menu
  codex-manage switch [account]              Switch default account
  codex-manage create-account [account]      Create account (optionally with API key)
  codex-manage update-account [account]      Update account (optionally rotate API key)
  codex-manage remove-account [account]      Remove account (optionally delete API key)
  codex-manage test [account]                Test connectivity
  codex-manage list [provider]               List accounts
  codex-manage doctor                        Run workflow diagnostics
  codex-manage current                       Show current account

Compatibility aliases:
  add-account -> create-account
  edit-account -> update-account

Legacy key-only commands (still supported):
  add-key | update-key | delete-key
EOF
}

# Main
main() {
    local cmd="${1:-}"
    shift || true

    case "$cmd" in
        help|--help|-h)
            show_help
            ;;
        "")
            require_cmd chezmoi jq fzf gopass || return 1
            run_cmd fzf_menu
            ;;
        switch|sw)
            require_cmd chezmoi jq || return 1
            run_cmd cmd_switch "$@"
            ;;
        create-account|add-account)
            require_cmd chezmoi jq gopass fzf || return 1
            run_cmd cmd_create_account "$@"
            ;;
        update-account|edit-account)
            if [[ $# -eq 0 ]]; then
                require_cmd chezmoi jq gopass fzf || return 1
            else
                require_cmd chezmoi jq gopass || return 1
            fi
            run_cmd cmd_update_account "$@"
            ;;
        remove-account)
            if [[ $# -eq 0 ]]; then
                require_cmd chezmoi jq gopass fzf || return 1
            else
                require_cmd chezmoi jq gopass || return 1
            fi
            run_cmd cmd_remove_account "$@"
            ;;
        add-key|update-key|delete-key)
            if [[ $# -eq 0 ]]; then
                require_cmd chezmoi jq gopass fzf || return 1
            else
                require_cmd chezmoi jq gopass || return 1
            fi
            case "$cmd" in
                add-key) run_cmd cmd_add_key "$@" ;;
                update-key) run_cmd cmd_update_key "$@" ;;
                delete-key) run_cmd cmd_delete_key "$@" ;;
            esac
            ;;
        test)
            require_cmd chezmoi jq gopass curl || return 1
            run_cmd cmd_test "$@"
            ;;
        list|ls)
            require_cmd chezmoi jq gopass || return 1
            run_cmd cmd_list "$@"
            ;;
        doctor)
            require_cmd chezmoi jq || return 1
            run_cmd cmd_doctor "$@"
            ;;
        current)
            require_cmd chezmoi jq || return 1
            cmd_current
            ;;
        *)
            log_error "Unknown: $cmd"
            show_help
            return 1
            ;;
    esac
}

main "$@"
