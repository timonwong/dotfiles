[delta]
    navigate = true
    line-numbers = true
    side-by-side = false
    dark = true
    syntax-theme = none

    # Keep diff UI on Catppuccin Mocha colors without relying on delta syntax themes.
    commit-style = raw
    file-style = "bold #CDD6F4"
    file-decoration-style = "#6C7086 ul"
    hunk-header-style = "file line-number syntax"
    hunk-header-file-style = "bold #CDD6F4"
    hunk-header-line-number-style = "bold #A6ADC8"
    hunk-header-decoration-style = "#6C7086 box"

    # Low-glare add/remove backgrounds based on the Catppuccin delta port.
    plus-style = "syntax #394545"
    plus-emph-style = "syntax bold #4E6356"
    minus-style = "syntax #493447"
    minus-emph-style = "syntax bold #694559"

    # Keep line numbers informative without overpowering content.
    line-numbers-left-style = "#6C7086"
    line-numbers-right-style = "#6C7086"
    line-numbers-plus-style = "bold #A6E3A1"
    line-numbers-minus-style = "bold #F38BA8"
    line-numbers-zero-style = "#6C7086"
    line-numbers-left-format = "{nm:>4}│"
    line-numbers-right-format = "{np:>4}│"
