# Locale (prefer UTF-8, avoid forcing LC_ALL globally)
if command -v locale >/dev/null 2>&1; then
    if locale -a 2>/dev/null | grep -Eqi '^en_US\.UTF-8$|^en_US\.utf8$'; then
        export LANG="${LANG:-en_US.UTF-8}"
        export LC_CTYPE="${LC_CTYPE:-en_US.UTF-8}"
    elif locale -a 2>/dev/null | grep -Eqi '^C\.UTF-8$|^C\.utf8$'; then
        export LANG="${LANG:-C.UTF-8}"
        export LC_CTYPE="${LC_CTYPE:-C.UTF-8}"
    fi
fi

# bat theme (fzf config is in ~/.custom/exports.sh)
export BAT_THEME="Catppuccin Mocha"

