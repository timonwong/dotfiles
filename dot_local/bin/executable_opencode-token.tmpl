#!/usr/bin/env bash
# OpenCode API Key Helper
# Retrieve API keys from gopass for OpenCode wrappers
#
# Usage:
#   opencode-token [account]            # Output API key for account
#   opencode-token --check [account]    # Check if key exists (exit code only)
#   opencode-token --config [account]   # Output account config as JSON

set -euo pipefail

# shellcheck source=lib/ai/opencode.tmpl
# shellcheck disable=SC1091
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
source "$SCRIPT_DIR/lib/ai/opencode"

provider_env_fallback() {
    local provider="$1"
    local env_var
    env_var="$(printf '%s' "$provider" | tr '[:lower:]' '[:upper:]' | tr -c 'A-Z0-9_' '_')_API_KEY"
    if [[ "$env_var" =~ ^[0-9] ]]; then
        env_var="P_${env_var}"
    fi
    printf '%s' "$env_var"
}

# Parse arguments
CHECK_ONLY=false
CONFIG_ONLY=false
ACCOUNT=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        --check)
            CHECK_ONLY=true
            shift
            ;;
        --config)
            CONFIG_ONLY=true
            shift
            ;;
        --help|-h)
            cat << 'EOF'
OpenCode API Key Helper

Usage:
  opencode-token [account]            Output API key for account
  opencode-token --check [account]    Check if key exists (exit code only)
  opencode-token --config [account]   Output account config as JSON

Examples:
  opencode-token deepseek@private
  opencode-token --check qwen@work
  opencode-token --config openai
EOF
            exit 0
            ;;
        *)
            ACCOUNT="$1"
            shift
            ;;
    esac
done

# Default to current account if not specified
if [[ -z "$ACCOUNT" ]]; then
    ACCOUNT=$(get_current)
fi

# Get provider and account name
PROVIDER=$(get_provider "$ACCOUNT")
PARSED=$(parse_provider_account "$ACCOUNT")
ACCT_NAME="${PARSED#*|}"

# Validate names to prevent path traversal
if ! validate_provider_name "$PROVIDER"; then
    log_error "Invalid provider name '$PROVIDER'"
    exit 1
fi
if ! validate_account_name "$ACCT_NAME"; then
    log_error "Invalid account name '$ACCT_NAME'"
    exit 1
fi

# Config mode: output account configuration from rendered ~/.config/opencode/opencode.jsonc
if $CONFIG_ONLY; then
    local_model=""
    model_ref=""
    base_url=""
    env_var=""
    config_file="$(opencode_config_file)"

    local_model=$(get_provider_default_model "$PROVIDER")
    [[ -z "$local_model" ]] && local_model=$(opencode_default_model_for_provider "$PROVIDER")
    model_ref="${PROVIDER}/${local_model}"

    if [[ -f "$config_file" ]] && command -v jq >/dev/null 2>&1; then
        base_url=$(jq -r --arg provider "$PROVIDER" '.provider[$provider].options.baseURL // empty' "$config_file" 2>/dev/null)
        env_var=$(jq -r --arg provider "$PROVIDER" '.provider[$provider].env[0] // empty' "$config_file" 2>/dev/null)
    fi

    if [[ -z "$env_var" ]]; then
        env_var=$(provider_env_fallback "$PROVIDER")
    fi

    if [[ -n "$base_url" ]]; then
        printf '{"provider":"%s","model":"%s","model_ref":"%s","base_url":"%s","env_var":"%s"}\n' \
            "$PROVIDER" "$local_model" "$model_ref" "$base_url" "$env_var"
    else
        printf '{"provider":"%s","model":"%s","model_ref":"%s"}\n' \
            "$PROVIDER" "$local_model" "$model_ref"
    fi
    exit 0
fi

# Check if this is a third-party provider that needs an API key
if ! is_third_party "$PROVIDER"; then
    if $CHECK_ONLY; then
        exit 0  # Native providers don't need keys
    fi
    echo ""  # No key needed
    exit 0
fi

# Check mode: just verify key exists
if $CHECK_ONLY; then
    if key_exists "$PROVIDER" "$ACCT_NAME"; then
        exit 0
    else
        exit 1
    fi
fi

# Get and output the API key
KEY=$(get_api_key "$PROVIDER" "$ACCT_NAME") || {
    log_error "Failed to retrieve API key for $ACCOUNT" >&2
    exit 1
}

echo "$KEY"
