#!/usr/bin/env bash
# Codex CLI Launcher
# Launch codex with any account via environment variable injection
#
# Usage:
#   codex-with                    # fzf interactive picker
#   codex-with <account> [args]   # Launch with account + codex args
#   codex-with -h                 # Show help

set -euo pipefail

# shellcheck source=lib/ai/codex.tmpl
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
source "$SCRIPT_DIR/lib/ai/codex"

# FZF picker with shortcuts
fzf_select() {
    local selected
    selected=$(build_account_list_with_token | fzf --ansi \
        --height=50% \
        --border=rounded \
        --header="Launch Codex" \
        --preview="$ACCOUNT_PREVIEW"'
            echo ""
            echo -e "\033[1;34m━━━ Shortcuts ━━━\033[0m"
            echo ""
            echo "  Enter     Launch"
        ' \
        --preview-window='right:50%:wrap' \
        --preview-label="[ Select and press Enter ]" \
        --bind='enter:accept' \
        --print-query) || true

    [[ -z "$selected" ]] && return 1

    # Parse output: first line is query (args), second is selection
    local query selection
    query=$(echo "$selected" | head -1)
    selection=$(echo "$selected" | tail -1)

    [[ -z "$selection" ]] && return 1

    # Extract account name
    local account
    account="${selection#* }"

    if [[ -n "$query" ]]; then
        echo "$account|$query"
    else
        echo "$account|"
    fi
}

# Build codex config overrides
build_config_overrides() {
    local account="$1"
    local provider base_url model env_var

    # Get config from chezmoi data
    local config
    config=$(codex-token --config "$account")
    provider=$(echo "$config" | jq -r '.provider // empty')
    base_url=$(echo "$config" | jq -r '.base_url // empty')
    model=$(echo "$config" | jq -r '.model // empty')

    [[ -z "$provider" ]] && provider="$account"

    # Build -c overrides
    local overrides=()

    # Set model_provider
    overrides+=("-c" "model_provider=${provider}")

    # Set base_url if third-party
    if [[ -n "$base_url" ]]; then
        overrides+=("-c" "model_providers.${provider}.base_url=${base_url}")
        overrides+=("-c" "model_providers.${provider}.env_key=OPENAI_API_KEY")
    fi

    # Set model if specified
    if [[ -n "$model" ]]; then
        overrides+=("-c" "model=${model}")
    fi

    printf '%s\n' "${overrides[@]}"
}

# Launch codex with account
launch_codex() {
    local account="$1"
    shift

    if ! is_configured_account "$account"; then
        log_error "Unknown account '$account'"
        echo "Available accounts:" >&2
        printf '  %s\n' "${ACCOUNTS[@]}" >&2
        return 1
    fi

    local provider
    provider=$(get_provider "$account")

    if is_third_party "$provider"; then
        require_cmd gopass || return 1
    fi

    # Check if key exists for third-party providers
    if is_third_party "$provider"; then
        if ! codex-token --check "$account" 2>/dev/null; then
            log_error "No API token for $account"
            echo -e "Run: ${YELLOW}codex-manage add-key $account${NC}" >&2
            return 1
        fi
    fi

    # Get API key
    local api_key=""
    if is_third_party "$provider"; then
        local parsed acct_name
        parsed=$(parse_provider_account "$account")
        acct_name="${parsed#*|}"
        api_key=$(get_api_key "$provider" "$acct_name") || {
            log_error "Failed to retrieve API key"
            return 1
        }
    fi

    # Build config overrides
    local overrides=()
    while IFS= read -r line; do
        [[ -n "$line" ]] && overrides+=("$line")
    done < <(build_config_overrides "$account")

    # Status
    echo -e "${GREEN}Launching codex with ${CYAN}$account${NC}"
    local config
    config=$(codex-token --config "$account")
    echo -e "  Model: $(echo "$config" | jq -r '.model // "default"')"
    [[ -n "$api_key" ]] && echo -e "  Provider: $provider (third-party)"
    echo ""

    # Launch with environment and overrides
    if [[ -n "$api_key" ]]; then
        OPENAI_API_KEY="$api_key" exec codex "${overrides[@]}" "$@"
    else
        exec codex "${overrides[@]}" "$@"
    fi
}

# Show help
show_help() {
    cat << 'EOF'
Codex CLI Launcher

Usage:
  codex-with                    Interactive fzf picker
  codex-with <account> [args]   Launch with account + pass args to codex
  codex-with -h, --help         Show this help

Examples:
  codex-with                    # fzf picker
  codex-with openai             # Launch with openai account
  codex-with deepseek "hello"   # Launch and send prompt

EOF
}

# Main
main() {
    if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
        require_cmd codex || exit 1
        show_help
        exit 0
    fi

    require_cmd chezmoi jq codex codex-token || exit 1

    if [[ $# -eq 0 ]]; then
        require_cmd fzf || exit 1
        local result
        result=$(fzf_select) || exit 0
        local account="${result%%|*}"
        local args_str="${result#*|}"
        local -a args=()
        if [[ -n "$args_str" ]]; then
            while IFS= read -r line; do
                [[ -n "$line" ]] && args+=("$line")
            done < <(split_cli_args "$args_str")
        fi
        launch_codex "$account" "${args[@]}"
        exit 0
    fi

    local account="$1"
    shift
    launch_codex "$account" "$@"
}

main "$@"
