#!/bin/bash

set -euo pipefail

# Sync Claude Code MCP servers on every chezmoi apply.
# Fast path: only add when missing, avoid remove+add churn.

echo ":: [11] Syncing Claude Code MCP servers"

# Ensure common install locations are discoverable in non-interactive shells.
PATH="$HOME/.nix-profile/bin:/opt/homebrew/bin:$HOME/.local/share/aquaproj-aqua/bin:$PATH"
claude_cmd="$(command -v claude 2>/dev/null || true)"

if [[ -z "$claude_cmd" ]]; then
    echo "    Skipped (claude not found)"
    exit 0
fi

if ! command -v jq &>/dev/null; then
    echo "    Skipped (jq not found)"
    exit 0
fi

CLAUDE_JSON="$HOME/.claude.json"

check_user_mcp_json() {
    local name="$1"
    local expected_json="$2"

    if [[ ! -f "$CLAUDE_JSON" ]]; then
        echo "missing"
        return 0
    fi

    local server
    server="$(jq -e --arg n "$name" '.mcpServers[$n]' "$CLAUDE_JSON" 2>/dev/null)" || {
        echo "missing"
        return 0
    }

    local actual_cmp expected_cmp actual_type
    actual_cmp="$(jq -cS '{command, args: (.args // []), env: (.env // {})}' <<<"$server")"
    expected_cmp="$(jq -cS '{command, args: (.args // []), env: (.env // {})}' <<<"$expected_json")"
    actual_type="$(jq -r '.type // "stdio"' <<<"$server")"

    if [[ "$actual_type" == "stdio" && "$actual_cmp" == "$expected_cmp" ]]; then
        echo "match"
    else
        echo "mismatch"
    fi
}

check_user_mcp_sse() {
    local name="$1"
    local expected_url="$2"

    if [[ ! -f "$CLAUDE_JSON" ]]; then
        echo "missing"
        return 0
    fi

    local server
    server="$(jq -e --arg n "$name" '.mcpServers[$n]' "$CLAUDE_JSON" 2>/dev/null)" || {
        echo "missing"
        return 0
    }

    local actual_type actual_url
    actual_type="$(jq -r '.type // "stdio"' <<<"$server")"
    actual_url="$(jq -r '.url // empty' <<<"$server")"

    if [[ "$actual_type" == "sse" && "$actual_url" == "$expected_url" ]]; then
        echo "match"
    else
        echo "mismatch"
    fi
}

check_user_mcp_http() {
    local name="$1"
    local expected_url="$2"

    if [[ ! -f "$CLAUDE_JSON" ]]; then
        echo "missing"
        return 0
    fi

    local server
    server="$(jq -e --arg n "$name" '.mcpServers[$n]' "$CLAUDE_JSON" 2>/dev/null)" || {
        echo "missing"
        return 0
    }

    local actual_type actual_url
    actual_type="$(jq -r '.type // "stdio"' <<<"$server")"
    actual_url="$(jq -r '.url // empty' <<<"$server")"

    if [[ "$actual_type" == "http" && "$actual_url" == "$expected_url" ]]; then
        echo "match"
    else
        echo "mismatch"
    fi
}

ensure_user_mcp_json() {
    local name="$1"
    local json="$2"

    local status
    status="$(check_user_mcp_json "$name" "$json")"

    case "$status" in
    match)
        echo "    Exists: $name"
        ;;
    missing)
        "$claude_cmd" mcp add-json -s user "$name" "$json"
        ;;
    mismatch)
        echo "    Updating: $name"
        "$claude_cmd" mcp remove -s user "$name" >/dev/null 2>&1 || true
        "$claude_cmd" mcp add-json -s user "$name" "$json"
        ;;
    *)
        echo "    Skipped: $name (unknown check status: $status)"
        ;;
    esac
}

ensure_user_mcp_sse() {
    local name="$1"
    local url="$2"

    local status
    status="$(check_user_mcp_sse "$name" "$url")"

    case "$status" in
    match)
        echo "    Exists: $name"
        ;;
    missing)
        "$claude_cmd" mcp add --transport sse -s user "$name" "$url"
        ;;
    mismatch)
        echo "    Updating: $name"
        "$claude_cmd" mcp remove -s user "$name" >/dev/null 2>&1 || true
        "$claude_cmd" mcp add --transport sse -s user "$name" "$url"
        ;;
    *)
        echo "    Skipped: $name (unknown check status: $status)"
        ;;
    esac
}

ensure_user_mcp_http() {
    local name="$1"
    local url="$2"

    local status
    status="$(check_user_mcp_http "$name" "$url")"

    case "$status" in
    match)
        echo "    Exists: $name"
        ;;
    missing)
        "$claude_cmd" mcp add --transport http -s user "$name" "$url"
        ;;
    mismatch)
        echo "    Updating: $name"
        "$claude_cmd" mcp remove -s user "$name" >/dev/null 2>&1 || true
        "$claude_cmd" mcp add --transport http -s user "$name" "$url"
        ;;
    *)
        echo "    Skipped: $name (unknown check status: $status)"
        ;;
    esac
}

ensure_user_mcp_json "slack" '{"command":"npx","args":["-y","@anthropic/mcp-server-slack"],"env":{"SLACK_BOT_TOKEN":"${SLACK_BOT_TOKEN}","SLACK_TEAM_ID":"${SLACK_TEAM_ID}"}}'

ensure_user_mcp_json "slack-explorer" '{"command":"docker","args":["run","-i","--rm","--pull","always","ghcr.io/shibayu36/slack-explorer-mcp:latest"],"env":{"SLACK_USER_TOKEN":"${SLACK_USER_TOKEN}"}}'

ensure_user_mcp_sse "notion" "https://mcp.notion.com/sse"
ensure_user_mcp_json "playwright" '{"command":"npx","args":["-y","@playwright/mcp@latest"]}'
ensure_user_mcp_json "context7" '{"command":"{{ .chezmoi.homeDir }}/.local/bin/mcp-context7","args":[]}'
ensure_user_mcp_json "serena" '{"command":"uvx","args":["--from","git+https://github.com/oraios/serena","serena","start-mcp-server","--context","ide-assistant","--project",".","--enable-web-dashboard","false"]}'
ensure_user_mcp_json "markitdown" '{"command":"uvx","args":["markitdown-mcp"]}'
ensure_user_mcp_json "arxiv-mcp-server" '{"command":"uv","args":["tool","run","arxiv-mcp-server"]}'
ensure_user_mcp_json "tavily" '{"command":"{{ .chezmoi.homeDir }}/.local/bin/mcp-tavily","args":[]}'
ensure_user_mcp_json "postgres" '{"command":"{{ .chezmoi.homeDir }}/.local/bin/mcp-postgres","args":[]}'
ensure_user_mcp_http "gitmcp" "https://gitmcp.io/docs"
