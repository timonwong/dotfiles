theme = Catppuccin Mocha

custom-shader = ~/.config/ghostty/shaders/cursor_smear.glsl

font-family = "CaskaydiaCove NFM"
font-size = 12
font-feature = -liga, -calt

window-decoration = true
window-padding-x = 12,8
window-padding-y = 0,2

macos-titlebar-proxy-icon = hidden
macos-titlebar-style = tabs
macos-option-as-alt = true
mouse-hide-while-typing = true

shell-integration = detect
shell-integration-features = no-ssh-env

keybind = shift+enter=text:\n

# Clipboard
clipboard-read = allow
clipboard-write = allow
clipboard-paste-protection = false

# Update
auto-update-channel = tip

# Quick Terminal
keybind = global:super+grave_accent=toggle_quick_terminal
quick-terminal-position = top
quick-terminal-size = 40%,100%
quick-terminal-autohide = true

# Unbind special keys so they will be forwarded to Zellij
keybind = cmd+opt+left=unbind
keybind = cmd+opt+right=unbind
keybind = opt+left=unbind
keybind = opt+right=unbind
keybind = opt+up=unbind
keybind = opt+down=unbind
