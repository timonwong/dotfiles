# mise global configuration
# https://mise.jdx.dev/configuration.html

[tools]
# Node.js (used for global JS CLIs via npm/npx)
node = "lts"

# Terraform (replaces tenv)
terraform = "latest"

# Python (for tools that need it)
python = "3.12"

# uv (Python package manager)
uv = "latest"

# Poetry (Python dependency manager, via pipx/uvx)
"pipx:poetry" = "latest"

# Go
go = "latest"

# Rust
rust = "latest"

# Lua 5.4 runtime (replaces nix lua5_4)
lua = "5.4"

{{ if eq .chezmoi.os "darwin" -}}
# Python CLI tools (via pipx) - macOS only
"pipx:mac-cleanup" = "latest"
{{ end -}}

# OpenSpec CLI managed declaratively via mise npm backend
"npm:@fission-ai/openspec" = "1.2.0"

# oh-my-opencode CLI (platform binary selected via npm optionalDependencies)
"npm:oh-my-opencode" = "3.5.5"

# HAPI CLI for remote control of local AI coding sessions
"npm:@twsxtd/hapi" = "latest"

# Gemini CLI managed via npm backend (replaces nix gemini-cli)
"npm:@google/gemini-cli" = "latest"

[settings]
# Keep auto_install enabled for normal mise workflow.
# Process storms were caused by shell PATH/init ordering, not this flag.
auto_install = true

# Use idiomatic version files (.node-version, .python-version, etc.)
idiomatic_version_file = true

# Experimental features
experimental = true

# Trust specific project paths (more secure than trusting ~)
# Add your trusted project directories here
trusted_config_paths = [
    "~/Projects",
    "~/Work",
]

# Always keep latest versions
always_keep_download = false
always_keep_install = false

[env]
# Add local bin to PATH
_.path = ["./node_modules/.bin", "./bin"]
