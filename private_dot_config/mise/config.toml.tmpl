# mise global configuration
# https://mise.jdx.dev/configuration.html

[tools]
# Node.js (used for global JS CLIs via npm/npx)
node = "lts"
yarn = "latest"

# Python (for tools that need it)
python = "3.12"

# uv (Python package manager)
uv = "latest"

# pre-commit (Git hook framework, moved from nix to avoid dotnet-sdk compilation)
"pipx:pre-commit" = "latest"

# Go
go = "latest"

# Rust
rust = "latest"

# Lua 5.4 runtime (replaces nix lua5_4)
lua = "5.4"

# Managed by .github/workflows/update-mise-tools.yml
# Add new auto-updated tools between the markers below.
# mise-update:begin
"bun" = "1.3.12"
codex = "0.120.0"
"claude-code" = "2.1.108"
# codex-auth for switching codex accounts
"npm:@loongphy/codex-auth" = "0.2.3"
# Oxfmt is a high-performance formatter for the JavaScript ecosystem.
"npm:oxfmt" = "0.45.0"
# mise-update:end

helm = "v3.5.4"   # 暂时 pin 到 3.5.x
amp = "latest"

# Paseo: https://paseo.sh
"npm:@getpaseo/cli" = "latest"

# nowledge mem
"pipx:nmem-cli" = "latest"

# bb-browser: https://github.com/epiral/bb-browser
"npm:bb-browser" = "latest"

"github:timonwong/skimi" = { version = "latest" }

[settings]
lockfile = true

# Keep auto_install enabled for normal mise workflow.
# Process storms were caused by shell PATH/init ordering, not this flag.
auto_install = true

# Use idiomatic version files (.node-version, .python-version, etc.)
idiomatic_version_file = true

# Experimental features
experimental = true

# Trust specific project paths (more secure than trusting ~)
# Add your trusted project directories here
trusted_config_paths = [
    "~/Projects",
    "~/Work",
    "~/.codex/worktrees",
]

# Always keep latest versions
always_keep_download = false
always_keep_install = false

[env]
# Add local bin to PATH
_.path = ["./node_modules/.bin", "./bin"]
