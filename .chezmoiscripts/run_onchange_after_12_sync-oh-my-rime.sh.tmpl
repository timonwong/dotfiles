#!/usr/bin/env bash

set -euo pipefail

{{ include ".chezmoitemplates/shell/source_nix_env.sh" }}
if [[ -d "$HOME/.nix-profile/bin" ]]; then
    export PATH="$HOME/.nix-profile/bin:$PATH"
fi
PATH="/opt/homebrew/bin:/home/linuxbrew/.linuxbrew/bin:$PATH"

OH_MY_RIME_REPO_URL="https://github.com/Mintimate/oh-my-rime"
OH_MY_RIME_COMMIT="3e43e004725ef883805ec7dc7b19f639b2235d72"
OH_MY_RIME_TARBALL_URL="${OH_MY_RIME_REPO_URL}/archive/${OH_MY_RIME_COMMIT}.tar.gz"
WANXIANG_GRAM_URL="https://github.com/amzxyz/RIME-LMDG/releases/download/LTS/wanxiang-lts-zh-hans.gram"
WANXIANG_GRAM_FILENAME="wanxiang-lts-zh-hans.gram"
SQUIRREL_BIN="/Library/Input Methods/Squirrel.app/Contents/MacOS/Squirrel"

echo ":: [12] Syncing oh-my-rime"
echo "    Source: ${OH_MY_RIME_REPO_URL}"
echo "    Commit: ${OH_MY_RIME_COMMIT}"

platform="{{ .chezmoi.os }}"
case "$platform" in
darwin)
    TARGET_DIR="$HOME/Library/Rime"
    PLATFORM_FILE="squirrel.yaml"
    ;;
linux)
    TARGET_DIR="$HOME/.config/ibus/rime"
    PLATFORM_FILE="ibus_rime.yaml"
    ;;
*)
    echo "    Skipped (unsupported OS: $platform)"
    exit 0
    ;;
esac

GRAM_TARGET_FILE="$TARGET_DIR/$WANXIANG_GRAM_FILENAME"

STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/oh-my-rime"
INSTALLED_COMMIT_FILE="$STATE_DIR/installed_commit"
UPSTREAM_MANAGED_FILES_FILE="$STATE_DIR/upstream-managed-files.txt"

pretty_path() {
    local path="$1"
    printf '%s\n' "${path/#$HOME/~}"
}

download_file() {
    local url="$1"
    local output="$2"

    if command -v curl >/dev/null 2>&1; then
        curl -fsSL --retry 3 "$url" -o "$output"
    elif command -v wget >/dev/null 2>&1; then
        wget -qO "$output" "$url"
    else
        echo "    Error: curl or wget is required" >&2
        exit 1
    fi
}

manifest_is_complete() {
    local manifest_file="$1"

    [[ -s "$manifest_file" ]] || return 1

    while IFS= read -r rel; do
        [[ -n "$rel" ]] || continue
        [[ -e "$TARGET_DIR/$rel" ]] || return 1
    done <"$manifest_file"
}

copy_file() {
    local repo_root="$1"
    local rel="$2"
    local manifest="$3"
    local src="$repo_root/$rel"
    local dst="$TARGET_DIR/$rel"

    [[ -f "$src" ]] || return 0
    mkdir -p "$(dirname "$dst")"
    cp -f "$src" "$dst"
    printf '%s\n' "$rel" >>"$manifest"
}

copy_dir_files() {
    local repo_root="$1"
    local dir_rel="$2"
    local manifest="$3"
    local src_dir="$repo_root/$dir_rel"

    [[ -d "$src_dir" ]] || return 0

    while IFS= read -r src; do
        [[ -n "$src" ]] || continue
        local rel="${src#"$repo_root"/}"
        local dst="$TARGET_DIR/$rel"
        mkdir -p "$(dirname "$dst")"
        cp -f "$src" "$dst"
        printf '%s\n' "$rel" >>"$manifest"
    done < <(find "$src_dir" -type f | LC_ALL=C sort)
}

prune_empty_dirs() {
    local dir="$1"

    while [[ "$dir" != "$TARGET_DIR" && "$dir" != "/" ]]; do
        rmdir "$dir" 2>/dev/null || break
        dir="$(dirname "$dir")"
    done
}

remove_stale_managed_files() {
    local manifest="$1"
    local new_manifest="$2"

    [[ -f "$manifest" ]] || return 0

    while IFS= read -r rel; do
        [[ -n "$rel" ]] || continue
        if ! grep -qxF "$rel" "$new_manifest"; then
            rm -f "$TARGET_DIR/$rel"
            prune_empty_dirs "$(dirname "$TARGET_DIR/$rel")"
        fi
    done <"$manifest"
}
{{ include ".chezmoitemplates/shell/rime_deploy.sh" }}
mkdir -p "$STATE_DIR"
if [[ ! -d "$TARGET_DIR" ]]; then
    mkdir -p "$TARGET_DIR"
    echo "    Created: $(pretty_path "$TARGET_DIR")"
fi

gram_tmp="$(mktemp "$TARGET_DIR/${WANXIANG_GRAM_FILENAME}.XXXXXX")"
download_file "$WANXIANG_GRAM_URL" "$gram_tmp"
mv -f "$gram_tmp" "$GRAM_TARGET_FILE"
echo "    Synced grammar: $(pretty_path "$GRAM_TARGET_FILE")"

if [[ -f "$INSTALLED_COMMIT_FILE" ]] && [[ "$(cat "$INSTALLED_COMMIT_FILE")" == "$OH_MY_RIME_COMMIT" ]] && manifest_is_complete "$UPSTREAM_MANAGED_FILES_FILE"; then
    echo "    Upstream already synced: $(pretty_path "$TARGET_DIR")"
else
    tmpdir="$(mktemp -d "${TMPDIR:-/tmp}/oh-my-rime.XXXXXX")"
    cleanup() {
        rm -rf "$tmpdir"
    }
    trap cleanup EXIT

    archive_file="$tmpdir/oh-my-rime.tar.gz"
    extract_dir="$tmpdir/extract"
    new_upstream_manifest="$tmpdir/upstream-managed-files.txt"

    mkdir -p "$extract_dir"
    : >"$new_upstream_manifest"

    download_file "$OH_MY_RIME_TARBALL_URL" "$archive_file"
    tar -xzf "$archive_file" -C "$extract_dir"

    repo_root="$(find "$extract_dir" -mindepth 1 -maxdepth 1 -type d | head -n 1)"
    if [[ -z "$repo_root" ]]; then
        echo "    Error: failed to locate extracted oh-my-rime sources" >&2
        exit 1
    fi

    while IFS= read -r src; do
        [[ -n "$src" ]] || continue
        rel="$(basename "$src")"

        case "$rel" in
        ibus_rime.yaml)
            [[ "$PLATFORM_FILE" == "$rel" ]] || continue
            ;;
        squirrel.yaml)
            [[ "$PLATFORM_FILE" == "$rel" ]] || continue
            ;;
        weasel.yaml)
            continue
            ;;
        *.yaml | rime.lua)
            copy_file "$repo_root" "$rel" "$new_upstream_manifest"
            ;;
        esac
    done < <(find "$repo_root" -mindepth 1 -maxdepth 1 -type f | LC_ALL=C sort)

    copy_dir_files "$repo_root" "dicts" "$new_upstream_manifest"
    copy_dir_files "$repo_root" "lua" "$new_upstream_manifest"
    copy_dir_files "$repo_root" "opencc" "$new_upstream_manifest"

    LC_ALL=C sort -u "$new_upstream_manifest" -o "$new_upstream_manifest"
    remove_stale_managed_files "$UPSTREAM_MANAGED_FILES_FILE" "$new_upstream_manifest"
    cp "$new_upstream_manifest" "$UPSTREAM_MANAGED_FILES_FILE"
    printf '%s\n' "$OH_MY_RIME_COMMIT" >"$INSTALLED_COMMIT_FILE"
    echo "    Synced upstream: $(pretty_path "$TARGET_DIR")"
fi

deploy_rime
