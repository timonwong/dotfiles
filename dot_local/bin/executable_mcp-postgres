#!/usr/bin/env bash
# PostgreSQL MCP wrapper
# Resolve PostgreSQL connection string from gopass at runtime, then launch MCP server.

set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
source "$SCRIPT_DIR/lib/common"

require_cmd npx

PG_DSN_GOPASS_PATH="postgres/api_key"

# Allow explicit env override for CI/non-interactive runners.
if [[ -z "${PG_DSN:-}" ]]; then
    if ! PG_DSN="$(gopass_show_secret "$PG_DSN_GOPASS_PATH" 3 2>/dev/null)"; then
        log_error "Failed to read PostgreSQL DSN from gopass: $PG_DSN_GOPASS_PATH"
        exit 1
    fi
fi

if [[ -z "$PG_DSN" ]]; then
    log_error "PostgreSQL DSN is empty: $PG_DSN_GOPASS_PATH"
    exit 1
fi

# Reference server: read-only Postgres MCP
# Upstream server-postgres currently requires DSN as argv[1].
# This means DSN may be visible in process listings on the local machine.
log_warn "server-postgres requires DSN as argv; DSN may be visible in process list"
exec npx -y @modelcontextprotocol/server-postgres@0.6.2 "$PG_DSN" "$@"
