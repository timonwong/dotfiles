encryption = "age"

{{/* boolean feature tags */}}
{{- $work := promptBoolOnce . "work" "Is this a work machine" -}}{{/* true if this machine is a work machine */}}
{{- $private := not $work -}}{{/* true if this machine should have private configuration  */}}
{{- $headless := false -}}{{/* true if this machine does not have a screen and keyboard */}}
{{- $useEncryption := false -}}{{/* default false for users without encryption key */}}
{{- if hasKey . "useEncryption" -}}
{{-   $useEncryption = .useEncryption -}}
{{- end -}}
{{- if stdinIsATTY -}}
{{-   $useEncryption = promptBoolOnce . "useEncryption" "Enable encryption & SSH config (requires ~/.ssh/main key, default: false)" -}}
{{- end -}}
{{- "" -}}

{{- $hostname := .chezmoi.hostname -}}
{{- if not $work -}}
{{- $hostname = promptStringOnce . "hostname" "Hostname" -}}{{/* set the hostname */}}
{{- end -}}

{{/* prompt for user specific configuration */}}
{{- $useremail := promptStringOnce . "useremail" "Email address" -}}{{/* set the useremail address */}}
{{- $gitUsername := promptStringOnce . "gitUsername" "GitHub username" -}}{{/* set the github username */}}
{{- $gitEmail := promptStringOnce . "gitEmail" "GitHub useremail" -}}{{/* set the github useremail */}}

{{- $osID := .chezmoi.os -}}
{{- if (and (eq .chezmoi.os "linux") (hasKey .chezmoi.osRelease "id")) -}}
{{-   $osID = printf "%s-%s" .chezmoi.os .chezmoi.osRelease.id -}}
{{- end -}}

{{/* detect GitHub codespaces, VSCode remote containers, Docker containers, Multipass VMs, and Vagrant boxes */}}
{{- if or (env "CODESPACES") (env "REMOTE_CONTAINERS_IPC") (eq .chezmoi.username "root" "ubuntu" "vagrant" "vscode") -}}
{{-   $headless = true -}}
{{- end -}}

{{/* prompt for headless if stdin is a TTY */}}
{{- if stdinIsATTY -}}
{{-   $headless = promptBoolOnce . "headless" "headless" -}}
{{- else if hasKey . "headless" -}}
{{-   $headless = .headless -}}
{{- else -}}
{{-   $headless = ne .chezmoi.os "darwin" -}}
{{- end -}}

{{/* macOS specific: install Mac App Store apps */}}
{{- $installMasApps := false -}}
{{- if hasKey . "installMasApps" -}}
{{-   $installMasApps = .installMasApps -}}
{{- end -}}
{{- if and (eq .chezmoi.os "darwin") (stdinIsATTY) -}}
{{-   $installMasApps = promptBoolOnce . "installMasApps" "Install Mac App Store apps (requires Apple ID login)" -}}
{{- end -}}

{{/* macOS specific: home WiFi SSIDs for auto-volume (comma-separated) */}}
{{- $homeWifiSSIDs := "" -}}
{{- if hasKey . "homeWifiSSIDs" -}}
{{-   $homeWifiSSIDs = .homeWifiSSIDs -}}
{{- end -}}
{{- if and (eq .chezmoi.os "darwin") (stdinIsATTY) -}}
{{-   $homeWifiSSIDs = promptStringOnce . "homeWifiSSIDs" "Home WiFi SSIDs for auto-volume (comma-separated, e.g. Home-5G,Home-2.4G)" -}}
{{- end -}}

{{/* Claude Code provider@account selection (e.g. "deepseek" or "deepseek@work") */}}
{{- $claudeProviderAccount := "anthropic" -}}{{/* default provider, no account means "default" */}}
{{- if hasKey . "claudeProviderAccount" -}}
{{-   $claudeProviderAccount = .claudeProviderAccount -}}
{{- else if hasKey . "claudeProvider" -}}
{{-   $claudeProviderAccount = .claudeProvider -}}{{/* backward compatibility */}}
{{- end -}}

{{/* Codex provider@account selection (e.g. "openai" or "deepseek@work") */}}
{{- $codexProviderAccount := "openai" -}}
{{- if hasKey . "codexProviderAccount" -}}
{{-   $codexProviderAccount = .codexProviderAccount -}}
{{- end -}}

{{/* gopass password store repository */}}
{{- $gopassRepository := printf "git@github.com:%s/passwords.git" $gitUsername -}}
{{- if hasKey . "gopassRepository" -}}
{{-   $gopassRepository = .gopassRepository -}}
{{- else if and (stdinIsATTY) $useEncryption -}}
{{-   $gopassRepository = promptStringOnce . "gopassRepository" "gopass repository URL" $gopassRepository -}}
{{- end -}}

{{/* keys-manage backup repository */}}
{{- $keysRepository := printf "git@github.com:%s/keypairs.git" $gitUsername -}}
{{- if hasKey . "keysRepository" -}}
{{-   $keysRepository = .keysRepository -}}
{{- else if and (stdinIsATTY) $useEncryption -}}
{{-   $keysRepository = promptStringOnce . "keysRepository" "keys-manage backup repository URL" $keysRepository -}}
{{- end -}}

{{/* timezone: prefer local config, fallback to prompt/UTC */}}
{{- $timezone := "" -}}

{{- if eq .chezmoi.os "darwin" -}}
{{-   $timezone = (output "sh" "-c" "systemsetup -gettimezone 2>/dev/null | awk -F': ' '{print $2}' || true") | trim -}}
{{-   if eq $timezone "" -}}
{{-   $timezone = (output "sh" "-c" "readlink /etc/localtime 2>/dev/null | sed -E 's#.*/zoneinfo/##' || true") | trim -}}
{{-   end -}}
{{- else if eq .chezmoi.os "linux" -}}
{{-   $timezone = (output "sh" "-c" "cat /etc/timezone 2>/dev/null || true") | trim -}}
{{-   if eq $timezone "" -}}
{{-     $timezone = (output "sh" "-c" "timedatectl show -p Timezone --value 2>/dev/null || true") | trim -}}
{{-   end -}}
{{-   if eq $timezone "" -}}
{{-     $timezone = (output "sh" "-c" "readlink /etc/localtime 2>/dev/null | sed -E 's#.*/zoneinfo/##' || true") | trim -}}
{{-   end -}}
{{- end -}}

{{- if eq $timezone "" -}}
{{-   if stdinIsATTY -}}
{{-     $timezone = promptStringOnce . "timezone" "Timezone (e.g. Asia/Tokyo)" -}}
{{-   else if hasKey . "timezone" -}}
{{-     $timezone = .timezone -}}
{{-   else -}}
{{-     $timezone = "Etc/UTC" -}}
{{-   end -}}
{{- end -}}

[data]
hostname = {{ $hostname | quote }}
platform = {{ .chezmoi.os | quote }}
useremail = {{ $useremail | quote }}
gitUsername = {{ $gitUsername | quote }}
gitEmail = {{ $gitEmail | quote }}
work = {{ $work }}
private = {{ $private }}
headless = {{ $headless }}
useEncryption = {{ $useEncryption }}
installMasApps = {{ $installMasApps }}
homeWifiSSIDs = {{ $homeWifiSSIDs | quote }}
osid = {{ $osID | quote }}
timezone = {{ $timezone | quote }}
claudeProviderAccount = {{ $claudeProviderAccount | quote }}
codexProviderAccount = {{ $codexProviderAccount | quote }}
gopassRepository = {{ $gopassRepository | quote }}
keysRepository = {{ $keysRepository | quote }}

[edit]
command = "code"
args = ["--wait"]

[diff]
pager = "sh -c 'delta --config ~/.config/delta/config --paging=never || less -FRX'"
exclude = ["scripts"]

[merge]
command = "bash"
args = [
    "-c",
    "cp {{ "{{ .Target }}" }} {{ "{{ .Target }}" }}.base && code --new-window --wait --merge {{ "{{ .Destination }}" }} {{ "{{ .Target }}" }} {{ "{{ .Target }}" }}.base {{ "{{ .Source }}" }}",
]

[age]
# Use a wrapper command so decryption can bootstrap age automatically.
command = "{{ .chezmoi.sourceDir }}/.chezmoitemplates/shell/age_command_wrapper.sh"
identity = "~/.ssh/main"
recipientsFile = "~/.ssh/main.pub"
