# bat theme (fzf config is in ~/.custom/exports.sh)
export BAT_THEME="Dracula"

# gpg symmetric encryption
# Only set GPG_TTY in actual TTY environments
if tty -s 2>/dev/null; then
    export GPG_TTY=$(tty)
fi

{{ if eq .platform "darwin" -}}
