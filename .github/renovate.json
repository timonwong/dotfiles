{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":semanticCommits"],
  "timezone": "Asia/Tokyo",
  "schedule": ["after 1am and before 5am"],
  "prHourlyLimit": 2,
  "prConcurrentLimit": 5,
  "dependencyDashboard": true,
  "automerge": false,
  "platformAutomerge": false,
  "lockFileMaintenance": {
    "enabled": false
  },
  "nix": {
    "enabled": false
  },
  "packageRules": [
    {
      "description": "Nix updates are managed by repository-owned workflows",
      "matchManagers": ["nix"],
      "enabled": false
    },
    {
      "description": "Group GitHub Actions non-major updates",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "groupName": "github actions non-major"
    },
    {
      "description": "Automerge safe GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "description": "Require manual review for major updates",
      "matchUpdateTypes": ["major"],
      "automerge": false
    }
  ]
}
