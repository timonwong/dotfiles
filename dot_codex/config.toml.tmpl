#:schema https://developers.openai.com/codex/config-schema.json
# Codex CLI Configuration
# Managed by chezmoi - do not edit directly
# Run: chezmoi edit ~/.codex/config.toml

{{- /* codexProviderAccount can be openai or provider@label */ -}}
{{- $accountKey := "openai" -}}
{{- if hasKey . "codexProviderAccount" -}}
{{-   $accountKey = .codexProviderAccount -}}
{{- end -}}
{{- $providerName := (split "@" $accountKey)._0 -}}

# =============================================================================
# Core Settings
# =============================================================================

# Default model
model = "gpt-5.3-codex"

# Model provider (only for third-party providers)
{{- if ne $providerName "openai" }}
model_provider = "{{ $providerName }}"
{{- end }}

# Approval policy: untrusted | on-failure | on-request | never
approval_policy = "on-request"

# Sandbox mode: read-only | workspace-write | danger-full-access
sandbox_mode = "danger-full-access"

# Network access: enabled | disabled
network_access = "enabled"

# Disable response storage
disable_response_storage = true

# Windows WSL setup acknowledgement
windows_wsl_setup_acknowledged = true

# Suppress unstable feature warnings
suppress_unstable_features_warning = true

# =============================================================================
# Model Configuration
# =============================================================================

# Reasoning effort: none | minimal | low | medium | high | xhigh
model_reasoning_effort = "xhigh"

# Personality: none | friendly | pragmatic
personality = "pragmatic"

# Verbosity: low | medium | high
model_verbosity = "high"

# Web search mode: disabled | cached | live
web_search = "live"

# =============================================================================
# Project Documentation
# =============================================================================

project_doc_fallback_filenames = ["CLAUDE.md", "TEAM_GUIDE.md", ".agents.md", "CODEX.md"]
project_doc_max_bytes = 65536

# =============================================================================
# Feature Flags
# =============================================================================

[features]
shell_tool = true
memory_tool = true
apply_patch_freeform = true
unified_exec = true
shell_snapshot = true
runtime_metrics = true
undo = true
request_rule = true
responses_websockets = false
remote_compaction = true
remote_models = true
skill_mcp_dependency_install = true
skill_env_var_dependency_prompt = true

# =============================================================================
# Tools
# =============================================================================

[tools]
view_image = true

# =============================================================================
# History Settings
# =============================================================================

[history]
persistence = "save-all"
max_bytes = 104857600

# =============================================================================
# TUI Settings
# =============================================================================

[tui]
notifications = true
animations = true
show_tooltips = true

# =============================================================================
# Model Providers (Third-Party)
# =============================================================================

[model_providers.deepseek]
name = "Deepseek"
base_url = "https://api.deepseek.com/v1"

[model_providers.doubao]
name = "Doubao"
base_url = "https://ark.cn-beijing.volces.com/api/v3"

[model_providers.glm]
name = "Glm"
base_url = "https://open.bigmodel.cn/api/paas/v4"

[model_providers.harui]
name = "Harui"
base_url = "https://codex.harui.edu.kg"
wire_api = "responses"

[model_providers.kimi]
name = "Kimi"
base_url = "https://api.moonshot.ai/v1"

[model_providers.minimax]
name = "Minimax"
base_url = "https://api.minimax.io/v1"

[model_providers.naapi]
name = "Naapi"
base_url = "https://na.wanxiaot.com/v1"

[model_providers.qwen]
name = "Qwen"
base_url = "https://dashscope.aliyuncs.com/compatible-mode/v1"

# =============================================================================
# MCP Servers
# =============================================================================

[mcp_servers.notion]
command = "npx"
args = ["-y", "@anthropic/mcp-server-notion"]
[mcp_servers.notion.env]
NOTION_API_KEY = "${NOTION_API_KEY}"

[mcp_servers.context7]
command = "{{ .chezmoi.homeDir }}/.local/bin/mcp-context7"
args = []

[mcp_servers.postgres]
command = "{{ .chezmoi.homeDir }}/.local/bin/mcp-postgres"
args = []

[mcp_servers.serena]
command = "uvx"
args = ["--from", "git+https://github.com/oraios/serena@v0.1.4", "serena", "start-mcp-server", "--context", "codex", "--project-from-cwd", "--open-web-dashboard", "false"]
startup_timeout_sec = 30

[mcp_servers.slack]
command = "npx"
args = ["-y", "@anthropic/mcp-server-slack"]
[mcp_servers.slack.env]
SLACK_BOT_TOKEN = "${SLACK_BOT_TOKEN}"
SLACK_TEAM_ID = "${SLACK_TEAM_ID}"

[mcp_servers.tavily]
command = "{{ .chezmoi.homeDir }}/.local/bin/mcp-tavily"
args = []

[mcp_servers.gitmcp]
url = "https://gitmcp.io/docs"

# =============================================================================
# Profiles
# =============================================================================

[profiles.deep-review]
model_reasoning_effort = "xhigh"
approval_policy = "on-request"

[profiles.fast]
model_reasoning_effort = "low"
approval_policy = "on-request"

[profiles.research]
model_reasoning_effort = "xhigh"
web_search = "live"

# =============================================================================
# Shell Environment Policy
# =============================================================================

[shell_environment_policy]
inherit = "all"
exclude = []
ignore_default_excludes = true
experimental_use_profile = true

# =============================================================================
# Sandbox Workspace Write Settings
# =============================================================================

[sandbox_workspace_write]
network_access = true
exclude_slash_tmp = false
