#!/usr/bin/env bash
# Keys Manager - Unified backup and restore command
# Manages SSH/GPG/Age keys with OpenSSL PBKDF2-encrypted git repository
# Dependencies: bash, git, openssl, jq (python3 optional; fzf optional)
set -euo pipefail

# Resolve script directory robustly (works with symlinked entrypoints too).
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
# shellcheck source=lib/common.tmpl
source "$SCRIPT_DIR/lib/common"

# ===== Constants =====

# Paths from chezmoi data
KEYS_REPO="{{ .keysRepository }}"
REPO_DIR="$HOME/.local/share/keys-backup"
BACKUP_FILES_DIR="backup-files"  # Generic directory for all backed up files
BACKUP_LIST="$REPO_DIR/backup-list.txt"
BACKUP_LIST_ENC="$REPO_DIR/backup-list.txt.enc"
METADATA_FILE="$REPO_DIR/backup-metadata.json"
METADATA_FILE_ENC="$REPO_DIR/backup-metadata.json.enc"
CONTROL_STATE_DIR="$REPO_DIR/.keys-manage"
CONTROL_BASELINE_LIST="$CONTROL_STATE_DIR/backup-list.remote.sha256"
CONTROL_BASELINE_META="$CONTROL_STATE_DIR/backup-metadata.remote.sha256"
HISTORY_LOG="$REPO_DIR/backup-history.log"
RESTORE_SNAPSHOT_DIR="$REPO_DIR/restore-snapshots"

VERSION=2

# Return codes used for interactive navigation.
RC_BACK=10   # Go back to previous menu
RC_EXIT=130  # User aborted (e.g., ESC in fzf)

# Run a top-level command and normalize interactive navigation return codes.
# When there is no parent menu, Back/ESC should simply exit successfully.
run_cmd() {
    if "$@"; then
        return 0
    else
        local rc=$?
        if [[ $rc -eq $RC_BACK || $rc -eq $RC_EXIT ]]; then
            return 0
        fi
        return "$rc"
    fi
}

# ===== Libraries =====

# shellcheck source=lib/keys-manage/core.sh
source "$SCRIPT_DIR/lib/keys-manage/core.sh"
# shellcheck source=lib/keys-manage/backup.sh
source "$SCRIPT_DIR/lib/keys-manage/backup.sh"
# shellcheck source=lib/keys-manage/restore.sh
source "$SCRIPT_DIR/lib/keys-manage/restore.sh"
# shellcheck source=lib/keys-manage/status.sh
source "$SCRIPT_DIR/lib/keys-manage/status.sh"
# shellcheck source=lib/keys-manage/menu.sh
source "$SCRIPT_DIR/lib/keys-manage/menu.sh"

# ===== Main Entry Point =====

main() {
    trap 'clear_password_cache; cleanup_registered_temp_files' EXIT

    # Parse global options first
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                show_help
                exit 0
                ;;
            -p|--password)
                if [[ $# -lt 2 ]]; then
                    log_error "Missing value for $1"
                    return 1
                fi
                # Avoid exporting secrets to child processes. Keep the password in-memory
                # for this keys-manage process only.
                _CACHED_PASSWORD="$2"
                shift 2
                ;;
            *)
                # Not a global option, assume it's a command
                break
                ;;
        esac
    done

    # Extract command after global options
    local cmd="${1:-}"
    shift || true

    # If no command, show interactive menu
    if [[ -z "$cmd" ]]; then
        run_cmd cmd_menu
        return $?
    fi

    # Route commands
    case "$cmd" in
        # Backup commands
        init) run_cmd cmd_init "$@" ;;
        menu) run_cmd cmd_menu "$@" ;;
        select) run_cmd cmd_select "$@" ;;
        add) run_cmd cmd_add "$@" ;;
        remove) run_cmd cmd_remove "$@" ;;
        backup) run_cmd cmd_sync "$@" ;;
        sync) run_cmd cmd_sync "$@" ;;
        verify) run_cmd cmd_verify "$@" ;;
        history) run_cmd cmd_history "$@" ;;

        # Restore commands
        restore) run_cmd cmd_restore "$@" ;;
        versions|list-versions) run_cmd cmd_versions "$@" ;;
        validate) run_cmd cmd_validate "$@" ;;

        # Unified commands
        status) run_cmd cmd_status "$@" ;;
        password) run_cmd cmd_password "$@" ;;

        *)
            log_error "Unknown command: $cmd"
            echo "Run 'keys-manage --help' for usage"
            return 1
            ;;
    esac
}

main "$@"
